{
  "name": "FlowTime Dev",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-9.0",
  "workspaceFolder": "/workspaces/flowtime-vnext",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces,type=bind,consistency=cached",
  "initializeCommand": "ln -sfn \"$HOME/.claude\" /tmp/.claude-mount",
  "mounts": [
    "source=/tmp/.claude-mount,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "updateContentCommand": "bash .devcontainer/init.sh",
  "postCreateCommand": "bash .devcontainer/init.sh --post-create",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "github.useLocalServer": false,
        "dotnet.server.useOmnisharp": false,
        "editor.formatOnSave": true,
        "yaml.validate": true,
        "yaml.format.enable": true,
        "yaml.schemas": {
          "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml",
          "https://json.schemastore.org/github-action.json": ".github/actions/**/action.yml"
        }
      },
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "EditorConfig.EditorConfig",
        "github.vscode-github-actions",
        "mhutchie.git-graph",
        "redhat.vscode-yaml",
        "GitHub.copilot",
        "github.copilot-chat",
        "openai.chatgpt",
        "anthropic.claude-code",
        "humao.rest-client",
        "shd101wyy.markdown-preview-enhanced",
        "svelte.svelte-vscode"
      ],
      "mcp": {}
    }
  },
  "remoteUser": "vscode",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--sysctl",
    "net.ipv6.conf.all.disable_ipv6=1",
    "--sysctl",
    "net.ipv6.conf.default.disable_ipv6=1",
    "--network=flowtime-dev"
  ],
  "containerEnv": {
    "MSBUILDNOINPROCNODE": "1",
    "FLOWTIME_API_BASEURL": "http://flowtime-api:8081",
    "FLOWTIME_API_VERSION": "v1"
  },
  "forwardPorts": [
    1455,
    5173,
    8080,
    8090,
    8091
  ],
  "portsAttributes": {
    "1455": {
      "label": "Codex OAuth callback"
    },
    "5173": {
      "label": "Svelte UI Dev"
    },
    "8080": {
      "label": "FlowTime API",
      "requireLocalPort": true
    },
    "8081": {
      "label": "FlowTime API"
    },
    "8090": {
      "label": "FlowTime Sim API",
      "requireLocalPort": true
    }
  },
  "remoteEnv": {
    "NODE_OPTIONS": "--dns-result-order=ipv4first",
    "PATH": "${containerEnv:HOME}/.local/bin:${containerEnv:PATH}"
  }
}
