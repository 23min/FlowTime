{
  "name": "flowtime-ui-perf",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright automation for FlowTime topology UI performance",
  "scripts": {
    "test-ui": "playwright test --config tests/ui/playwright.config.ts",
    "test-ui:debug": "playwright test --debug --headed --config tests/ui/playwright.config.ts",
    "test-ui:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "^5.6.3"
  }
}
