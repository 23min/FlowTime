{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://flowtime.dev/schemas/time-travel-state.schema.json",
    "title": "FlowTime Time-Travel State Responses",
    "description": "Schema for FlowTime Engine time-travel state responses returned by /v1/runs/{runId}/state and /v1/runs/{runId}/state_window.",
    "oneOf": [
        { "$ref": "#/$defs/stateSnapshotResponse" },
        { "$ref": "#/$defs/stateWindowResponse" }
    ],
    "$defs": {
        "stateSnapshotResponse": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metadata", "bin", "nodes", "warnings"],
            "properties": {
                "metadata": { "$ref": "#/$defs/stateMetadata" },
                "bin": { "$ref": "#/$defs/binDetail" },
                "nodes": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/nodeSnapshot" },
                    "default": []
                },
                "edges": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/edgeSeries" },
                    "default": []
                },
                "edgeWarnings": { "$ref": "#/$defs/edgeWarnings" },
                "warnings": { "$ref": "#/$defs/stateWarnings" }
            }
        },
        "stateWindowResponse": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metadata", "window", "timestampsUtc", "nodes", "warnings"],
            "properties": {
                "metadata": { "$ref": "#/$defs/stateMetadata" },
                "window": { "$ref": "#/$defs/windowSlice" },
                "timestampsUtc": {
                    "type": "array",
                    "items": { "type": "string", "format": "date-time" }
                },
                "nodes": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/nodeSeries" },
                    "default": []
                },
                "edges": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/edgeSeries" },
                    "default": []
                },
                "edgeWarnings": { "$ref": "#/$defs/edgeWarnings" },
                "warnings": { "$ref": "#/$defs/stateWarnings" }
            }
        },
        "stateMetadata": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runId", "templateId", "mode", "schema", "storage", "edgeQuality"],
            "properties": {
                "runId": { "type": "string", "minLength": 1 },
                "templateId": { "type": "string", "minLength": 1 },
                "templateTitle": { "type": "string", "minLength": 1 },
                "templateNarrative": { "type": ["string", "null"] },
                "templateVersion": { "type": "string", "minLength": 1 },
                "mode": { "type": "string", "enum": ["simulation", "telemetry"] },
                "provenanceHash": { "$ref": "#/$defs/hash" },
                "telemetrySourcesResolved": { "type": "boolean" },
                "schema": { "$ref": "#/$defs/schemaMetadata" },
                "storage": { "$ref": "#/$defs/storageDescriptor" },
                "classCoverage": { "type": ["string", "null"], "enum": ["full", "partial", "missing", null] },
                "edgeQuality": { "type": "string", "enum": ["exact", "approx", "missing", "partialClass"] },
                "rng": {
                    "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/$defs/rngMetadata" }
                    ]
                }
            }
        },
        "schemaMetadata": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "version", "hash"],
            "properties": {
                "id": { "type": "string", "minLength": 1 },
                "version": { "type": "string", "minLength": 1 },
                "hash": { "$ref": "#/$defs/hash" }
            }
        },
        "storageDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["modelPath"],
            "properties": {
                "modelPath": { "type": "string", "minLength": 1 },
                "metadataPath": { "type": "string", "minLength": 1 },
                "provenancePath": { "type": "string", "minLength": 1 }
            }
        },
        "binDetail": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "durationMinutes"],
            "properties": {
                "index": { "type": "integer", "minimum": 0 },
                "startUtc": { "type": ["string", "null"], "format": "date-time" },
                "endUtc": { "type": ["string", "null"], "format": "date-time" },
                "durationMinutes": { "type": "number", "minimum": 0 }
            }
        },
        "windowSlice": {
            "type": "object",
            "additionalProperties": false,
            "required": ["startBin", "endBin", "binCount"],
            "properties": {
                "startBin": { "type": "integer", "minimum": 0 },
                "endBin": { "type": "integer", "minimum": 0 },
                "binCount": { "type": "integer", "minimum": 1 }
            }
        },
        "nodeSnapshot": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "metrics", "derived", "telemetry"],
            "properties": {
                "id": { "$ref": "#/$defs/nodeId" },
                "kind": { "type": "string", "minLength": 1 },
                "nodeLogicalType": { "type": ["string", "null"], "minLength": 1 },
                "metrics": { "$ref": "#/$defs/nodeMetrics" },
                "seriesMetadata": { "$ref": "#/$defs/seriesMetadata" },
                "byClass": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/$defs/classMetrics" }
                },
                "constraints": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/$defs/constraintMetrics" }
                },
                "constraintStatus": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                },
                "derived": { "$ref": "#/$defs/nodeDerivedMetrics" },
                "telemetry": { "$ref": "#/$defs/nodeTelemetryInfo" },
                "aliases": { "$ref": "#/$defs/aliasDictionary" },
                "dispatchSchedule": {
                    "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/$defs/dispatchScheduleDescriptor" }
                    ]
                },
                "sla": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/slaMetricDescriptor" },
                    "default": []
                }
            }
        },
        "nodeSeries": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "series", "telemetry"],
            "properties": {
                "id": { "$ref": "#/$defs/nodeId" },
                "kind": { "type": "string", "minLength": 1 },
                "nodeLogicalType": { "type": ["string", "null"], "minLength": 1 },
                "series": {
                    "type": "object",
                    "minProperties": 1,
                    "additionalProperties": { "$ref": "#/$defs/numericSeries" }
                },
                "seriesMetadata": { "$ref": "#/$defs/seriesMetadata" },
                "byClass": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "additionalProperties": { "$ref": "#/$defs/numericSeries" }
                    }
                },
                "constraints": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/$defs/constraintSeries" }
                },
                "constraintStatus": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/$defs/numericSeries" }
                },
                "telemetry": { "$ref": "#/$defs/nodeTelemetryInfo" },
                "aliases": { "$ref": "#/$defs/aliasDictionary" },
                "dispatchSchedule": {
                    "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/$defs/dispatchScheduleDescriptor" }
                    ]
                },
                "sla": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/slaSeriesDescriptor" },
                    "default": []
                }
            }
        },
        "edgeSeries": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "from", "to", "series"],
            "properties": {
                "id": { "$ref": "#/$defs/nodeId" },
                "from": { "$ref": "#/$defs/nodeId" },
                "to": { "$ref": "#/$defs/nodeId" },
                "edgeType": { "type": ["string", "null"], "minLength": 1 },
                "field": { "type": ["string", "null"], "minLength": 1 },
                "multiplier": { "$ref": "#/$defs/nullableNumber" },
                "lag": { "type": ["integer", "null"], "minimum": 0 },
                "series": {
                    "type": "object",
                    "minProperties": 1,
                    "additionalProperties": { "$ref": "#/$defs/numericSeries" }
                },
                "seriesMetadata": { "$ref": "#/$defs/seriesMetadata" },
                "byClass": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "additionalProperties": { "$ref": "#/$defs/numericSeries" }
                    }
                }
            }
        },
        "constraintMetrics": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metrics"],
            "properties": {
                "metrics": {
                    "type": "object",
                    "minProperties": 1,
                    "additionalProperties": { "$ref": "#/$defs/nullableNumber" }
                },
                "seriesMetadata": { "$ref": "#/$defs/seriesMetadata" }
            }
        },
        "constraintSeries": {
            "type": "object",
            "additionalProperties": false,
            "required": ["series"],
            "properties": {
                "series": {
                    "type": "object",
                    "minProperties": 1,
                    "additionalProperties": { "$ref": "#/$defs/numericSeries" }
                },
                "seriesMetadata": { "$ref": "#/$defs/seriesMetadata" }
            }
        },
        "nodeMetrics": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "arrivals": { "$ref": "#/$defs/nullableNumber" },
                "served": { "$ref": "#/$defs/nullableNumber" },
                "errors": { "$ref": "#/$defs/nullableNumber" },
                "attempts": { "$ref": "#/$defs/nullableNumber" },
                "failures": { "$ref": "#/$defs/nullableNumber" },
                "exhaustedFailures": { "$ref": "#/$defs/nullableNumber" },
                "retryEcho": { "$ref": "#/$defs/nullableNumber" },
                "retryBudgetRemaining": { "$ref": "#/$defs/nullableNumber" },
                "queue": { "$ref": "#/$defs/nullableNumber" },
                "capacity": { "$ref": "#/$defs/nullableNumber" },
                "parallelism": { "$ref": "#/$defs/nullableNumber" },
                "externalDemand": { "$ref": "#/$defs/nullableNumber" },
                "maxAttempts": { "$ref": "#/$defs/nullableNumber" }
            }
        },
        "classMetrics": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "arrivals": { "$ref": "#/$defs/nullableNumber" },
                "served": { "$ref": "#/$defs/nullableNumber" },
                "errors": { "$ref": "#/$defs/nullableNumber" },
                "queue": { "$ref": "#/$defs/nullableNumber" },
                "capacity": { "$ref": "#/$defs/nullableNumber" },
                "processingTimeMsSum": { "$ref": "#/$defs/nullableNumber" },
                "servedCount": { "$ref": "#/$defs/nullableNumber" }
            }
        },
        "nodeDerivedMetrics": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "utilization": { "$ref": "#/$defs/nullableNumber" },
                "latencyMinutes": { "$ref": "#/$defs/nullableNumber" },
                "serviceTimeMs": { "$ref": "#/$defs/nullableNumber" },
                "flowLatencyMs": { "$ref": "#/$defs/nullableNumber" },
                "throughputRatio": { "$ref": "#/$defs/nullableNumber" },
                "retryTax": { "$ref": "#/$defs/nullableNumber" },
                "color": { "type": ["string", "null"], "minLength": 1 }
            }
        },
        "nodeTelemetryInfo": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sources", "warnings"],
            "properties": {
                "sources": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "default": [],
                    "uniqueItems": true
                },
                "warnings": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/nodeTelemetryWarning" },
                    "default": []
                }
            }
        },
        "slaMetricDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "status"],
            "properties": {
                "kind": { "$ref": "#/$defs/slaKind" },
                "status": { "$ref": "#/$defs/slaStatus" },
                "threshold": { "$ref": "#/$defs/nullableNumber" },
                "value": { "$ref": "#/$defs/nullableNumber" }
            }
        },
        "slaSeriesDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "status", "values"],
            "properties": {
                "kind": { "$ref": "#/$defs/slaKind" },
                "status": { "$ref": "#/$defs/slaStatus" },
                "threshold": { "$ref": "#/$defs/nullableNumber" },
                "values": { "$ref": "#/$defs/numericSeries" }
            }
        },
        "slaKind": {
            "type": "string",
            "enum": ["completion", "backlogAge", "scheduleAdherence"]
        },
        "slaStatus": {
            "type": "string",
            "enum": ["ok", "unavailable", "noEvents"]
        },
        "nodeTelemetryWarning": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
                "code": { "type": "string", "minLength": 1 },
                "message": { "type": "string", "minLength": 1 },
                "severity": { "type": ["string", "null"], "minLength": 1 }
            }
        },
        "seriesMetadata": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/seriesSemantics" }
        },
        "seriesSemantics": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "aggregation": {
                    "type": ["string", "null"],
                    "enum": ["avg", "sum", "min", "max", "p50", "p95", "p99", "unknown", null]
                },
                "origin": {
                    "type": ["string", "null"],
                    "enum": ["derived", "explicit", "telemetry", "model", "unknown", null]
                }
            }
        },
        "stateWarnings": {
            "type": "array",
            "items": { "$ref": "#/$defs/stateWarning" },
            "default": []
        },
        "edgeWarnings": {
            "type": "object",
            "additionalProperties": {
                "type": "array",
                "items": { "$ref": "#/$defs/stateWarning" },
                "default": []
            },
            "default": {}
        },
        "stateWarning": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
                "code": { "type": "string", "minLength": 1 },
                "message": { "type": "string", "minLength": 1 },
                "severity": { "type": "string", "minLength": 1 },
                "nodeId": { "$ref": "#/$defs/nodeId" },
                "startBin": { "type": ["integer", "null"], "minimum": 0 },
                "endBin": { "type": ["integer", "null"], "minimum": 0 },
                "signal": { "type": ["string", "null"], "minLength": 1 }
            }
        },
        "aliasDictionary": {
            "type": ["object", "null"],
            "default": null,
            "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "dispatchScheduleDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "periodBins", "phaseOffset"],
            "properties": {
                "kind": { "type": "string", "minLength": 1 },
                "periodBins": { "type": "integer", "minimum": 1 },
                "phaseOffset": { "type": "integer" },
                "capacitySeries": { "type": ["string", "null"], "minLength": 1 }
            }
        },
        "rngMetadata": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "seed"],
            "properties": {
                "kind": { "type": "string", "minLength": 1 },
                "seed": { "type": "integer" }
            }
        },
        "numericSeries": {
            "type": "array",
            "items": { "$ref": "#/$defs/nullableNumber" }
        },
        "nullableNumber": { "type": ["number", "null"] },
        "nodeId": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
    }
}
