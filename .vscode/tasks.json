{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet build",
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "build-sim",
      "type": "shell",
      "command": "dotnet build src/FlowTime.Sim.Core/FlowTime.Sim.Core.csproj && dotnet build src/FlowTime.Sim.Service/FlowTime.Sim.Service.csproj && dotnet build src/FlowTime.Sim.Cli/FlowTime.Sim.Cli.csproj",
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "dotnet test --nologo",
      "group": "test",
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "test-sim",
      "type": "shell",
      "command": "dotnet test tests/FlowTime.Sim.Tests/FlowTime.Sim.Tests.csproj --nologo",
      "group": "test",
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "start-api",
      "type": "shell",
      "command": "$env:ASPNETCORE_URLS = 'http://0.0.0.0:8081'; dotnet run --project src/FlowTime.API",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "start-api-integration",
      "type": "shell",
      "command": "dotnet run --project src/FlowTime.API",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "options": {
        "env": {
          "ASPNETCORE_URLS": "http://0.0.0.0:8081",
          "FLOWTIME_DATA_DIR": "/workspaces/flowtime-vnext/data"
        }
      }
    },
    {
      "label": "stop-api",
      "type": "shell",
      "command": "pkill -f 'FlowTime.API' || echo 'No API process found'",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "start-sim-api",
      "type": "shell",
      "command": "dotnet run --project src/FlowTime.Sim.Service",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "options": {
        "env": {
          "ASPNETCORE_URLS": "http://0.0.0.0:8090"
        }
      }
    },
    {
      "label": "start-mcp-server",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "options": {
        "cwd": "${workspaceFolder}/tools/mcp-server",
        "env": {
          "FLOWTIME_SIM_API_URL": "http://localhost:8090/api/v1",
          "FLOWTIME_SIM_DRAFT_API_URL": "http://localhost:8090/api/v1",
          "FLOWTIME_API_URL": "http://localhost:8081/v1",
          "FLOWTIME_DATA_DIR": "${workspaceFolder}/data",
          "FLOWTIME_TEMPLATES_DIR": "${workspaceFolder}/templates",
          "FLOWTIME_TEMPLATES_DRAFT_DIR": "${workspaceFolder}/templates-draft",
          "MCP_MAX_BINS": "1000"
        }
      }
    },
    {
      "label": "stop-sim-api",
      "type": "shell",
      "command": "pkill -f 'FlowTime.Sim.Service' || echo 'No Sim API process found'",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "start-ui",
      "type": "shell",
      "command": "dotnet run --project src/FlowTime.UI",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "stop-ui",
      "type": "shell",
      "command": "pkill -f 'FlowTime.UI' || echo 'No UI process found'",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "start-svelte-ui",
      "type": "shell",
      "command": "pnpm dev --host",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 0,
          "location": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "options": {
        "cwd": "${workspaceFolder}/ui"
      }
    },
    {
      "label": "stop-svelte-ui",
      "type": "shell",
      "command": "pkill -f 'node.*vite' || echo 'No Svelte UI process found'",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "stop-all",
      "type": "shell",
      "command": "bash scripts/stop-all.sh",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "kill-port-8080",
      "type": "shell",
      "command": "lsof -ti:8081 | xargs -r ps -p | grep dotnet | awk '{print $1}' | xargs -r kill -TERM && echo 'Killed dotnet on 8080' || echo 'No dotnet process on 8080'",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "demo-1-build-engine",
      "detail": "Build the Rust flowtime-engine release binary (required by the Engine API).",
      "type": "shell",
      "command": ". \"$HOME/.cargo/env\" && cargo build --release",
      "options": {
        "cwd": "${workspaceFolder}/engine"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "demo-2-start-api",
      "detail": "Start the .NET Engine API on :8081 (WebSocket bridge to flowtime-engine session).",
      "type": "shell",
      "command": "dotnet run --project src/FlowTime.API",
      "isBackground": true,
      "options": {
        "env": {
          "ASPNETCORE_URLS": "http://0.0.0.0:8081"
        }
      },
      "dependsOn": ["demo-1-build-engine"],
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 0,
          "location": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^(Building|info:)",
          "endsPattern": "Now listening on|Application started"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "group": "demo"
      }
    },
    {
      "label": "demo-3-start-ui",
      "detail": "Start the Svelte dev server on :5173 (the What-If page).",
      "type": "shell",
      "command": "pnpm dev --host",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 0,
          "location": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "group": "demo"
      }
    },
    {
      "label": "demo-start",
      "detail": "Full demo startup: build engine → start API → start Svelte UI. Then open http://localhost:5173/what-if",
      "dependsOn": ["demo-1-build-engine", "demo-2-start-api", "demo-3-start-ui"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "demo-teardown",
      "detail": "Stop the Engine API and Svelte dev server started by the demo tasks.",
      "type": "shell",
      "command": "bash scripts/stop-all.sh",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}
