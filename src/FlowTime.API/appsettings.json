{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Diagnostics": {
    "Hover": {
      "RollingMaxRows": 720
    },
    "Canvas": {
      "RollingMaxRows": 720
    }
  },
  "RustEngine": {
    "Enabled": false,
    "BinaryPath": ""
  },
  "AllowedHosts": "*"
}
