    private void RefreshDiagnosticsConfig()
    {
        var hoverOptions = DiagnosticsOptionsAccessor.Value?.Hover;
        diagnosticsOverlayEnabled = hoverOptions?.EnableOverlay ?? false;

        if (TryGetQueryFlag("diag", out var diagToken))
        {
            diagnosticsOverlayEnabled = string.IsNullOrWhiteSpace(diagToken)
                || !string.Equals(diagToken, "0", StringComparison.OrdinalIgnoreCase);
        }

        diagnosticsDisableHoverCache = false;
        if (TryGetQueryFlag("hovercache", out var hoverCacheToken))
        {
            diagnosticsDisableHoverCache = IsQueryFlagDisabled(hoverCacheToken);
        }

        diagnosticsUploadUrl = null;
        diagnosticsUploadIntervalMs = 0;

        if (hoverOptions is not null &&
            hoverOptions.AutoUploadEnabled &&
            !string.IsNullOrWhiteSpace(hoverOptions.UploadPath))
        {
            diagnosticsUploadUrl = CombineDiagnosticsUrl(
                FlowTimeApiOptionsAccessor.Value?.BaseUrl,
                hoverOptions.UploadPath);
            diagnosticsUploadIntervalMs = Math.Max(1, hoverOptions.UploadIntervalSeconds) * 1000;
        }
    }

    private static string CombineDiagnosticsUrl(string? baseUrl, string path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return baseUrl ?? string.Empty;
        }

        if (Uri.TryCreate(path, UriKind.Absolute, out var absolute))
        {
            return absolute.ToString();
        }

        if (!string.IsNullOrWhiteSpace(baseUrl) && Uri.TryCreate(baseUrl, UriKind.Absolute, out var root))
        {
            return new Uri(root, path).ToString();
        }

        return path;
    }

    private bool TryGetQueryFlag(string key, out string? value)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (string.IsNullOrEmpty(uri.Query))
        {
            value = null;
            return false;
        }

        var segments = uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
        foreach (var segment in segments)
        {
            var pair = segment.Split('=', 2);
            if (pair.Length == 0)
            {
                continue;
            }

            if (string.Equals(pair[0], key, StringComparison.OrdinalIgnoreCase))
            {
                value = pair.Length > 1 ? Uri.UnescapeDataString(pair[1]) : string.Empty;
                return true;
            }
        }

        value = null;
        return false;
    }

    private static bool IsQueryFlagDisabled(string? token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            return true;
        }

        return token.Equals("0", StringComparison.OrdinalIgnoreCase) ||
               token.Equals("false", StringComparison.OrdinalIgnoreCase) ||
               token.Equals("off", StringComparison.OrdinalIgnoreCase) ||
               token.Equals("disable", StringComparison.OrdinalIgnoreCase) ||
               token.Equals("disabled", StringComparison.OrdinalIgnoreCase);
    }

    private void SyncOperationalViewFlagFromOverlay(bool resetSavedValues = false)
    {
        var derivedOperational = !overlaySettings.EnableFullDag
            && !overlaySettings.IncludeExpressionNodes
            && !overlaySettings.IncludeConstNodes;

        operationalViewOnly = derivedOperational;

        if (resetSavedValues)
        {
            savedIncludeExpressionNodes = null;
            savedIncludeConstNodes = null;
            savedEnableFullDag = null;
            operationalTogglePending = false;
        }
    }

