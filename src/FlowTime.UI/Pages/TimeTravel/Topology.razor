    private void UpdateClassMetadata(SeriesIndex index)
    {
        if (index.Classes is { Count: > 0 })
        {
            var ordered = index.Classes
                .Where(entry => !string.IsNullOrWhiteSpace(entry.Id))
                .OrderBy(entry => entry.DisplayName ?? entry.Id, StringComparer.OrdinalIgnoreCase)
                .Select(entry => entry.Id)
                .ToArray();

            availableClasses = ordered;
            classDisplayNames = index.Classes
                .Where(entry => !string.IsNullOrWhiteSpace(entry.Id))
                .ToDictionary(entry => entry.Id, entry => entry.DisplayName ?? entry.Id, StringComparer.OrdinalIgnoreCase);
            classMetadata = index.Classes
                .Where(entry => !string.IsNullOrWhiteSpace(entry.Id))
                .ToDictionary(entry => entry.Id, entry => entry, StringComparer.OrdinalIgnoreCase);
        }
        else
        {
            availableClasses = Array.Empty<string>();
            classDisplayNames = emptyClassLabels;
            classMetadata = emptyClassMetadata;
        }

        Logger?.LogInformation("Topology class metadata for run {RunId}: coverage={Coverage}; classes={Count}; values={Classes}",
            RunId,
            index.ClassCoverage,
            availableClasses.Count,
            availableClasses.Count > 0 ? string.Join(", ", availableClasses) : "(none)");

        classCoverageState = index.ClassCoverage;
    }

    private void UpdateDispatchEntries()
    {
        if (topologyGraph is null)
        {
            dispatchScheduleEntries = Array.Empty<DispatchScheduleEntry>();
            return;
        }

        var entries = topologyGraph.Nodes
            .Where(n => n.DispatchSchedule is not null)
            .Select(n =>
            {
                var schedule = n.DispatchSchedule!;
                return new DispatchScheduleEntry(
                    n.Id,
                    FormatDispatchSummary(schedule),
                    FormatDispatchCapacity(schedule));
            })
            .OrderBy(e => e.NodeId, StringComparer.OrdinalIgnoreCase)
            .ToList();

        dispatchScheduleEntries = entries;
    }

