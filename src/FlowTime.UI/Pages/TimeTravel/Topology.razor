    private const string lastRunStorageKey = "ft.topology.lastRunId";

    private void UpdateActiveMetrics(int bin)
    {
        var context = CaptureBinDataContext();
        var sparklinesSnapshot = nodeSparklines ?? new Dictionary<string, NodeSparklineData>(StringComparer.OrdinalIgnoreCase);
        var missingSnapshot = nodesMissingSparkline ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var result = ComputeActiveMetricsSnapshot(context, bin, sparklinesSnapshot, missingSnapshot, CancellationToken.None);
        ApplyActiveMetricsResult(result);
    }

    private static ActiveMetricsComputationResult ComputeActiveMetricsSnapshot(
        BinDataComputationContext context,
        int bin,
        IReadOnlyDictionary<string, NodeSparklineData> nodeSparklinesSnapshot,
        IReadOnlyCollection<string> nodesMissingSnapshot,
        CancellationToken token)
    {
        var classFilteredNodes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (context.WindowData is null)
        {
            return new ActiveMetricsComputationResult(
                new Dictionary<string, NodeBinMetrics>(StringComparer.OrdinalIgnoreCase),
                new Dictionary<string, IReadOnlyList<ClassContribution>>(StringComparer.OrdinalIgnoreCase),
                classFilteredNodes,
                new Dictionary<string, IReadOnlyList<NodeConstraintBadgeDto>>(StringComparer.OrdinalIgnoreCase),
                bin,
                bin.ToString(CultureInfo.InvariantCulture),
                string.Empty,
                context.IncludeInspectorDetails);
        }

        var spanStart = context.WindowData.Window.StartBin;
        var localIndex = bin - spanStart;
        if (localIndex < 0 || localIndex >= context.WindowData.Window.BinCount)
        {
            return new ActiveMetricsComputationResult(
                new Dictionary<string, NodeBinMetrics>(StringComparer.OrdinalIgnoreCase),
                new Dictionary<string, IReadOnlyList<ClassContribution>>(StringComparer.OrdinalIgnoreCase),
                classFilteredNodes,
                new Dictionary<string, IReadOnlyList<NodeConstraintBadgeDto>>(StringComparer.OrdinalIgnoreCase),
                bin,
                bin.ToString(CultureInfo.InvariantCulture),
                string.Empty,
                context.IncludeInspectorDetails);
        }

        var metrics = new Dictionary<string, NodeBinMetrics>(StringComparer.OrdinalIgnoreCase);
        var constraintBadgeMap = new Dictionary<string, IReadOnlyList<NodeConstraintBadgeDto>>(StringComparer.OrdinalIgnoreCase);
        var selectionTimestamp = localIndex >= 0 && localIndex < context.Timestamps.Count
            ? context.Timestamps[localIndex]
            : (DateTimeOffset?)null;

        var classContributionMap = context.IncludeClassContributions
            ? new Dictionary<string, IReadOnlyList<ClassContribution>>(StringComparer.OrdinalIgnoreCase)
            : new Dictionary<string, IReadOnlyList<ClassContribution>>(StringComparer.OrdinalIgnoreCase);

        foreach (var node in context.WindowData.Nodes)
        {
            token.ThrowIfCancellationRequested();

            var classDataFound = !context.HasClassSelection;
            double classVolume = 0d;

            double? Get(string key) => GetSeriesValueSnapshot(node, key, localIndex, ref classDataFound, ref classVolume, context.HasClassSelection, context.SelectedClasses);

            var topoNode = context.FindNode(node.Id);
            var nodeCategory = ResolveNodeCategory(topoNode, node);
            var nodeIdentity = ResolveAnalyticalIdentity(topoNode, node);
            var hasQueueSemantics = ResolveHasQueueSemantics(topoNode, node);
            var hasServiceSemantics = ResolveHasServiceSemantics(topoNode, node);
            var displayKind = ResolveNodeDisplayKind(topoNode, node);
            var isPmf = IsPmfIdentity(nodeIdentity);
            var isComputed = IsComputedCategory(nodeCategory);
            var distribution = topoNode?.Semantics?.Distribution;
            var (modeProbability, modeValue) = ComputePmfMode(distribution);
            var arrivals = Get("arrivals");
            var served = Get("served");
            var errors = Get("errors");
            var attempts = Get("attempts");
            var failures = Get("failures");
            var retryEcho = Get("retryEcho");
            var exhaustedFailures = Get("exhaustedFailures");
            var retryBudgetRemaining = Get("retryBudgetRemaining");
            var capacity = Get("capacity");
            var parallelism = Get("parallelism");
            var throughput = Get("throughputRatio");
            var utilization = Get("utilization");
            var queue = Get("queue");
            var latency = Get("latencyMinutes");
            var serviceTime = Get("serviceTimeMs");
            var retryTax = Get("retryTax");

            var completionSla = context.HasClassSelection ? null : GetSlaValueSnapshot(node, "completion", localIndex);
            var scheduleAdherence = context.HasClassSelection ? null : GetSlaValueSnapshot(node, "scheduleAdherence", localIndex);
            var hasSchedule = node.DispatchSchedule is not null;
            var isSinkNode = IsSinkCategory(nodeCategory) || IsSinkRole(topoNode?.NodeRole);
            double? successRate = completionSla ?? throughput;
            if (isSinkNode && hasSchedule)
            {
                successRate = scheduleAdherence;
            }
            if (successRate is null && !(isSinkNode && hasSchedule) && arrivals.HasValue && arrivals.Value > 0 && served.HasValue)
            {
                successRate = served.Value / arrivals.Value;
            }
            double? errorRate = null;
            var denominator = arrivals ?? served;
            if (errors.HasValue && denominator.HasValue && denominator.Value > 0)
            {
                errorRate = errors.Value / denominator.Value;
            }

            double? customValue = null;
            string? customLabel = null;
            double? pmfProbability = null;
            double? pmfSupportValue = null;

            var rawMetrics = new Dictionary<string, double?>(StringComparer.OrdinalIgnoreCase);
            void SetRaw(string key, double? value)
            {
                if (value.HasValue)
                {
                    rawMetrics[key] = value.Value;
                }
            }

            SetRaw("arrivals", arrivals);
            SetRaw("served", served);
            SetRaw("errors", errors);
            SetRaw("attempts", attempts);
            SetRaw("failures", failures);
            SetRaw("exhaustedFailures", exhaustedFailures);
            SetRaw("retryEcho", retryEcho);
            SetRaw("retryBudgetRemaining", retryBudgetRemaining);
            SetRaw("queue", queue);
            SetRaw("retryTax", retryTax);
            SetRaw("capacity", capacity);
            SetRaw("parallelism", parallelism);
            if (capacity.HasValue && parallelism.HasValue)
            {
                SetRaw("effectiveCapacity", capacity.Value * parallelism.Value);
            }
            SetRaw("completionSla", completionSla);
            if (hasSchedule)
            {
                rawMetrics["scheduleAdherence"] = scheduleAdherence;
            }
            SetRaw("flowLatencyMs", Get("flowLatencyMs"));
            SetRaw("maxAttempts", topoNode?.Semantics?.MaxAttempts);

            if (isComputed && !isPmf)
            {
                if (nodeSparklinesSnapshot.TryGetValue(node.Id, out var sparkline))
                {
                    var sampled = SampleSparklineAt(sparkline, bin);
                    if (sampled.HasValue)
                    {
                        customValue = sampled;
                        customLabel = binValueLabel;
                    }
                }

                if (!customValue.HasValue && IsExpressionNode(nodeCategory, nodeIdentity) && nodesMissingSnapshot.Contains(node.Id))
                {
                    customLabel = missingSeriesMessage;
                }
            }

            if (isPmf)
            {
                var expectation = ComputePmfExpectation(distribution);
                if (expectation.HasValue)
                {
                    customValue = expectation;
                    customLabel = pmfExpectationLabel;
                }

                pmfProbability = modeProbability;
                pmfSupportValue = modeValue ?? expectation;

                if (string.IsNullOrWhiteSpace(customLabel) && nodesMissingSnapshot.Contains(node.Id))
                {
                    customLabel = missingSeriesMessage;
                }
            }

            if (!customValue.HasValue)
            {
                double? direct = Get("values");
                if (!direct.HasValue)
                {
                    direct = Get($"series:{node.Id}") ?? Get(node.Id);
                }

                if (direct.HasValue && double.IsFinite(direct.Value))
                {
                    customValue = direct;
                    customLabel = isPmf ? pmfExpectationLabel : binValueLabel;
                }
            }

            var queueLatencyStatus = ResolveQueueLatencyStatus(node, localIndex);

            metrics[node.Id] = new NodeBinMetrics(
                successRate,
                utilization,
                errorRate,
                queue,
                latency,
                selectionTimestamp,
                CustomValue: customValue,
                CustomLabel: customLabel,
                PmfProbability: pmfProbability,
                PmfValue: pmfSupportValue,
                NodeKind: displayKind,
                ServiceTimeMs: serviceTime,
                FlowLatencyMs: Get("flowLatencyMs"),
                RetryTax: retryTax,
                RawMetrics: rawMetrics.Count == 0 ? null : rawMetrics,
                Metadata: topoNode?.Semantics?.Metadata,
                QueueLatencyStatus: queueLatencyStatus)
            {
                NodeCategory = nodeCategory,
                AnalyticalIdentity = nodeIdentity,
                HasQueueSemantics = hasQueueSemantics,
                HasServiceSemantics = hasServiceSemantics
            };

            if (context.HasClassSelection)
            {
                if (!classDataFound || classVolume <= 0d)
                {
                    classFilteredNodes.Add(node.Id);
                }
            }

            var constraintBadgesForNode = BuildConstraintBadgesSnapshot(node, localIndex);
            if (constraintBadgesForNode.Count > 0)
            {
                constraintBadgeMap[node.Id] = constraintBadgesForNode;
            }

            if (context.IncludeClassContributions &&
                (string.IsNullOrWhiteSpace(context.InspectorNodeId) ||
                 string.Equals(context.InspectorNodeId, node.Id, StringComparison.OrdinalIgnoreCase)))
            {
                var contributions = BuildClassContributions(node, localIndex, token);
                if (contributions.Count > 0)
                {
                    classContributionMap[node.Id] = contributions;
                }
            }
        }

        if (context.TopologyGraph is not null)
        {
            foreach (var topoNode in context.TopologyGraph.Nodes)
            {
                token.ThrowIfCancellationRequested();

                if (topoNode is null || string.IsNullOrWhiteSpace(topoNode.Id))
                {
                    continue;
                }

                var topoNodeId = topoNode.Id;
                metrics.TryGetValue(topoNodeId, out var existingMetrics);
                nodeSparklinesSnapshot.TryGetValue(topoNodeId, out var sparkline);

                double? inlineValue = null;
                var inline = topoNode.Semantics?.InlineValues;
                if (inline != null && inline.Count > 0)
                {
                    if (bin >= 0 && bin < inline.Count)
                    {
                        inlineValue = inline[bin];
                    }
                    else if (localIndex >= 0 && localIndex < inline.Count)
                    {
                        inlineValue = inline[localIndex];
                    }

                    if (inlineValue.HasValue && (!double.IsFinite(inlineValue.Value)))
                    {
                        inlineValue = null;
                    }
                }

                var seriesNode = context.WindowData.Nodes?.FirstOrDefault(n => string.Equals(n.Id, topoNodeId, StringComparison.OrdinalIgnoreCase));
                var topoCategory = ResolveNodeCategory(topoNode, seriesNode, existingMetrics);
                var topoIdentity = ResolveAnalyticalIdentity(topoNode, seriesNode, existingMetrics);
                var hasQueueSemantics = ResolveHasQueueSemantics(topoNode, seriesNode, existingMetrics);
                var hasServiceSemantics = ResolveHasServiceSemantics(topoNode, seriesNode, existingMetrics);
                var displayKind = ResolveNodeDisplayKind(topoNode, seriesNode, existingMetrics);
                var isPmfNode = IsPmfIdentity(topoIdentity);
                double? pmfProbability = null;
                double? pmfSupportValue = null;
                double? customValue = null;
                string? customLabel = null;

                if (isPmfNode)
                {
                    var distribution = topoNode.Semantics?.Distribution;
                    var expectation = ComputePmfExpectation(distribution);
                    var (modeProbability, modeValue) = ComputePmfMode(distribution);

                    pmfProbability = modeProbability;
                    pmfSupportValue = modeValue ?? expectation ?? inlineValue;

                    if (expectation.HasValue)
                    {
                        customValue = expectation;
                        customLabel = pmfExpectationLabel;
                    }
                    else if (pmfSupportValue.HasValue)
                    {
                        customValue = pmfSupportValue;
                        customLabel = pmfExpectationLabel;
                    }
                    else if (inlineValue.HasValue)
                    {
                        customValue = inlineValue;
                        customLabel = pmfExpectationLabel;
                    }
                    else if (nodesMissingSnapshot.Contains(topoNode.Id))
                    {
                        customLabel = missingSeriesMessage;
                    }
                }
                else
                {
                    var sampleValue = SampleSparklineAt(sparkline, bin);
                    customValue = sampleValue ?? inlineValue;
                    if (customValue.HasValue)
                    {
                        customLabel = binValueLabel;
                    }
                    else if (IsExpressionNode(topoCategory, topoIdentity) && nodesMissingSnapshot.Contains(topoNode.Id))
                    {
                        customLabel = missingSeriesMessage;
                    }
                }

                if (!customValue.HasValue && string.IsNullOrWhiteSpace(customLabel))
                {
                    continue;
                }

                if (existingMetrics is not null)
                {
                    var newCustomValue = customValue ?? existingMetrics.CustomValue;
                    var newCustomLabel = customLabel ?? existingMetrics.CustomLabel;
                    if (customValue.HasValue && string.IsNullOrWhiteSpace(customLabel))
                    {
                        newCustomLabel = isPmfNode ? pmfExpectationLabel : binValueLabel;
                    }

                    if (!Equals(newCustomValue, existingMetrics.CustomValue) ||
                        !string.Equals(newCustomLabel, existingMetrics.CustomLabel, StringComparison.Ordinal) ||
                        !Equals(pmfProbability, existingMetrics.PmfProbability) ||
                        !Equals(pmfSupportValue, existingMetrics.PmfValue))
                    {
                        metrics[topoNodeId] = new NodeBinMetrics(
                            existingMetrics.SuccessRate,
                            existingMetrics.Utilization,
                            existingMetrics.ErrorRate,
                            existingMetrics.QueueDepth,
                            existingMetrics.LatencyMinutes,
                            existingMetrics.Timestamp,
                            CustomValue: newCustomValue,
                            CustomLabel: newCustomLabel,
                            PmfProbability: pmfProbability ?? existingMetrics.PmfProbability,
                            PmfValue: pmfSupportValue ?? existingMetrics.PmfValue,
                            NodeKind: string.IsNullOrWhiteSpace(existingMetrics.NodeKind) ? displayKind : existingMetrics.NodeKind,
                            ServiceTimeMs: existingMetrics.ServiceTimeMs,
                            FlowLatencyMs: existingMetrics.FlowLatencyMs,
                            RetryTax: existingMetrics.RetryTax,
                            RawMetrics: existingMetrics.RawMetrics,
                            Metadata: existingMetrics.Metadata ?? topoNode.Semantics?.Metadata,
                            QueueLatencyStatus: existingMetrics.QueueLatencyStatus)
                        {
                            NodeCategory = topoCategory,
                            AnalyticalIdentity = topoIdentity,
                            HasQueueSemantics = hasQueueSemantics,
                            HasServiceSemantics = hasServiceSemantics
                        };
                    }

                    continue;
                }

                metrics[topoNodeId] = new NodeBinMetrics(
                    null,
                    null,
                    null,
                    null,
                    null,
                    selectionTimestamp,
                    CustomValue: customValue,
                    CustomLabel: customLabel,
                    PmfProbability: pmfProbability,
                    PmfValue: pmfSupportValue,
                    NodeKind: displayKind,
                    RetryTax: existingMetrics?.RetryTax,
                    RawMetrics: existingMetrics?.RawMetrics,
                    Metadata: existingMetrics?.Metadata ?? topoNode.Semantics?.Metadata,
                    QueueLatencyStatus: existingMetrics?.QueueLatencyStatus)
                {
                    NodeCategory = topoCategory,
                    AnalyticalIdentity = topoIdentity,
                    HasQueueSemantics = hasQueueSemantics,
                    HasServiceSemantics = hasServiceSemantics
                };
            }
        }

        if (context.HasClassSelection && context.TopologyGraph is not null)
        {
            foreach (var topoNode in context.TopologyGraph.Nodes)
            {
                token.ThrowIfCancellationRequested();

                if (string.IsNullOrWhiteSpace(topoNode?.Id))
                {
                    continue;
                }

                if (!metrics.ContainsKey(topoNode.Id))
                {
                    classFilteredNodes.Add(topoNode.Id);
                }
            }
        }

        var timestampLabel = FormatTimestampSnapshot(context.Timestamps, localIndex);
        var headerLabel = string.IsNullOrWhiteSpace(timestampLabel)
            ? $"bin {bin}"
            : $"{timestampLabel} - bin {bin}";

        return new ActiveMetricsComputationResult(
            metrics,
            classContributionMap,
            classFilteredNodes,
            constraintBadgeMap,
            bin,
            bin.ToString(CultureInfo.InvariantCulture),
            headerLabel,
            context.IncludeInspectorDetails);
    }

    private static IReadOnlyList<NodeConstraintBadgeDto> BuildConstraintBadgesSnapshot(TimeTravelNodeSeriesDto node, int localIndex)
    {
        if ((node.Constraints is null || node.Constraints.Count == 0) &&
            (node.ConstraintStatus is null || node.ConstraintStatus.Count == 0))
        {
            return Array.Empty<NodeConstraintBadgeDto>();
        }

        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (node.Constraints is not null)
        {
            foreach (var id in node.Constraints.Keys)
            {
                if (!string.IsNullOrWhiteSpace(id))
                {
                    ids.Add(id);
                }
            }
        }

        if (node.ConstraintStatus is not null)
        {
            foreach (var id in node.ConstraintStatus.Keys)
            {
                if (!string.IsNullOrWhiteSpace(id))
                {
                    ids.Add(id);
                }
            }
        }

        if (ids.Count == 0)
        {
            return Array.Empty<NodeConstraintBadgeDto>();
        }

        var badges = new List<NodeConstraintBadgeDto>(ids.Count);
        foreach (var id in ids)
        {
            var isLimited = false;
            if (node.ConstraintStatus is not null &&
                node.ConstraintStatus.TryGetValue(id, out var statusSeries))
            {
                var value = GetConstraintStatusSnapshot(statusSeries, localIndex);
                isLimited = value.HasValue && value.Value >= 0.5d;
            }

            badges.Add(new NodeConstraintBadgeDto(id, isLimited));
        }

        return badges;
    }

    private static IReadOnlyList<string> ExtractConstraintIds(TimeTravelNodeSeriesDto? node)
    {
        if (node is null)
        {
            return Array.Empty<string>();
        }

        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (node.Constraints is not null)
        {
            foreach (var id in node.Constraints.Keys)
            {
                if (!string.IsNullOrWhiteSpace(id))
                {
                    ids.Add(id);
                }
            }
        }

        if (node.ConstraintStatus is not null)
        {
            foreach (var id in node.ConstraintStatus.Keys)
            {
                if (!string.IsNullOrWhiteSpace(id))
                {
                    ids.Add(id);
                }
            }
        }

        return ids.Count == 0
            ? Array.Empty<string>()
            : ids.OrderBy(id => id, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private static double? GetConstraintStatusSnapshot(double?[]? series, int localIndex)
    {
        if (series is null || localIndex < 0 || localIndex >= series.Length)
        {
            return null;
        }

        var value = series[localIndex];
        return double.IsFinite(value ?? double.NaN) ? value : null;
    }

    private static QueueLatencyStatus? ResolveQueueLatencyStatus(TimeTravelNodeSeriesDto node, int localIndex)
    {
        if (node.QueueLatencyStatus is not { Length: > 0 })
        {
            return null;
        }

        if (localIndex < 0 || localIndex >= node.QueueLatencyStatus.Length)
        {
            return null;
        }

        return ConvertQueueLatencyStatus(node.QueueLatencyStatus[localIndex]);
    }

    private static QueueLatencyStatus? ConvertQueueLatencyStatus(TimeTravelQueueLatencyStatusDto? dto)
    {
        if (dto is null || string.IsNullOrWhiteSpace(dto.Code))
        {
            return null;
        }

        var code = dto.Code.Trim();
        var message = string.IsNullOrWhiteSpace(dto.Message) ? null : dto.Message.Trim();
        return new QueueLatencyStatus(code, message);
    }

    private void RefreshTimelineTicks()
    {
        if (visibleEndBin < visibleStartBin)
        {
            timelineTicks = Array.Empty<TimelineTick>();
            timelineMinorTicks = Array.Empty<double>();
            return;
        }

        RecomputePlaybackSpeedOptions(Math.Max(1, visibleEndBin - visibleStartBin + 1));

        if (visibleEndBin == visibleStartBin)
        {
            timelineTicks = new[]
            {
                new TimelineTick(visibleStartBin, 0d, BuildTickLabel(visibleStartBin))
            };
            timelineMinorTicks = Array.Empty<double>();
            return;
        }

        var span = visibleEndBin - visibleStartBin;
        var totalBins = span + 1;

        // Aim for ~12 labels; adjust step accordingly
        var targetLabels = 12;
        var step = Math.Max(1, (int)Math.Ceiling(totalBins / (double)targetLabels));

        // If we know bin minutes, try to align to nice hour multiples
        try
        {
            var binMinutes = seriesIndex?.Grid?.BinMinutes ?? 0;
            if (binMinutes > 0)
            {
                var niceMinutes = new[] { 60, 120, 180, 240, 360, 720 };
                foreach (var minutes in niceMinutes)
                {
                    var candidate = Math.Max(1, (int)Math.Round(minutes / (double)binMinutes));
                    var count = Math.Max(1, (int)Math.Ceiling(totalBins / (double)candidate));
                    if (count <= targetLabels)
                    {
                        step = candidate;
                        break;
                    }
                }
            }
        }
        catch
        {
            // ignore and use computed step
        }

        var ticks = new List<TimelineTick>(Math.Min(totalBins, targetLabels) + 2);
        for (var bin = visibleStartBin; bin <= visibleEndBin; bin += step)
        {
            var percent = ((bin - visibleStartBin) / (double)span) * 100d;
            percent = Math.Clamp(percent, 0d, 100d);
            ticks.Add(new TimelineTick(bin, percent, BuildTickLabel(bin)));
        }

        // Ensure last label is included
        if (ticks.Count == 0 || ticks[^1].Bin != visibleEndBin)
        {
            ticks.Add(new TimelineTick(visibleEndBin, 100d, BuildTickLabel(visibleEndBin)));
        }

        timelineTicks = ticks;

        var minorTicks = new List<double>();
        for (var i = 0; i < ticks.Count - 1; i++)
        {
            var current = ticks[i];
            var next = ticks[i + 1];
            if (next.Bin - current.Bin <= 1)
            {
                continue;
            }

            var midPercent = (current.Percent + next.Percent) / 2d;
            if (midPercent > current.Percent && midPercent < next.Percent)
            {
                minorTicks.Add(midPercent);
            }
        }

        timelineMinorTicks = minorTicks;
    }

    private void RecomputePlaybackSpeedOptions(int totalBins)
    {
        totalBins = Math.Max(1, totalBins);
        var baseSeconds = basePlaybackTotalSeconds / totalBins;
        baseSeconds = Math.Clamp(baseSeconds, minPlaybackDelay, maxPlaybackDelay);

        var options = new List<PlaybackSpeedOption>(playbackSpeedFactors.Length);
        foreach (var factor in playbackSpeedFactors)
        {
            var seconds = Math.Clamp(baseSeconds / factor, minPlaybackDelay, maxPlaybackDelay);
            var label = $"{factor:0.#}x";
            options.Add(new PlaybackSpeedOption(factor, seconds, label));
        }

        if (options.Count == 0)
        {
            options.Add(new PlaybackSpeedOption(1d, baseSeconds, "1x"));
        }

        playbackSpeedOptions = options;
        playbackSpeedFactor = AlignPlaybackFactor(playbackSpeedFactor);
        playbackSecondsPerFrame = GetSecondsForFactor(playbackSpeedFactor);
    }

    private double AlignPlaybackFactor(double value)
    {
        if (playbackSpeedOptions.Count == 0)
        {
            playbackSpeedOptions.Add(new PlaybackSpeedOption(1d, Math.Clamp(playbackSecondsPerFrame, minPlaybackDelay, maxPlaybackDelay), "1x"));
        }

        var closest = playbackSpeedOptions[0].Factor;
        var smallestDelta = Math.Abs(playbackSpeedOptions[0].Factor - value);

        foreach (var option in playbackSpeedOptions)
        {
            var delta = Math.Abs(option.Factor - value);
            if (delta < smallestDelta)
            {
                smallestDelta = delta;
                closest = option.Factor;
            }
        }

        return closest;
    }

    private double GetSecondsForFactor(double factor)
    {
        var option = playbackSpeedOptions.FirstOrDefault(o => Math.Abs(o.Factor - factor) < 0.0001);
        if (option is not null)
        {
            return option.Seconds;
        }

        return playbackSpeedOptions.Count > 0
            ? playbackSpeedOptions[0].Seconds
            : Math.Clamp(basePlaybackTotalSeconds, minPlaybackDelay, maxPlaybackDelay);
    }

    private string BuildTickLabel(int bin)
    {
        if (windowData is not null)
        {
            var spanStart = windowData.Window.StartBin;
            var localIndex = bin - spanStart;
            if (localIndex >= 0 && localIndex < timestamps.Count)
            {
                var ts = timestamps[localIndex];
                return ts.ToString("HH:mm", CultureInfo.InvariantCulture);
            }
        }

        return $"Bin {bin}";
    }

    private (double?[]? Data, double Min, double Max, int HighlightStart, int HighlightEnd) ResolveHorizonSeries(string nodeId, string? seriesKey, NodeSparklineData? fallback)
    {
        double?[]? data = null;
        double min = 0d, max = 0d;
        int hStart = 0, hEnd = 0;

        if (windowData is not null)
        {
            var node = windowData.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
            if (node is not null)
            {
                data = ResolveFullSeries(node, seriesKey);
            }

            var startBin = windowData.Window.StartBin;
            var endBin = windowData.Window.EndBin;
            var totalBins = Math.Max(1, endBin - startBin + 1);
            var winStart = Math.Max(startBin, selectedBin - sparklinePointLimit + 1);
            var winEnd = Math.Max(winStart, Math.Min(selectedBin, endBin));
            hStart = Math.Clamp(winStart - startBin, 0, totalBins - 1);
            hEnd = Math.Clamp(winEnd - startBin, 0, totalBins - 1);
        }

        if (data is null || data.Length == 0)
        {
            // Fallback to trimmed values to avoid empty charts
            if (fallback is not null)
            {
                data = fallback.Values as double?[] ?? fallback.Values.ToArray();
                hStart = 0;
                hEnd = data.Length - 1;
            }
            else
            {
                data = Array.Empty<double?>();
                hStart = 0;
                hEnd = 0;
            }
        }

        (min, max) = ComputeSeriesMinMax(data);
        return (data, min, max, hStart, hEnd);
    }

    private static (double Min, double Max) ComputeSeriesMinMax(double?[]? data)
    {
        if (data is null || data.Length == 0)
        {
            return (0d, 0d);
        }

        var min = double.PositiveInfinity;
        var max = double.NegativeInfinity;
        var any = false;
        foreach (var v in data)
        {
            if (v.HasValue && double.IsFinite(v.Value))
            {
                any = true;
                if (v.Value < min) min = v.Value;
                if (v.Value > max) max = v.Value;
            }
        }

        if (!any)
        {
            return (0d, 0d);
        }

        if (Math.Abs(max - min) < 1e-9)
        {
            var baseline = min;
            var epsilon = Math.Max(Math.Abs(baseline) * 0.001d, 0.001d);
            var adjustedMin = baseline - epsilon;
            if (baseline >= 0d && adjustedMin < 0d)
            {
                min = 0d;
                max = epsilon;
            }
            else
            {
                min = adjustedMin;
                max = baseline + epsilon;
            }
        }

        return (min, max);
    }

    private double?[]? ResolveFullSeries(TimeTravelNodeSeriesDto node, string? key)
    {
        var k = (key ?? string.Empty).Trim().ToLowerInvariant();
        if (k.StartsWith("constraint:", StringComparison.OrdinalIgnoreCase))
        {
            var parts = k.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (parts.Length >= 3)
            {
                return TryGetConstraintSeries(node, parts[1], parts[2]);
            }
        }
        switch (k)
        {
            case "successrate":
                return BuildSuccessRateSeries(node);
            case "errorrate":
                return BuildErrorRateSeries(node);
            case "latency":
            case "latencyminutes":
                return TryGetSeries(node, "latencyMinutes") ?? TryGetSeries(node, "latency");
            case "queue":
            case "queuedepth":
                return TryGetSeries(node, "queue") ?? TryGetSeries(node, "queueDepth");
            case "values":
            case "output":
                return TryGetSeries(node, "values") ?? TryGetSeries(node, "output") ?? TryGetSeries(node, node.Id) ?? TryGetSeries(node, $"series:{node.Id}");
            case "errors":
                return TryGetSeries(node, "errors");
            case "served":
                return TryGetSeries(node, "served");
            case "arrivals":
                return TryGetSeries(node, "arrivals");
            default:
                // Unknown series key; try direct lookup
                return string.IsNullOrWhiteSpace(key) ? null : TryGetSeries(node, key);
        }
    }

    private void StartPlayback()
    {
        if (isPlaying || visibleStartBin == visibleEndBin)
        {
            return;
        }

        playbackCts?.Cancel();
        playbackCts = new CancellationTokenSource();
        var token = playbackCts.Token;
        isPlaying = true;
        playbackTask = RunPlaybackLoopAsync(token);
        StateHasChanged();
    }

    private void StopPlayback()
    {
        playbackCts?.Cancel();
        pointerNeedsJump = false;
    }

    private async Task RunPlaybackLoopAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(playbackSecondsPerFrame), token);

                var shouldJumpAfterPause = false;
                await InvokeAsync(() =>
                {
                    if (visibleStartBin == visibleEndBin)
                    {
                        StopPlayback();
                        return;
                    }

                    var stepCount = Math.Max(1, (int)Math.Round(playbackSpeedFactor));
                    var next = selectedBin + stepCount;
                    if (next > visibleEndBin)
                    {
                        if (loopPlayback)
                        {
                            pointerNeedsJump = true;
                            shouldJumpAfterPause = true;
                            return;
                        }
                        else
                        {
                            StopPlayback();
                            return;
                        }
                    }

                    ApplyBinSelection(next, jumpPointer: false);
                });

                if (shouldJumpAfterPause)
                {
                    await Task.Delay(TimeSpan.FromSeconds(1), token);

                    await InvokeAsync(() =>
                    {
                        if (token.IsCancellationRequested)
                        {
                            return;
                        }

                        ApplyBinSelection(visibleStartBin, jumpPointer: true);
                    });
                }
            }
        }
        catch (TaskCanceledException)
        {
            // expected when playback is stopped
        }
        finally
        {
            await InvokeAsync(() =>
            {
                playbackCts?.Dispose();
                playbackCts = null;
                isPlaying = false;
                playbackTask = Task.CompletedTask;
                StateHasChanged();
            });
        }
    }

    private string FormatTimestamp(int localIndex) =>
        FormatTimestampSnapshot(timestamps, localIndex);

    private static string FormatTimestampSnapshot(IReadOnlyList<DateTimeOffset> timestampsSnapshot, int localIndex)
    {
        if (localIndex < 0 || localIndex >= timestampsSnapshot.Count)
        {
            return string.Empty;
        }

        var ts = timestampsSnapshot[localIndex];
        return ts.ToString("dd MMM yyyy HH:mm 'UTC'", CultureInfo.InvariantCulture);
    }

    private void ApplySelectedBinUi(int bin)
    {
        selectedBin = bin;
        selectedBinLabel = bin.ToString(CultureInfo.InvariantCulture);
        if (windowData is { } data)
        {
            var localIndex = bin - data.Window.StartBin;
            var timestamp = FormatTimestamp(localIndex);
            selectedTimestampLabel = string.IsNullOrWhiteSpace(timestamp)
                ? $"bin {bin}"
                : $"{timestamp} - bin {bin}";
        }
        else
        {
            selectedTimestampLabel = string.Empty;
        }
    }

    private void ScheduleBinDataRefresh(int bin, bool cancelCurrent = true)
    {
        var revision = Interlocked.Increment(ref binDataRevision);
        var workItem = new BinDataWorkItem(bin, revision, CaptureBinDataContext());
        var worker = GetOrCreateBinDataWorker();
        worker.Schedule(workItem, cancelCurrent);
    }

    private void MaybeScheduleScrubRefresh(int bin)
    {
        var now = Environment.TickCount64;
        if (lastScrubRefreshBin == bin && (now - lastScrubRefreshAtMs) < scrubRefreshIntervalMs)
        {
            return;
        }

        if ((now - lastScrubRefreshAtMs) < scrubRefreshIntervalMs)
        {
            return;
        }

        lastScrubRefreshAtMs = now;
        lastScrubRefreshBin = bin;
        ScheduleBinDataRefresh(bin, cancelCurrent: true);
    }

    private AsyncWorkQueue<BinDataWorkItem, BinDataRefreshResult> GetOrCreateBinDataWorker()
    {
        return binDataWorker ??= new AsyncWorkQueue<BinDataWorkItem, BinDataRefreshResult>(
            (job, token) => ComputeBinDataRefreshResult(job, token),
            HandleBinDataResultAsync);
    }

    private Task HandleBinDataResultAsync(BinDataRefreshResult result)
    {
        return InvokeAsync(() =>
        {
            if (!TryApplyBinDataResult(result))
            {
                return;
            }

            StateHasChanged();
        });
    }

    private bool TryApplyBinDataResult(BinDataRefreshResult result)
    {
        if (result.Revision != binDataRevision)
        {
            return false;
        }

        ApplyNodeSparklinesResult(result.Sparklines);
        ApplyActiveMetricsResult(result.Metrics);
        return true;
    }

    private void CancelBinDataRefresh()
    {
        binDataWorker?.Cancel(clearQueue: true);
    }

    private void DisposeBinDataWorker()
    {
        if (binDataWorker is null)
        {
            return;
        }

        binDataWorker.Dispose();
        binDataWorker = null;
    }

    private void FlushPendingDragBin()
    {
        if (pendingDragBin is not int bin)
        {
            return;
        }

        pendingDragBin = null;
        ScheduleBinDataRefresh(bin, cancelCurrent: true);
    }

    private BinDataComputationContext CaptureBinDataContext()
    {
        var timestampsSnapshot = timestamps?.ToList() ?? new List<DateTimeOffset>();
        var classSelectionSnapshot = selectedClasses.ToArray();
        var inspectorIdSnapshot = inspectorNodeId;
        var includeInspectorDetails = inspectorOpen && !string.IsNullOrWhiteSpace(inspectorIdSnapshot);
        var includeClassContributions = includeInspectorDetails || HasNodeClassData(windowData);
        return new BinDataComputationContext(
            windowData,
            topologyGraph,
            timestampsSnapshot,
            classSelectionSnapshot,
            sparklinePointLimit,
            includeInspectorDetails,
            includeClassContributions,
            includeInspectorDetails ? inspectorIdSnapshot : null);
    }

    private static bool HasNodeClassData(TimeTravelStateWindowDto? window)
    {
        if (window?.Nodes is null)
        {
            return false;
        }

        foreach (var node in window.Nodes)
        {
            if (node?.ByClass is { Count: > 0 })
            {
                return true;
            }
        }

        return false;
    }

    private sealed record BinDataRefreshResult(
        long Revision,
        NodeSparklineComputationResult Sparklines,
        ActiveMetricsComputationResult Metrics);

    private sealed record BinDataWorkItem(int Bin, long Revision, BinDataComputationContext Context);

    private sealed class BinDataComputationContext
    {
        private readonly Dictionary<string, TopologyNode> nodeLookup;

        public BinDataComputationContext(
            TimeTravelStateWindowDto? windowData,
            TopologyGraph? topologyGraph,
            IReadOnlyList<DateTimeOffset> timestamps,
            IReadOnlyCollection<string> selectedClasses,
            int sparklinePointLimit,
            bool includeInspectorDetails,
            bool includeClassContributions,
            string? inspectorNodeId)
        {
            WindowData = windowData;
            TopologyGraph = topologyGraph;
            Timestamps = timestamps;
            SelectedClasses = selectedClasses;
            this.sparklinePointLimit = sparklinePointLimit;
            HasClassSelection = selectedClasses.Count > 0;
            IncludeInspectorDetails = includeInspectorDetails;
            IncludeClassContributions = includeClassContributions;
            InspectorNodeId = inspectorNodeId;
            nodeLookup = topologyGraph?.Nodes?
                .Where(n => n is not null && !string.IsNullOrWhiteSpace(n.Id))
                .ToDictionary(n => n!.Id!, n => n!, StringComparer.OrdinalIgnoreCase) ??
                new Dictionary<string, TopologyNode>(StringComparer.OrdinalIgnoreCase);
        }

        public TimeTravelStateWindowDto? WindowData { get; }

        public TopologyGraph? TopologyGraph { get; }

        public IReadOnlyList<DateTimeOffset> Timestamps { get; }

        public IReadOnlyCollection<string> SelectedClasses { get; }

        public bool HasClassSelection { get; }

        public int sparklinePointLimit { get; }

        public bool IncludeInspectorDetails { get; }

        public bool IncludeClassContributions { get; }

        public string? InspectorNodeId { get; }

        public TopologyNode? FindNode(string? nodeId)
        {
            if (string.IsNullOrWhiteSpace(nodeId))
            {
                return null;
            }

            return nodeLookup.TryGetValue(nodeId, out var node) ? node : null;
        }
    }

    private sealed record NodeSparklineComputationResult(
        Dictionary<string, NodeSparklineData> Sparklines,
        HashSet<string> MissingNodes,
        IReadOnlyCollection<string> MissingExpressionNodeIds);

    private sealed record ActiveMetricsComputationResult(
        Dictionary<string, NodeBinMetrics> Metrics,
        Dictionary<string, IReadOnlyList<ClassContribution>> ClassContributions,
        HashSet<string> ClassFilteredNodes,
        Dictionary<string, IReadOnlyList<NodeConstraintBadgeDto>> ConstraintBadges,
        int SelectedBin,
        string SelectedBinLabel,
        string SelectedTimestampLabel,
        bool IncludesInspectorDetails);

    private static BinDataRefreshResult ComputeBinDataRefreshResult(
        BinDataWorkItem job,
        CancellationToken token)
    {
        var sparklines = ComputeNodeSparklinesSnapshot(job.Context, job.Bin, token);
        var metrics = ComputeActiveMetricsSnapshot(job.Context, job.Bin, sparklines.Sparklines, sparklines.MissingNodes, token);
        return new BinDataRefreshResult(job.Revision, sparklines, metrics);
    }

    private void ApplyNodeSparklinesResult(NodeSparklineComputationResult result)
    {
        nodeSparklines = result.Sparklines;
        nodesMissingSparkline = result.MissingNodes;
        loggedMissingMetricKinds.Clear();

        if (Logger is not null && overlaySettings.IncludeExpressionNodes)
        {
            foreach (var nodeId in result.MissingExpressionNodeIds)
            {
                if (loggedMissingExpressionSeries.Add(nodeId))
                {
                    Logger.LogWarning("Expression node {NodeId} has no series for selected range.", nodeId);
                }
            }
        }

        EnsureInspectorVisibility();
    }

    private void ApplyActiveMetricsResult(ActiveMetricsComputationResult result)
    {
        activeMetrics = result.Metrics;
        constraintBadges = result.ConstraintBadges;
        nodeClassContributions = result.ClassContributions;
        inspectorDataDirty = result.IncludesInspectorDetails ? false : true;
        classFilteredNodes.Clear();
        foreach (var nodeId in result.ClassFilteredNodes)
        {
            classFilteredNodes.Add(nodeId);
        }

        if (selectedBin != result.SelectedBin)
        {
            selectedBin = result.SelectedBin;
        }
        renderBin = result.SelectedBin;

        if (!string.Equals(selectedBinLabel, result.SelectedBinLabel, StringComparison.Ordinal))
        {
            selectedBinLabel = result.SelectedBinLabel;
        }

        if (!string.Equals(selectedTimestampLabel, result.SelectedTimestampLabel, StringComparison.Ordinal))
        {
            selectedTimestampLabel = result.SelectedTimestampLabel;
        }
        EnsureInspectorVisibility();
        if (inspectorOpen)
        {
            EnsureInspectorDataFresh();
        }

        if (hasLoaded && !isPlaying)
        {
            ScheduleRunStateSave();
        }
    }

    private Task OnNodeFocused(string? nodeId)
    {
        var wasOpen = inspectorOpen;
        if (string.IsNullOrWhiteSpace(nodeId))
        {
            inspectorPinned = false;
            inspectorOpen = false;
            inspectorNodeId = null;
            inspectorDataDirty = true;
            SetFocusViewEnabled(false);
            focusIncludeDownstream = false;
        }
        else
        {
            inspectorNodeId = nodeId;
            lastInspectorNodeId = nodeId;
            selectedNodeId = nodeId;
            inspectorOpen = true;
            inspectorPinned = true;
            EnsureInspectorDataFresh();
            SyncConstraintSelection(nodeId);
        }

        if (!wasOpen && inspectorOpen)
        {
            inspectorTab = InspectorTab.Charts;
        }

        inspectorMetricsExpanded = false;
        ClearInspectorEdgeHighlights();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnNodeSelected(string? nodeId)
    {
        selectedNodeId = string.IsNullOrWhiteSpace(nodeId) ? null : nodeId;
        SyncConstraintSelection(selectedNodeId);
        if (selectedNodeId is null)
        {
            SetFocusViewEnabled(false);
            focusIncludeDownstream = false;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private void SyncConstraintSelection(string? nodeId)
    {
        if (string.IsNullOrWhiteSpace(nodeId) || windowData is null)
        {
            selectedConstraintId = null;
            return;
        }

        var node = windowData.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        var ids = ExtractConstraintIds(node);
        if (ids.Count == 0)
        {
            selectedConstraintId = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedConstraintId) ||
            !ids.Contains(selectedConstraintId, StringComparer.OrdinalIgnoreCase))
        {
            selectedConstraintId = ids[0];
        }
    }

    private void SelectConstraint(string constraintId)
    {
        if (string.IsNullOrWhiteSpace(constraintId))
        {
            return;
        }

        selectedConstraintId = constraintId;
        StateHasChanged();
    }

    private void EnsureInspectorVisibility()
    {
        if (inspectorPinned && !string.IsNullOrWhiteSpace(inspectorNodeId))
        {
            inspectorOpen = true;
            EnsureInspectorDataFresh();
        }
    }

    private void EnsureInspectorDataFresh()
    {
        if (!inspectorOpen || string.IsNullOrWhiteSpace(inspectorNodeId))
        {
            return;
        }

        if (inspectorDataDirty)
        {
            ScheduleBinDataRefresh(selectedBin, cancelCurrent: true);
        }
    }

    private static string FormatPercent(double? value)
    {
        return value.HasValue
            ? (value.Value * 100).ToString("0", CultureInfo.InvariantCulture) + "%"
            : "-";
    }

    private string GetAggregationIndicatorLabel()
    {
        return "Avg";
