    private double?[]? BuildSuccessRateSeries(TimeTravelNodeSeriesDto node) =>
        BuildSuccessRateSeriesSnapshot(node, HasClassSelection, selectedClasses);

    private static double?[]? BuildSuccessRateSeriesSnapshot(
        TimeTravelNodeSeriesDto node,
        bool hasClassSelection,
        IReadOnlyCollection<string> selectedClassIds)
    {
        if (node is null)
        {
            return null;
        }

        if (!hasClassSelection)
        {
            var isSink = IsSinkCategory(ResolveNodeCategory(null, node));
            if (isSink)
            {
                var scheduleSeries = TryGetSlaSeriesSnapshot(node, "scheduleAdherence");
                if (scheduleSeries is not null && scheduleSeries.Length > 0)
                {
                    return scheduleSeries;
                }
            }

            var slaCompletion = TryGetSlaSeriesSnapshot(node, "completion");
            if (slaCompletion is not null && slaCompletion.Length > 0)
            {
                return slaCompletion;
            }
        }

        var throughput = TryGetSeriesSnapshot(node, "throughputRatio", hasClassSelection, selectedClassIds);
        var arrivals = TryGetSeriesSnapshot(node, "arrivals", hasClassSelection, selectedClassIds);
        var served = TryGetSeriesSnapshot(node, "served", hasClassSelection, selectedClassIds);

        var length = Math.Max(
            throughput?.Length ?? 0,
            Math.Max(arrivals?.Length ?? 0, served?.Length ?? 0));

        if (length <= 0)
        {
            return null;
        }

        var values = new double?[length];
        for (var i = 0; i < length; i++)
        {
            var throughputValue = GetValueAt(throughput, i);
            if (throughputValue.HasValue)
            {
                values[i] = throughputValue;
                continue;
            }

            var arrivalsValue = GetValueAt(arrivals, i);
            var servedValue = GetValueAt(served, i);

            if (arrivalsValue.HasValue && arrivalsValue.Value > 0 && servedValue.HasValue)
            {
                values[i] = servedValue.Value / arrivalsValue.Value;
            }
            else if ((!arrivalsValue.HasValue || arrivalsValue.Value <= 0) && servedValue.HasValue)
            {
                values[i] = servedValue.Value > 0 ? 1d : 0d;
            }
            else
            {
                values[i] = null;
            }
        }

        return values;
    }

    private double?[]? BuildErrorRateSeries(TimeTravelNodeSeriesDto node) =>
        BuildErrorRateSeriesSnapshot(node, HasClassSelection, selectedClasses);

    private static double?[]? BuildErrorRateSeriesSnapshot(
        TimeTravelNodeSeriesDto node,
        bool hasClassSelection,
        IReadOnlyCollection<string> selectedClassIds)
    {
        if (node is null)
        {
            return null;
        }

        var errors = TryGetSeriesSnapshot(node, "errors", hasClassSelection, selectedClassIds);
        var arrivals = TryGetSeriesSnapshot(node, "arrivals", hasClassSelection, selectedClassIds);
        var served = TryGetSeriesSnapshot(node, "served", hasClassSelection, selectedClassIds);

        var length = Math.Max(errors?.Length ?? 0, Math.Max(arrivals?.Length ?? 0, served?.Length ?? 0));
        if (length <= 0)
        {
            return null;
        }

        var values = new double?[length];
        for (var i = 0; i < length; i++)
        {
            var errorsValue = GetValueAt(errors, i);
            if (!errorsValue.HasValue)
            {
                values[i] = null;
                continue;
            }

            var denominator = GetValueAt(arrivals, i) ?? GetValueAt(served, i);
            if (denominator.HasValue && denominator.Value > 0)
            {
                values[i] = errorsValue.Value / denominator.Value;
            }
            else
            {
                values[i] = errorsValue.Value > 0 ? 1d : 0d;
            }
        }

        return values;
    }

    private double?[]? BuildUtilizationSeries(TimeTravelNodeSeriesDto node) =>
        BuildUtilizationSeriesSnapshot(node, HasClassSelection, selectedClasses);

    private static double?[]? BuildUtilizationSeriesSnapshot(
        TimeTravelNodeSeriesDto node,
        bool hasClassSelection,
        IReadOnlyCollection<string> selectedClassIds)
    {
        var served = TryGetSeriesSnapshot(node, "served", hasClassSelection, selectedClassIds);
        var capacity = TryGetSeriesSnapshot(node, "capacity", hasClassSelection, selectedClassIds);
        if (served is null || capacity is null)
        {
            return null;
        }

        var length = Math.Max(served.Length, capacity.Length);
        if (length <= 0)
        {
            return null;
        }

        var values = new double?[length];
        for (var i = 0; i < length; i++)
        {
            var servedValue = GetValueAt(served, i);
            var capacityValue = GetValueAt(capacity, i);

            if (!servedValue.HasValue)
            {
                values[i] = null;
                continue;
            }

            if (!capacityValue.HasValue || capacityValue.Value <= 0)
            {
                values[i] = servedValue.Value <= 0 ? 0d : null;
                continue;
            }

            values[i] = servedValue.Value / capacityValue.Value;
        }

        return values;
    }

    private double?[]? BuildServiceTimeSeries(TimeTravelNodeSeriesDto node) =>
        BuildServiceTimeSeriesSnapshot(node, HasClassSelection, selectedClasses);

    private static double?[]? BuildServiceTimeSeriesSnapshot(
        TimeTravelNodeSeriesDto node,
        bool hasClassSelection,
        IReadOnlyCollection<string> selectedClassIds)
    {
        var processingTime = TryGetSeriesSnapshot(node, "processingTimeMsSum", hasClassSelection, selectedClassIds);
        var servedCount = TryGetSeriesSnapshot(node, "servedCount", hasClassSelection, selectedClassIds);
        if (processingTime is null || servedCount is null)
        {
            return null;
        }

        var length = Math.Max(processingTime.Length, servedCount.Length);
        if (length <= 0)
        {
            return null;
        }

        var values = new double?[length];
        for (var i = 0; i < length; i++)
        {
            var sumValue = GetValueAt(processingTime, i);
            var countValue = GetValueAt(servedCount, i);

            if (!sumValue.HasValue)
            {
                values[i] = null;
                continue;
            }

            if (!countValue.HasValue || countValue.Value <= 0)
            {
                values[i] = null;
                continue;
            }

            var ratio = sumValue.Value / countValue.Value;
            values[i] = double.IsFinite(ratio) ? ratio : null;
        }

        return values;
    }

    private double?[]? TryGetSeries(TimeTravelNodeSeriesDto node, string key) =>
        TryGetSeriesSnapshot(node, key, HasClassSelection, selectedClasses);

    private static double?[]? TryGetConstraintSeries(TimeTravelNodeSeriesDto node, string constraintId, string metricKey)
    {
        if (node.Constraints is null ||
            string.IsNullOrWhiteSpace(constraintId) ||
            string.IsNullOrWhiteSpace(metricKey) ||
            !node.Constraints.TryGetValue(constraintId, out var constraint))
        {
            return null;
        }

        return constraint.Series.TryGetValue(metricKey, out var series) ? series : null;
    }

    private static double?[]? TryGetSlaSeriesSnapshot(TimeTravelNodeSeriesDto node, string kind)
    {
        if (node.Sla is null || string.IsNullOrWhiteSpace(kind))
        {
            return null;
        }

        var entry = node.Sla.FirstOrDefault(series => string.Equals(series.Kind, kind, StringComparison.OrdinalIgnoreCase));
        return entry?.Values is { Length: > 0 } values ? values : null;
    }

    private static double?[]? TryGetSeriesSnapshot(
        TimeTravelNodeSeriesDto node,
        string key,
        bool hasClassSelection,
        IReadOnlyCollection<string> selectedClassIds)
    {
        if (hasClassSelection)
        {
            var aggregated = ResolveSeriesForClassesSnapshot(node, key, selectedClassIds, out _);
            if (aggregated is not null)
            {
                return aggregated;
            }
        }

        if (node.Series is null || string.IsNullOrWhiteSpace(key))
        {
            return null;
        }

        return node.Series.TryGetValue(key, out var series) && series is { Length: > 0 }
            ? series
            : null;
    }

    private double?[]? ResolveSeriesForClasses(TimeTravelNodeSeriesDto node, string key, out bool hadData) =>
        ResolveSeriesForClassesSnapshot(node, key, selectedClasses, out hadData);

    private static double?[]? ResolveSeriesForClassesSnapshot(
        TimeTravelNodeSeriesDto node,
        string key,
        IReadOnlyCollection<string> selectedClassIds,
        out bool hadData)
    {
        hadData = false;
        if (node.ByClass is null || selectedClassIds.Count == 0 || string.IsNullOrWhiteSpace(key))
        {
            return null;
        }

        double?[]? accumulator = null;
        foreach (var classId in selectedClassIds)
        {
            if (!node.ByClass.TryGetValue(classId, out var classMetrics) ||
                classMetrics is null ||
                !classMetrics.TryGetValue(key, out var series) ||
                series is null ||
                series.Length == 0)
            {
                continue;
            }

            hadData = true;
            accumulator ??= new double?[series.Length];
            var limit = Math.Min(accumulator.Length, series.Length);
            for (var i = 0; i < limit; i++)
            {
                var value = series[i];
                if (!value.HasValue)
                {
                    continue;
                }

                accumulator[i] = (accumulator[i] ?? 0d) + value.Value;
            }
        }

        return accumulator;
    }

    private double? GetSeriesValue(
        TimeTravelNodeSeriesDto node,
        string key,
        int localIndex,
        ref bool classDataFound,
        ref double classVolume) =>
        GetSeriesValueSnapshot(node, key, localIndex, ref classDataFound, ref classVolume, HasClassSelection, selectedClasses);

    private static double? GetSeriesValueSnapshot(
        TimeTravelNodeSeriesDto node,
        string key,
        int localIndex,
        ref bool classDataFound,
        ref double classVolume,
        bool hasClassSelection,
        IReadOnlyCollection<string> selectedClassIds)
    {
        if (hasClassSelection)
        {
            var series = ResolveSeriesForClassesSnapshot(node, key, selectedClassIds, out var hasData);
            if (hasData)
            {
                classDataFound = true;
            }

            if (series is not null && localIndex >= 0 && localIndex < series.Length)
            {
                var value = series[localIndex];
                if (value.HasValue && ShouldContributeToVolume(key))
                {
                    classVolume += Math.Abs(value.Value);
                }

                return value;
            }
        }

        if (node.Series is null || string.IsNullOrWhiteSpace(key))
        {
            return null;
        }

        if (node.Series.TryGetValue(key, out var fallback) &&
            fallback is not null &&
            localIndex >= 0 &&
            localIndex < fallback.Length)
        {
            return fallback[localIndex];
        }

        return null;
    }

    private static double? GetConstraintSeriesValueSnapshot(
        TimeTravelNodeSeriesDto node,
        string constraintId,
        string key,
        int localIndex)
    {
        if (node.Constraints is null ||
            string.IsNullOrWhiteSpace(constraintId) ||
            string.IsNullOrWhiteSpace(key) ||
            !node.Constraints.TryGetValue(constraintId, out var constraint) ||
            constraint.Series is null ||
            !constraint.Series.TryGetValue(key, out var series) ||
            localIndex < 0 ||
            localIndex >= series.Length)
        {
            return null;
        }

        return series[localIndex];
    }

    private static double? GetConstraintStatusValueSnapshot(
        TimeTravelNodeSeriesDto node,
        string constraintId,
        int localIndex)
    {
        if (node.ConstraintStatus is null ||
            string.IsNullOrWhiteSpace(constraintId) ||
            !node.ConstraintStatus.TryGetValue(constraintId, out var series) ||
            localIndex < 0 ||
            localIndex >= series.Length)
        {
            return null;
        }

        return series[localIndex];
    }

    private static double? GetSlaValueSnapshot(TimeTravelNodeSeriesDto node, string kind, int localIndex)
    {
        if (node.Sla is null || string.IsNullOrWhiteSpace(kind))
        {
            return null;
        }

        var series = node.Sla.FirstOrDefault(item => string.Equals(item.Kind, kind, StringComparison.OrdinalIgnoreCase));
        if (series?.Values is null || localIndex < 0 || localIndex >= series.Values.Length)
        {
            return null;
        }

        var value = series.Values[localIndex];
        return value.HasValue && double.IsFinite(value.Value) ? value : null;
    }

    private static bool ShouldContributeToVolume(string key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        return key.Equals("arrivals", StringComparison.OrdinalIgnoreCase) ||
               key.Equals("served", StringComparison.OrdinalIgnoreCase) ||
               key.Equals("queue", StringComparison.OrdinalIgnoreCase) ||
               key.Equals("capacity", StringComparison.OrdinalIgnoreCase) ||
               key.Equals("attempts", StringComparison.OrdinalIgnoreCase) ||
               key.Equals("errors", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsClassSelectedChip(string classId) =>
        HasClassSelection && selectedClasses.Contains(classId, StringComparer.OrdinalIgnoreCase);

    private string ResolveClassLabel(string classId)
    {
        if (IsDefaultClassId(classId))
        {
            return "Total";
        }

        if (classDisplayNames.TryGetValue(classId, out var label) && !string.IsNullOrWhiteSpace(label))
        {
            return label;
        }

        return classId;
    }

    private static bool IsDefaultClassId(string classId) =>
        string.Equals(classId, "DEFAULT", StringComparison.OrdinalIgnoreCase);

    private static IReadOnlyList<ClassContribution> BuildClassContributions(
        TimeTravelNodeSeriesDto node,
        int localIndex,
        CancellationToken token = default)
    {
        var contributions = new List<ClassContribution>();
        if (node.ByClass is null || localIndex < 0)
        {
            return contributions;
        }

        foreach (var entry in node.ByClass)
        {
            token.ThrowIfCancellationRequested();

            var metrics = entry.Value;
            if (metrics is null)
            {
                continue;
            }

            double? GetMetric(string key)
            {
                if (!metrics.TryGetValue(key, out var series) || series is null || series.Length == 0)
                {
                    return null;
                }

                if (localIndex < 0 || localIndex >= series.Length)
                {
                    return null;
                }

                var value = series[localIndex];
                return value.HasValue && double.IsFinite(value.Value) ? value : null;
            }

            var arrivals = GetMetric("arrivals");
            var served = GetMetric("served");
            var errors = GetMetric("errors");
            var queue = GetMetric("queue");

            if (!(arrivals.HasValue || served.HasValue || errors.HasValue || queue.HasValue))
            {
                continue;
            }

            contributions.Add(new ClassContribution(entry.Key, arrivals, served, errors, queue));
        }

        return contributions
            .OrderByDescending(c => c.Arrivals ?? 0d)
            .ThenBy(c => c.Id, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private string BuildFilteredCsvContent()
    {
        if (windowData is null)
        {
            return string.Empty;
        }

        var sb = new StringBuilder();
        sb.AppendLine("nodeId,classId,metric,binIndex,value");
        var metrics = new[] { "arrivals", "served", "errors", "queue" };
        var startBin = windowData.Window.StartBin;
        var binCount = Math.Max(1, windowData.Window.BinCount);

        foreach (var node in windowData.Nodes)
        {
            var hasByClass = node.ByClass is not null && node.ByClass.Count > 0;
            var targetClasses = new List<string>();
            if (HasClassSelection && selectedClasses.Count > 0)
            {
                targetClasses.AddRange(selectedClasses);
            }
            else if (hasByClass && node.ByClass is not null)
            {
                targetClasses.AddRange(node.ByClass.Keys);
            }

            if (hasByClass && targetClasses.Count > 0 && node.ByClass is not null)
            {
                foreach (var classId in targetClasses)
                {
                    if (!node.ByClass.TryGetValue(classId, out var metricMap) || metricMap is null)
                    {
                        continue;
                    }

                    foreach (var metric in metrics)
                    {
                        if (!metricMap.TryGetValue(metric, out var series) || series is null || series.Length == 0)
                        {
                            continue;
                        }

                        var limit = Math.Min(series.Length, binCount);
                        for (var i = 0; i < limit; i++)
                        {
                            var value = series[i];
                            if (!value.HasValue)
                            {
                                continue;
                            }

                            sb.AppendLine(FormattableString.Invariant($"{node.Id},{classId},{metric},{startBin + i},{value.Value}"));
                        }
                    }
                }
            }
            else
            {
                foreach (var metric in metrics)
                {
                    if (node.Series is null || !node.Series.TryGetValue(metric, out var series) || series is null || series.Length == 0)
                    {
                        continue;
                    }

                    var limit = Math.Min(series.Length, binCount);
                    for (var i = 0; i < limit; i++)
                    {
                        var value = series[i];
                        if (!value.HasValue)
                        {
                            continue;
                        }

                        sb.AppendLine(FormattableString.Invariant($"{node.Id},*,{metric},{startBin + i},{value.Value}"));
                    }
                }
            }
        }

        return sb.ToString();
    }

    private IReadOnlyList<InspectorDependencyViewModel> BuildInspectorDependencies(string nodeId)
    {
        if (topologyGraph?.Edges is null || string.IsNullOrWhiteSpace(nodeId))
        {
            return Array.Empty<InspectorDependencyViewModel>();
        }

        var matches = new List<InspectorDependencyViewModel>();
        foreach (var edge in topologyGraph.Edges)
        {
            if (!string.Equals(edge.EdgeType, "dependency", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (!IsDependencyFieldEnabled(edge.Field))
            {
                continue;
            }

            var sourceNodeReference = ExtractNodeReference(edge.From);
            var targetNodeReference = ExtractNodeReference(edge.To);
            var isInbound = !string.IsNullOrWhiteSpace(targetNodeReference)
                && string.Equals(targetNodeReference, nodeId, StringComparison.OrdinalIgnoreCase);
            var isOutbound = !string.IsNullOrWhiteSpace(sourceNodeReference)
                && string.Equals(sourceNodeReference, nodeId, StringComparison.OrdinalIgnoreCase);

            if (!isInbound && !isOutbound)
            {
                continue;
            }

            var edgeId = edge.Id ?? $"{edge.From}->{edge.To}:{edge.Field}";
            var otherReference = isInbound ? edge.From : edge.To;
            var otherNodeId = isInbound ? sourceNodeReference : targetNodeReference;
            var otherNode = string.IsNullOrWhiteSpace(otherNodeId) ? null : FindTopologyNode(otherNodeId);
            var label = FormatDependencyFieldLabel(edge.Field, otherNode);
            var direction = isInbound ? "from" : "to";
            var source = $"{direction} {otherReference ?? "Unknown"}";
            var order = ResolveDependencyFieldOrder(edge.Field) + (isOutbound ? 100 : 0);
            matches.Add(new InspectorDependencyViewModel(edgeId, label, source, order));
        }

        if (matches.Count == 0)
        {
            return Array.Empty<InspectorDependencyViewModel>();
        }

        return matches
            .OrderBy(match => match.Order)
            .ThenBy(match => match.Source, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static int ResolveDependencyFieldOrder(string? field)
    {
        return field?.ToLowerInvariant() switch
        {
            "arrivals" => 0,
            "served" => 1,
            "attempts" => 2,
            "failures" => 3,
            "retryecho" or "retry_echo" => 4,
            "errors" => 5,
            "queue" => 6,
            "capacity" => 7,
            "expr" or "expression" => 8,
            _ => 9
        };
    }

    private static string FormatDependencyFieldLabel(string? field, TopologyNode? sourceNode)
    {
        var fallback = field?.ToLowerInvariant() switch
        {
            "arrivals" => "Arrivals",
            "served" => "Served",
            "errors" => "Errors",
            "attempts" => "Attempts",
            "failures" => "Failures",
            "retryecho" or "retry_echo" => "Retry echo",
            "queue" => "Queue depth",
            "capacity" => "Capacity",
            "expr" or "expression" => "Expression",
            _ => string.IsNullOrWhiteSpace(field)
                ? "Dependency"
                : CultureInfo.InvariantCulture.TextInfo.ToTitleCase(field.ToLowerInvariant())
        };

        var aliasKeys = BuildAliasKeyCandidates(field);
        var alias = TryResolveAlias(sourceNode, aliasKeys);
        return FormatSemanticLabelWithAlias(fallback, alias);
    }

    private bool IsDependencyFieldEnabled(string? field)
    {
        var key = field?.ToLowerInvariant();
        return key switch
        {
            "arrivals" => overlaySettings.ShowArrivalsDependencies,
            "served" => overlaySettings.ShowServedDependencies,
            "errors" => overlaySettings.ShowErrorsDependencies,
            "queue" => overlaySettings.ShowQueueDependencies,
            "capacity" => overlaySettings.ShowCapacityDependencies,
            "expr" or "expression" => overlaySettings.ShowExpressionDependencies,
            "attempts" or "failures" or "retryecho" or "retry_echo" => overlaySettings.ShowRetryMetrics,
            _ => true
        };
    }

    private bool IsDependencyHighlighted(string edgeId)
    {
        if (string.IsNullOrWhiteSpace(edgeId))
        {
            return false;
        }

        return string.Equals(inspectorHoveredEdgeId, edgeId, StringComparison.OrdinalIgnoreCase)
            || string.Equals(inspectorPinnedEdgeId, edgeId, StringComparison.OrdinalIgnoreCase)
            || string.Equals(canvasHoveredEdgeId, edgeId, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OnInspectorDependencyHover(string? edgeId)
    {
        if (string.Equals(inspectorHoveredEdgeId, edgeId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        inspectorHoveredEdgeId = edgeId;
        if (canvasComponent is not null)
        {
            await canvasComponent.SetInspectorEdgeHoverAsync(edgeId);
        }
        StateHasChanged();
    }

    private async Task OnInspectorDependencyClick(string? edgeId)
    {
        inspectorPinnedEdgeId = edgeId;
        if (canvasComponent is not null)
        {
            await canvasComponent.FocusEdgeAsync(edgeId, centerOnEdge: true);
        }
    }

    private Task OnCanvasEdgeHovered(string? edgeId)
    {
        if (string.Equals(canvasHoveredEdgeId, edgeId, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(pendingCanvasHoveredEdgeId, edgeId, StringComparison.OrdinalIgnoreCase))
        {
            return Task.CompletedTask;
        }

        pendingCanvasHoveredEdgeId = edgeId;
        ScheduleCanvasHoverStateUpdate();
        return Task.CompletedTask;
    }

    private void ScheduleCanvasHoverStateUpdate()
    {
        if (canvasHoverDebounceCts is { } existing)
        {
            existing.Cancel();
        }

        var cts = new CancellationTokenSource();
        canvasHoverDebounceCts = cts;
        _ = FlushCanvasHoverStateAsync(cts);
    }

    private async Task FlushCanvasHoverStateAsync(CancellationTokenSource cts)
    {
        try
        {
            await Task.Delay(canvasHoverDebounceInterval, cts.Token);
            if (cts.Token.IsCancellationRequested)
            {
                return;
            }

            await InvokeAsync(() =>
            {
                if (canvasHoverDebounceCts != cts)
                {
                    return;
                }

                canvasHoverDebounceCts = null;

                var nextId = pendingCanvasHoveredEdgeId;
                if (string.Equals(canvasHoveredEdgeId, nextId, StringComparison.OrdinalIgnoreCase))
                {
                    return;
                }

                canvasHoveredEdgeId = nextId;
                if (inspectorOpen)
                {
                    StateHasChanged();
                }
            });
        }
        catch (TaskCanceledException)
        {
            // Debounce canceled; nothing to flush.
        }
        finally
        {
            if (!ReferenceEquals(canvasHoverDebounceCts, cts) || canvasHoverDebounceCts is null)
            {
                cts.Dispose();
            }
        }
    }

    private void ClearInspectorEdgeHighlights()
    {
        inspectorHoveredEdgeId = null;
        inspectorPinnedEdgeId = null;
        canvasHoveredEdgeId = null;
        pendingCanvasHoveredEdgeId = null;
        if (canvasHoverDebounceCts is { } pending)
        {
            pending.Cancel();
            canvasHoverDebounceCts = null;
        }
        if (canvasComponent is not null)
        {
            _ = canvasComponent.SetInspectorEdgeHoverAsync(null);
            _ = canvasComponent.FocusEdgeAsync(null, centerOnEdge: false);
        }
    }

    private static double? GetValueAt(double?[]? series, int index)
    {
        if (series is null || index < 0 || index >= series.Length)
        {
            return null;
        }

        return series[index];
    }

    private static IReadOnlyList<double?> TrimSeries(double?[]? source, int limit, int fallbackLength = 0)
    {
        if (source is null || source.Length == 0)
        {
            return fallbackLength == 0
                ? Array.Empty<double?>()
                : Enumerable.Repeat<double?>(null, fallbackLength).ToArray();
        }

        if (source.Length <= limit)
        {
            return source.ToArray();
        }

        var start = Math.Max(0, source.Length - limit);
        var result = new double?[limit];
        Array.Copy(source, start, result, 0, limit);
        return result;
    }

private static IReadOnlyList<double?> TrimSeriesAt(double?[]? source, int limit, int anchorIndex, int fallbackLength = 0)
{
    var effectiveLength = Math.Max(limit, fallbackLength);
    if (effectiveLength <= 0)
    {
        return Array.Empty<double?>();
    }

    var result = new double?[effectiveLength];

    if (source is null || source.Length == 0)
    {
        return result;
    }

    var length = source.Length;
    var anchor = Math.Clamp(anchorIndex, 0, length - 1);
    var copyCount = Math.Min(effectiveLength, anchor + 1);
    if (copyCount <= 0)
    {
        return result;
    }

    var sourceStart = anchor - copyCount + 1;
    Array.Copy(source, sourceStart, result, effectiveLength - copyCount, copyCount);
    return result;
}

    private static void ApplyLegacyOverlayFields(string rawJson, TopologyOverlaySettings settings)
    {
        try
        {
            using var document = JsonDocument.Parse(rawJson);
            var root = document.RootElement;

            settings.ShowLabels = ResolveLegacyOverlay(root, "labels", settings.ShowLabels);
            settings.ShowEdgeArrows = ResolveLegacyOverlay(root, "edgeArrows", settings.ShowEdgeArrows);
            settings.ShowEdgeShares = ResolveLegacyOverlay(root, "edgeShares", settings.ShowEdgeShares);
            settings.ShowSparklines = ResolveLegacyOverlay(root, "sparklines", settings.ShowSparklines);
        }
        catch
        {
            // Legacy payload parsing failure can be ignored.
        }
    }

    private static bool ResolveLegacyOverlay(JsonElement root, string propertyName, bool currentValue)
    {
        if (root.TryGetProperty(propertyName, out var property) && property.ValueKind == JsonValueKind.Number)
        {
            var legacy = property.GetInt32();
            return legacy switch
            {
                1 => true,
                2 => false,
                _ => currentValue
            };
        }

        return currentValue;
    }

    private Task OnBinChanged(int value)
    {
        var clamped = Math.Clamp(value, visibleStartBin, visibleEndBin);
        if (clamped == selectedBin)
        {
            return Task.CompletedTask;
        }

        ApplyBinSelection(clamped);
        return Task.CompletedTask;
    }

    private void ApplyBinSelection(int bin, bool jumpPointer = false, bool cancelCurrentRefresh = true, bool forceRefresh = false)
    {
        ApplySelectedBinUi(bin);
        pointerNeedsJump = jumpPointer;
        _ = InvokeAsync(StateHasChanged);

        if (isDialPointerDragging && !forceRefresh)
        {
            pendingDragBin = bin;
            MaybeScheduleScrubRefresh(bin);
            return;
        }

        pendingDragBin = null;
        ScheduleBinDataRefresh(bin, cancelCurrentRefresh);
    }

