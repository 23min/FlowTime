                                                </MudStack>
                                            </MudTabPanel>
                                        }
                                    </MudTabs>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>

                </MudStack>
            }
        </MudStack>
    </MudPaper>
</MudStack>

