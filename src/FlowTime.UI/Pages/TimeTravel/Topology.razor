    private static IReadOnlyList<TimeTravelStateWarningDto> FilterWindowWarnings(IReadOnlyList<TimeTravelStateWarningDto>? warnings)
    {
        if (warnings is null || warnings.Count == 0)
        {
            return Array.Empty<TimeTravelStateWarningDto>();
        }

        var filtered = warnings.Where(ShouldDisplayStateWarning).ToArray();
        return filtered.Length == 0 ? Array.Empty<TimeTravelStateWarningDto>() : filtered;
    }

    private static bool ShouldDisplayStateWarning(TimeTravelStateWarningDto warning) =>
        warning is not null &&
        !string.Equals(warning.Code, "queue_latency_gate_closed", StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<TimeTravelStateWarningDto> GetInspectorWarnings(string nodeId)
    {
        if (windowWarnings.Count == 0 || string.IsNullOrWhiteSpace(nodeId))
        {
            return Array.Empty<TimeTravelStateWarningDto>();
        }

        return windowWarnings
            .Where(w => string.Equals(w.NodeId, nodeId, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

    private static string NormalizeWarningSeverity(string? severity)
    {
        return string.IsNullOrWhiteSpace(severity)
            ? "warning"
            : severity.Trim().ToLowerInvariant();
    }

    private static string FormatWarningBinRange(int? startBin, int? endBin)
    {
        if (!startBin.HasValue && !endBin.HasValue)
        {
            return string.Empty;
        }

        if (startBin.HasValue && endBin.HasValue)
        {
            return startBin == endBin ? startBin.Value.ToString() : $"{startBin}-{endBin}";
        }

        return (startBin ?? endBin)!.Value.ToString();
    }

    private void UpdateNodeWarningMap()
    {
        if (windowWarnings.Count == 0)
        {
            nodeWarningsForCanvas = emptyNodeWarnings;
            return;
        }

        var grouped = windowWarnings
            .Where(w => !string.IsNullOrWhiteSpace(w.NodeId))
            .GroupBy(w => w.NodeId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                g => g.Key,
                g => (IReadOnlyList<NodeWarningPayload>)g.Select(w =>
                {
                    var code = string.IsNullOrWhiteSpace(w.Code) ? "warning" : w.Code.Trim();
                    var message = string.IsNullOrWhiteSpace(w.Message) ? string.Empty : w.Message.Trim();
                    var severity = string.IsNullOrWhiteSpace(w.Severity) ? "warning" : w.Severity.Trim().ToLowerInvariant();
                    return new NodeWarningPayload(code, message, severity, w.NodeId);
                }).ToArray(),
                StringComparer.OrdinalIgnoreCase);

        nodeWarningsForCanvas = grouped.Count == 0 ? emptyNodeWarnings : grouped;
        Logger?.LogDebug("Node warning map rebuilt: {Count} nodes", nodeWarningsForCanvas.Count);
    }

    private void UpdateEdgeWarningMap()
    {
        if (windowData?.EdgeWarnings is null || windowData.EdgeWarnings.Count == 0)
        {
            edgeWarningsForCanvas = emptyEdgeWarnings;
            return;
        }

        var grouped = windowData.EdgeWarnings
            .Where(entry => !string.IsNullOrWhiteSpace(entry.Key))
            .ToDictionary(
                entry => entry.Key,
                entry => (IReadOnlyList<EdgeWarningPayload>)entry.Value
                    .Where(w => w is not null)
                    .Select(w =>
                    {
                        var code = string.IsNullOrWhiteSpace(w.Code) ? "warning" : w.Code.Trim();
                        var message = string.IsNullOrWhiteSpace(w.Message) ? string.Empty : w.Message.Trim();
                        var severity = string.IsNullOrWhiteSpace(w.Severity) ? "warning" : w.Severity.Trim().ToLowerInvariant();
                        return new EdgeWarningPayload(code, message, severity);
                    })
                    .ToArray(),
                StringComparer.OrdinalIgnoreCase);

        edgeWarningsForCanvas = grouped.Count == 0 ? emptyEdgeWarnings : grouped;
        Logger?.LogDebug("Edge warning map rebuilt: {Count} edges", edgeWarningsForCanvas.Count);
    }

    public void Dispose()
    {
        loadCts?.Cancel();
        loadCts?.Dispose();
        windowReloadCts?.Cancel();
        windowReloadCts?.Dispose();
        windowReloadCts = null;
        DisposeBinDataWorker();
        if (hotkeyRegistrationId.HasValue)
        {
            _ = JS.InvokeVoidAsync("FlowTime.TopologyHotkeys.unregister", hotkeyRegistrationId.Value);
        }
        selfReference?.Dispose();
        saveRunStateDebounceCts?.Cancel();
        saveRunStateDebounceCts?.Dispose();
        saveRunStateDebounceCts = null;
        canvasHoverDebounceCts?.Cancel();
        canvasHoverDebounceCts?.Dispose();
        canvasHoverDebounceCts = null;
    }
