    private IReadOnlyList<InspectorMetricBlock> BuildInspectorMetricBlocks(string? nodeId)
    {
        if (string.IsNullOrWhiteSpace(nodeId))
        {
            return Array.Empty<InspectorMetricBlock>();
        }

        nodeSparklines.TryGetValue(nodeId, out var baseSparkline);
        var topoNode = FindTopologyNode(nodeId);
        var nodeSeries = windowData?.Nodes.FirstOrDefault(node => string.Equals(node.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        var nodeCategory = ResolveNodeCategory(topoNode, nodeSeries);
        var nodeIdentity = ResolveAnalyticalIdentity(topoNode, nodeSeries);
        var provenanceKind = ResolveProvenanceKind(topoNode, nodeSeries);
        var kindKey = string.IsNullOrWhiteSpace(provenanceKind) ? "unknown" : provenanceKind;
        var availableSeries = BuildProvenanceSeriesKeys(nodeSeries);
        var provenanceCatalog = MetricProvenanceCatalog.GetForNodeKind(kindKey);
        var successLabel = ResolveSuccessRateLabel(nodeId);

        var blocks = new List<InspectorMetricBlock>();

        string Label(string fallback, params string[] keys) =>
            ResolveMetricLabel(topoNode, fallback, keys);

        MetricProvenanceEvaluation? ResolveProvenance(string? seriesKey)
        {
            if (string.IsNullOrWhiteSpace(seriesKey))
            {
                return null;
            }

            if (!provenanceCatalog.TryGetValue(seriesKey, out var definition))
            {
                return null;
            }

            var evaluation = definition.Evaluate(availableSeries);
            return AttachSeriesSemantics(evaluation, nodeSeries, seriesKey);
        }


        InspectorMetricBlock CreatePlaceholder(string title, InspectorValueFormat valueFormat = InspectorValueFormat.Number, string? seriesKey = null)
        {
            if (Logger is not null && loggedMissingMetricKinds.Add(kindKey))
            {
                Logger.LogWarning("Model does not include required series data for {NodeKind} inspector metrics (missing {Metric}).", kindKey, title);
            }

            return InspectorMetricBlock.CreatePlaceholder(title, InspectorMissingSeriesMessage, valueFormat, seriesKey, ResolveProvenance(seriesKey));
        }

        InspectorMetricBlock CreateSparkline(
            string title,
            NodeSparklineData data,
            string? ariaLabel = null,
            string? strokeOverride = null,
            InspectorValueFormat valueFormat = InspectorValueFormat.Number,
            string? seriesKey = null)
            => InspectorMetricBlock.FromSparkline(
                title,
                data,
                strokeOverride ?? ResolveInspectorSparklineStroke(data, seriesKey),
                ariaLabel ?? $"{title} sparkline",
                valueFormat,
                seriesKey,
                ResolveProvenance(seriesKey));

        void AddRequired(
            string title,
            string key,
            double? min = null,
            double? max = null,
            string? ariaLabel = null,
            string? strokeOverride = null,
            InspectorValueFormat valueFormat = InspectorValueFormat.Number,
            string? seriesKeyOverride = null)
        {
            if (baseSparkline is null)
            {
                var seriesKey = seriesKeyOverride ?? key;
                blocks.Add(CreatePlaceholder(title, valueFormat, seriesKey));
                return;
            }

            var sparkline = BuildInspectorSparkline(baseSparkline, key, min, max);
            if (sparkline is null)
            {
                var seriesKey = seriesKeyOverride ?? key;
                blocks.Add(CreatePlaceholder(title, valueFormat, seriesKey));
                return;
            }

            var resolvedSeriesKey = seriesKeyOverride ?? key;
            blocks.Add(CreateSparkline(title, sparkline, ariaLabel, strokeOverride, valueFormat, resolvedSeriesKey));
        }

        void AddOptional(
            string title,
            string key,
            double? min = null,
            double? max = null,
            string? ariaLabel = null,
            string? strokeOverride = null,
            InspectorValueFormat valueFormat = InspectorValueFormat.Number,
            string? seriesKeyOverride = null)
        {
            if (baseSparkline is null)
            {
                return;
            }

            var sparkline = BuildInspectorSparkline(baseSparkline, key, min, max);
            if (sparkline is null)
            {
                return;
            }

            var seriesKey = seriesKeyOverride ?? key;
            blocks.Add(CreateSparkline(title, sparkline, ariaLabel, strokeOverride, valueFormat, seriesKey));
        }

        if (IsComputedCategory(nodeCategory))
        {
            if (IsPmfIdentity(nodeIdentity))
            {
                var probabilitySparkline = BuildPmfSparkline(topoNode, baseSparkline);
                if (probabilitySparkline is not null)
                {
                    blocks.Add(InspectorMetricBlock.FromSparkline(
                        "Probability",
                        probabilitySparkline,
                        "#94A3B8",
                        seriesKey: "probability",
                        provenance: ResolveProvenance("probability")));
                }
                else
                {
                    blocks.Add(CreatePlaceholder("Probability", seriesKey: "probability"));
                }

                var valueSparkline = baseSparkline is not null ? BuildInspectorSparkline(baseSparkline, "values") : null;
                blocks.Add(valueSparkline is not null
                    ? CreateSparkline("Values", valueSparkline, strokeOverride: "#94A3B8", seriesKey: "values")
                    : CreatePlaceholder("Values", seriesKey: "values"));

                return blocks;
            }

            if (baseSparkline is not null)
            {
                var outputSparkline = BuildInspectorSparkline(baseSparkline, "values");
                blocks.Add(outputSparkline is not null ? CreateSparkline("Output", outputSparkline, strokeOverride: "#94A3B8", seriesKey: "values") : CreatePlaceholder("Output", seriesKey: "values"));
            }
            else
            {
                blocks.Add(CreatePlaceholder("Output", seriesKey: "values"));
            }

            AddOptional("Error rate", "errorRate", 0d, 1d, valueFormat: InspectorValueFormat.Percent, seriesKeyOverride: "errorRate");

            return blocks;
        }

        var isQueueNode = IsQueueCategory(nodeCategory);
        var isServiceWithBuffer = IsServiceWithBufferIdentity(nodeIdentity);
        var isRouterNode = IsRouterCategory(nodeCategory);
        var isSinkNode = IsSinkCategory(nodeCategory) || IsSinkRole(topoNode?.NodeRole);
        var isDependencyNode = IsDependencyCategory(nodeCategory);

        if (isDependencyNode)
        {
            AddRequired(Label("Arrivals", "arrivals"), "arrivals", 0d, seriesKeyOverride: "arrivals");
            AddRequired(Label("Served", "served"), "served", 0d, seriesKeyOverride: "served");
            AddRequired(Label("Errors", "errors"), "errors", 0d, seriesKeyOverride: "errors");
            return blocks;
        }
        var servedAlreadyAdded = false;

        if (isQueueNode || isServiceWithBuffer)
        {
            AddRequired(Label("Queue depth", "queue", "queueDepth"), "queue", 0d);
            AddRequired("Queue latency", "latencyMinutes", 0d);
            AddRequired(Label("Arrivals", "arrivals"), "arrivals", 0d);
            AddRequired(Label("Served", "served"), "served", 0d);
            servedAlreadyAdded = true;

            if (isQueueNode && !isServiceWithBuffer)
            {
                return blocks;
            }
        }
        else if (!isRouterNode)
        {
            AddRequired(Label("Arrivals", "arrivals"), "arrivals", 0d, seriesKeyOverride: "arrivals");
        }

        var showRetryMetrics = overlaySettings.ShowRetryMetrics;
        var showRetryBudget = overlaySettings.ShowRetryBudget;
        var hasAttemptsSeries = baseSparkline?.Series.ContainsKey("attempts") == true;
        var hasFailuresSeries = baseSparkline?.Series.ContainsKey("failures") == true;
        var hasRetryEchoSeries = baseSparkline?.Series.ContainsKey("retryEcho") == true;
        var hasServedSeries = baseSparkline?.Series.ContainsKey("served") == true || AllowsFallback("served");
        var hasExhaustedSeries = baseSparkline?.Series.ContainsKey("exhaustedFailures") == true;
        var hasBudgetSeries = baseSparkline?.Series.ContainsKey("retryBudgetRemaining") == true;
        var wantsRetryMetrics = showRetryMetrics && (hasAttemptsSeries ||
            hasFailuresSeries ||
            hasRetryEchoSeries ||
            hasExhaustedSeries ||
            !string.IsNullOrWhiteSpace(topoNode?.Semantics?.Attempts) ||
            !string.IsNullOrWhiteSpace(topoNode?.Semantics?.Failures) ||
            !string.IsNullOrWhiteSpace(topoNode?.Semantics?.RetryEcho) ||
            !string.IsNullOrWhiteSpace(topoNode?.Semantics?.ExhaustedFailures));

        if (wantsRetryMetrics && (hasAttemptsSeries || !string.IsNullOrWhiteSpace(topoNode?.Semantics?.Attempts)))
        {
            AddRequired(Label("Attempts", "attempts"), "attempts", 0d, seriesKeyOverride: "attempts");
        }

        if (isRouterNode)
        {
            AddRequired(Label("Arrivals", "arrivals"), "arrivals", 0d, seriesKeyOverride: "arrivals");
        }

        if (hasServedSeries && !servedAlreadyAdded)
        {
            AddRequired(Label("Served", "served"), "served", 0d, seriesKeyOverride: "served");
        }

        if (wantsRetryMetrics && (hasFailuresSeries || !string.IsNullOrWhiteSpace(topoNode?.Semantics?.Failures)))
        {
            AddRequired(Label("Failed retries", "failures"), "failures", 0d, seriesKeyOverride: "failures");
        }

        if (wantsRetryMetrics && (hasRetryEchoSeries || !string.IsNullOrWhiteSpace(topoNode?.Semantics?.RetryEcho)))
        {
            AddRequired(Label("Retry echo", "retryEcho", "retry_echo", "retry"), "retryEcho", 0d, seriesKeyOverride: "retryEcho");
        }

        if (wantsRetryMetrics && (hasExhaustedSeries || !string.IsNullOrWhiteSpace(topoNode?.Semantics?.ExhaustedFailures)))
        {
            AddRequired(Label("Exhausted", "exhaustedFailures"), "exhaustedFailures", 0d, seriesKeyOverride: "exhaustedFailures");
        }

        if (showRetryBudget && (hasBudgetSeries || !string.IsNullOrWhiteSpace(topoNode?.Semantics?.RetryBudgetRemaining)))
        {
            AddRequired(Label("Retry budget remaining", "retryBudgetRemaining"), "retryBudgetRemaining", 0d, seriesKeyOverride: "retryBudgetRemaining");
        }

        if (wantsRetryMetrics)
        {
            AddRequired("Retry tax", "retryTax", 0d, 1d, valueFormat: InspectorValueFormat.Percent, seriesKeyOverride: "retryTax");
        }

        AddRequired(successLabel, "successRate", 0d, 1d, valueFormat: InspectorValueFormat.Percent);
        if (isSinkNode)
        {
            AddOptional("Utilization", "utilization", 0d, 1d, valueFormat: InspectorValueFormat.Percent);
        }
        else
        {
            AddRequired("Utilization", "utilization", 0d, 1d, valueFormat: InspectorValueFormat.Percent);
        }
        if (!isSinkNode)
        {
            AddRequired("Service time", "serviceTimeMs", 0d, seriesKeyOverride: "serviceTimeMs");
        }
        AddRequired("Flow latency", "flowLatencyMs", 0d, seriesKeyOverride: "flowLatencyMs");
        if (isSinkNode)
        {
            AddOptional("Error rate", "errorRate", 0d, 1d, valueFormat: InspectorValueFormat.Percent);
        }
        else
        {
            AddRequired("Error rate", "errorRate", 0d, 1d, valueFormat: InspectorValueFormat.Percent);
        }
        AddOptional(Label("Errors", "errors"), "errors", 0d, ariaLabel: "Errors sparkline");

        return blocks;
    }

    private IReadOnlyList<InspectorMetricBlock> BuildInspectorConstraintBlocks(string? nodeId, string? constraintId)
    {
        if (string.IsNullOrWhiteSpace(nodeId) || string.IsNullOrWhiteSpace(constraintId) || windowData is null)
        {
            return Array.Empty<InspectorMetricBlock>();
        }

        var seriesNode = windowData.Nodes.FirstOrDefault(node => string.Equals(node.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        if (seriesNode?.Constraints is null ||
            !seriesNode.Constraints.TryGetValue(constraintId, out var constraintSeries) ||
            constraintSeries.Series.Count == 0)
        {
            return Array.Empty<InspectorMetricBlock>();
        }

        var sparkline = BuildConstraintSparklineData(seriesNode, constraintId);
        if (sparkline is null)
        {
            return Array.Empty<InspectorMetricBlock>();
        }

        var blocks = new List<InspectorMetricBlock>();

        InspectorMetricBlock CreatePlaceholder(string title, string seriesKey, InspectorValueFormat valueFormat = InspectorValueFormat.Number)
            => InspectorMetricBlock.CreatePlaceholder(title, InspectorMissingSeriesMessage, valueFormat, seriesKey, ResolveConstraintProvenance(constraintSeries, title, key: seriesKey));

        void AddConstraintSeries(
            string title,
            string key,
            bool required,
            InspectorValueFormat valueFormat = InspectorValueFormat.Number,
            double? min = null,
            double? max = null)
        {
            var seriesKey = $"constraint:{constraintId}:{key}";
            var blockSparkline = BuildInspectorSparkline(sparkline, key, min, max);
            if (blockSparkline is null)
            {
                if (required)
                {
                    blocks.Add(CreatePlaceholder(title, seriesKey, valueFormat));
                }
                return;
            }

            var provenance = ResolveConstraintProvenance(constraintSeries, title, seriesKey);
            blocks.Add(InspectorMetricBlock.FromSparkline(
                title,
                blockSparkline,
                ResolveInspectorSparklineStroke(blockSparkline, seriesKey),
                ariaLabel: $"{title} sparkline",
                valueFormat: valueFormat,
                seriesKey: seriesKey,
                provenance: provenance));
        }

        AddConstraintSeries("Arrivals", "arrivals", required: true, min: 0d);
        AddConstraintSeries("Served", "served", required: true, min: 0d);
        AddConstraintSeries("Errors", "errors", required: false, min: 0d);
        AddConstraintSeries("Shortfall", "shortfall", required: false, min: 0d);
        AddConstraintSeries("Latency", "latencyMinutes", required: false, min: 0d);

        return blocks;
    }

    private static MetricProvenanceEvaluation? ResolveConstraintProvenance(
        TimeTravelConstraintSeriesDto constraintSeries,
        string title,
        string key)
    {
        if (constraintSeries.Series is null)
        {
            return null;
        }

        var metricKey = key.Split(':').LastOrDefault() ?? key;
        var unit = metricKey.Equals("latencyMinutes", StringComparison.OrdinalIgnoreCase)
            ? "min"
            : "count";
        var meaning = metricKey switch
        {
            "arrivals" => "Observed arrivals for the constraint resource.",
            "served" => "Constraint capacity delivered.",
            "errors" => "Constraint errors observed.",
            "shortfall" => "Demand that exceeded constraint capacity.",
            "latencyMinutes" => "Constraint latency (source-defined).",
            _ => null
        };

        var definition = new MetricProvenanceDefinition(
            metricKey,
            title,
            unit,
            new[]
            {
                new MetricFormulaOption($"{title} = {metricKey} series", new[] { metricKey })
            },
            Array.Empty<string>(),
            meaning);

        var available = constraintSeries.Series.Keys as IReadOnlyCollection<string> ?? constraintSeries.Series.Keys.ToList();
        var evaluation = definition.Evaluate(available);
        var semantics = constraintSeries.SeriesMetadata is not null &&
                        constraintSeries.SeriesMetadata.TryGetValue(metricKey, out var metadata)
            ? metadata
            : null;

        return evaluation with { SeriesSemantics = semantics };
    }

    private static IReadOnlyCollection<string> BuildProvenanceSeriesKeys(TimeTravelNodeSeriesDto? node)
    {
        if (node is null)
        {
            return Array.Empty<string>();
        }

        var keys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (node.Series is not null)
        {
            foreach (var key in node.Series.Keys)
            {
                keys.Add(key);
            }
        }

        if (node.ByClass is not null)
        {
            foreach (var classSeries in node.ByClass.Values)
            {
                foreach (var key in classSeries.Keys)
                {
                    keys.Add(key);
                }
            }
        }

        if (node.Sla is not null)
        {
            foreach (var sla in node.Sla)
            {
                if (!string.IsNullOrWhiteSpace(sla.Kind))
                {
                    keys.Add($"sla:{sla.Kind}");
                }
            }
        }

        return keys.ToArray();
    }

    private static MetricProvenanceEvaluation AttachSeriesSemantics(
        MetricProvenanceEvaluation evaluation,
        TimeTravelNodeSeriesDto? node,
        string seriesKey)
    {
        if (node?.SeriesMetadata is null)
        {
            return evaluation;
        }

        return node.SeriesMetadata.TryGetValue(seriesKey, out var semantics)
            ? evaluation with { SeriesSemantics = semantics }
            : evaluation;
    }


    private async Task DumpInspectorBinAsync(BinDumpRequest request)
    {
        var targetNodeId = request.NodeId ?? inspectorNodeId ?? lastInspectorNodeId;
        var dump = BuildInspectorBinDump(targetNodeId);
        if (dump is null)
        {
            return;
        }

        var json = JsonSerializer.Serialize(dump, new JsonSerializerOptions { WriteIndented = true });
        var nodeLabel = string.IsNullOrWhiteSpace(dump.NodeId) ? "node" : dump.NodeId;
        var fileName = $"bin_dump_{nodeLabel}_{dump.SelectedBin}.json";
        if (request.OpenInNewTab)
        {
            await JS.InvokeVoidAsync("FlowTime.openTextInNewTab", fileName, json, "application/json");
        }
        else
        {
            await JS.InvokeVoidAsync("FlowTime.downloadText", fileName, json, "application/json");
        }
    }


    private BinDebugDump? BuildInspectorBinDump(string? nodeId)
    {
        if (string.IsNullOrWhiteSpace(nodeId) || windowData is null)
        {
            return null;
        }

        var node = windowData.Nodes.FirstOrDefault(entry => string.Equals(entry.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        if (node is null)
        {
            return null;
        }

        var windowStart = windowData.Window.StartBin;
        var localIndex = selectedBin - windowStart;
        var timestamp = localIndex >= 0 && localIndex < windowData.TimestampsUtc.Count
            ? windowData.TimestampsUtc[localIndex]
            : (DateTimeOffset?)null;
        var selectedSeries = BuildSeriesSnapshot(node, localIndex, HasClassSelection, selectedClasses);
        var unfilteredSeries = BuildSeriesSnapshot(node, localIndex, hasClassSelection: false, Array.Empty<string>());
        var metricsSnapshot = ComputeActiveMetricsSnapshot(
            CaptureBinDataContext(),
            selectedBin,
            nodeSparklines ?? new Dictionary<string, NodeSparklineData>(StringComparer.OrdinalIgnoreCase),
            nodesMissingSparkline ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase),
            CancellationToken.None);
        metricsSnapshot.Metrics.TryGetValue(nodeId, out var metrics);
        var derived = BuildDerivedMetricsSnapshot(metrics);
        var sla = BuildSlaSnapshot(node, localIndex);
        var queueLatencyStatus = ResolveQueueLatencyStatus(node, localIndex);
        var topoNode = FindTopologyNode(nodeId);
        var dispatchSchedule = topoNode?.DispatchSchedule ?? ToGraphDispatchSchedule(node.DispatchSchedule);
        var provenance = BuildMetricProvenanceBundle(node, topoNode);

        return new BinDebugDump(
            RunId: currentRunId,
            NodeId: nodeId,
            NodeKind: ResolveNodeDisplayKind(topoNode, node, metrics),
            NodeRole: topoNode?.NodeRole,
            DispatchSchedule: dispatchSchedule,
            SelectedBin: selectedBin,
            WindowStartBin: windowStart,
            SelectedTimestampUtc: timestamp,
            SelectedClasses: selectedClasses.ToArray(),
            HasClassSelection: HasClassSelection,
            SelectedSeries: selectedSeries,
            UnfilteredSeries: unfilteredSeries,
            DerivedMetrics: derived,
            SlaValues: sla,
            Provenance: provenance,
            QueueLatencyStatusCode: queueLatencyStatus?.Code,
            QueueLatencyStatusMessage: queueLatencyStatus?.Message);
    }

    private static MetricProvenanceBundle? BuildMetricProvenanceBundle(TimeTravelNodeSeriesDto node, TopologyNode? topoNode)
    {
        var nodeKind = ResolveProvenanceKind(topoNode, node);
        var availableSeries = BuildProvenanceSeriesKeys(node);
        if (string.IsNullOrWhiteSpace(nodeKind))
        {
            return null;
        }

        var catalog = MetricProvenanceCatalog.GetForNodeKind(nodeKind);
        if (catalog.Count == 0)
        {
            return new MetricProvenanceBundle(nodeKind, availableSeries, new Dictionary<string, MetricProvenanceEvaluation>());
        }

        var evaluations = new Dictionary<string, MetricProvenanceEvaluation>(StringComparer.OrdinalIgnoreCase);
        foreach (var entry in catalog)
        {
            var evaluation = entry.Value.Evaluate(availableSeries);
            evaluations[entry.Key] = AttachSeriesSemantics(evaluation, node, entry.Key);
        }

        return new MetricProvenanceBundle(nodeKind, availableSeries, evaluations);
    }

    private IReadOnlyDictionary<string, double?> BuildSeriesSnapshot(
        TimeTravelNodeSeriesDto node,
        int localIndex,
        bool hasClassSelection,
        IReadOnlyCollection<string> classSelection)
    {
        var keys = new[]
        {
            "arrivals", "served", "errors", "attempts", "failures", "retryEcho", "exhaustedFailures",
            "retryBudgetRemaining", "retryTax", "queue", "capacity", "parallelism", "effectiveCapacity", "throughputRatio",
            "utilization", "latencyMinutes", "serviceTimeMs", "flowLatencyMs"
        };

        var result = new Dictionary<string, double?>(StringComparer.OrdinalIgnoreCase);
        foreach (var key in keys)
        {
            var classDataFound = !hasClassSelection;
            var classVolume = 0d;
            var value = GetSeriesValueSnapshot(node, key, localIndex, ref classDataFound, ref classVolume, hasClassSelection, classSelection);
            result[key] = value;
        }

        if (!result.TryGetValue("effectiveCapacity", out var existingEffective) || !existingEffective.HasValue)
        {
            if (result.TryGetValue("capacity", out var capacity) &&
                result.TryGetValue("parallelism", out var parallelism) &&
                capacity.HasValue &&
                parallelism.HasValue)
            {
                result["effectiveCapacity"] = capacity.Value * parallelism.Value;
            }
        }

        return result;
    }

    private static IReadOnlyDictionary<string, double?> BuildDerivedMetricsSnapshot(NodeBinMetrics? metrics)
    {
        if (metrics is null)
        {
            return new Dictionary<string, double?>(StringComparer.OrdinalIgnoreCase);
        }

        return new Dictionary<string, double?>(StringComparer.OrdinalIgnoreCase)
        {
            ["successRate"] = metrics.SuccessRate,
            ["utilization"] = metrics.Utilization,
            ["errorRate"] = metrics.ErrorRate,
            ["queueDepth"] = metrics.QueueDepth,
            ["latencyMinutes"] = metrics.LatencyMinutes,
            ["serviceTimeMs"] = metrics.ServiceTimeMs,
            ["flowLatencyMs"] = metrics.FlowLatencyMs,
            ["retryTax"] = metrics.RetryTax
        };
    }

    private static IReadOnlyDictionary<string, double?> BuildSlaSnapshot(TimeTravelNodeSeriesDto node, int localIndex)
    {
        var result = new Dictionary<string, double?>(StringComparer.OrdinalIgnoreCase)
        {
            ["completion"] = GetSlaValueSnapshot(node, "completion", localIndex),
            ["backlogAge"] = GetSlaValueSnapshot(node, "backlogAge", localIndex),
            ["scheduleAdherence"] = GetSlaValueSnapshot(node, "scheduleAdherence", localIndex)
        };

        return result;
    }

    private IReadOnlyList<InspectorBinMetric> BuildInspectorBinMetrics(string? nodeId, NodeBinMetrics? metrics)
    {
        if (string.IsNullOrWhiteSpace(nodeId))
        {
            return Array.Empty<InspectorBinMetric>();
        }

        var rows = new List<InspectorBinMetric>();
        var localIndex = windowData is null ? -1 : selectedBin - windowData.Window.StartBin;
        var timestampLabel = windowData is null ? string.Empty : FormatTimestampSnapshot(windowData.TimestampsUtc, localIndex);
        var seriesNode = windowData?.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        var topoNode = FindTopologyNode(nodeId);
        var nodeCategory = ResolveNodeCategory(topoNode, seriesNode, metrics);
        var nodeIdentity = ResolveAnalyticalIdentity(topoNode, seriesNode, metrics);
        var hasQueueSemantics = ResolveHasQueueSemantics(topoNode, seriesNode, metrics);
        var nodeKind = ResolveProvenanceKind(topoNode, seriesNode, metrics);
        var availableSeries = BuildProvenanceSeriesKeys(seriesNode);
        var provenanceCatalog = MetricProvenanceCatalog.GetForNodeKind(nodeKind ?? string.Empty);

        MetricProvenanceEvaluation? ResolveBinProvenance(string? metricKey)
        {
            if (string.IsNullOrWhiteSpace(metricKey))
            {
                return null;
            }

            if (!provenanceCatalog.TryGetValue(metricKey, out var definition))
            {
                return null;
            }

            var evaluation = definition.Evaluate(availableSeries);
            return AttachSeriesSemantics(evaluation, seriesNode, metricKey);
        }

        InspectorBinMetric CreateRow(
            string label,
            string value,
            string? metricKey = null,
            InspectorBinMetricSection section = InspectorBinMetricSection.Series,
            string? alias = null,
            bool includeAliasInTooltip = false)
        {
            return new InspectorBinMetric(label, value, ResolveBinProvenance(metricKey), section, alias, includeAliasInTooltip);
        }

        if (!string.IsNullOrWhiteSpace(timestampLabel))
        {
            rows.Add(CreateRow("Timestamp", timestampLabel));
        }
        rows.Add(CreateRow("bin", selectedBin.ToString(CultureInfo.InvariantCulture)));
        if (metrics is not null &&
            string.Equals(metrics.CustomLabel, binValueLabel, StringComparison.OrdinalIgnoreCase) &&
            metrics.CustomValue.HasValue)
        {
            rows.Add(CreateRow(binValueLabel, FormatBinValue(metrics.CustomValue, InspectorValueFormat.Number)));
        }
        else
        {
            rows.Add(CreateRow(binValueLabel, "-"));
        }
        if (metrics is not null &&
            !string.IsNullOrWhiteSpace(metrics.CustomLabel) &&
            !string.Equals(metrics.CustomLabel, binValueLabel, StringComparison.OrdinalIgnoreCase))
        {
            if (metrics.CustomValue.HasValue)
            {
                rows.Add(CreateRow(metrics.CustomLabel!, FormatBinValue(metrics.CustomValue, InspectorValueFormat.Number)));
            }
            else if (string.Equals(metrics.CustomLabel, missingSeriesMessage, StringComparison.Ordinal))
            {
                rows.Add(CreateRow("Value", metrics.CustomLabel));
            }
        }
        var raw = metrics?.RawMetrics;
        var successLabel = ResolveSuccessRateLabel(nodeId);
        var isSink = IsSinkCategory(nodeCategory) || IsSinkRole(topoNode?.NodeRole);
        var isDependency = IsDependencyCategory(nodeCategory);
        var isRouter = IsRouterCategory(nodeCategory);
        var isServiceWithBuffer = IsServiceWithBufferIdentity(nodeIdentity);
        var dispatchSchedule = topoNode?.DispatchSchedule ?? ToGraphDispatchSchedule(seriesNode?.DispatchSchedule);
        var scheduleEntry = dispatchScheduleEntries.FirstOrDefault(entry => string.Equals(entry.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));
        var hasSchedule = dispatchSchedule is not null
            || scheduleEntry is not null
            || string.Equals(successLabel, "Schedule SLA", StringComparison.OrdinalIgnoreCase);
        var constraintIds = ExtractConstraintIds(seriesNode);

        string? ResolveAlias(params string[] keys) => TryResolveAlias(topoNode, keys);

        string Label(string fallback, params string[] keys) =>
            FormatSemanticLabelWithAlias(fallback, ResolveAlias(keys));

        string? FormatSlaStatus(string? status)
        {
            if (string.IsNullOrWhiteSpace(status))
            {
                return null;
            }

            return status.Trim().ToLowerInvariant() switch
            {
                "unavailable" => "Unavailable",
                "noevents" => "No events",
                _ => null
            };
        }

        void AddConstraintStatus(TimeTravelNodeSeriesDto node, string constraintId, int localIndex)
        {
            var status = GetConstraintStatusValueSnapshot(node, constraintId, localIndex);
            var label = $"Limited: {constraintId}";
            var value = status.HasValue ? (status.Value >= 0.5d ? "Yes" : "No") : "-";
            rows.Add(CreateRow(label, value, section: InspectorBinMetricSection.Constraints));
        }

        void AddConstraintMetric(
            TimeTravelNodeSeriesDto node,
            string constraintId,
            string metricKey,
            string label,
            int localIndex,
            InspectorValueFormat format = InspectorValueFormat.Number,
            string? unit = null)
        {
            var value = GetConstraintSeriesValueSnapshot(node, constraintId, metricKey, localIndex);
            var rowLabel = $"{constraintId}: {label}";
            rows.Add(CreateRow(rowLabel, FormatBinValue(value, format, unit), section: InspectorBinMetricSection.Constraints));
        }

        void AddRaw(
            string fallback,
            string key,
            InspectorValueFormat format = InspectorValueFormat.Number,
            string? unit = null,
            bool gate = true,
            bool useAlias = true,
            bool includeAliasInTooltip = false)
        {
            if (!gate)
            {
                return;
            }

            if (raw is null || !raw.TryGetValue(key, out var value) || !value.HasValue)
            {
                return;
            }

            var alias = ResolveAlias(key);
            var label = useAlias ? FormatSemanticLabelWithAlias(fallback, alias) : fallback;
            rows.Add(CreateRow(label, FormatBinValue(value, format, unit), key, InspectorBinMetricSection.Series, alias, includeAliasInTooltip));
        }

        void AddDerived(
            string fallback,
            double? value,
            InspectorValueFormat format = InspectorValueFormat.Number,
            string? unit = null,
            bool gate = true,
            bool alwaysShow = false,
            string? metricKey = null,
            params string[] aliasKeys)
        {
            if (!gate)
            {
                return;
            }

            if (!value.HasValue)
            {
                if (alwaysShow)
                {
                    rows.Add(CreateRow(Label(fallback, aliasKeys), "-", metricKey, InspectorBinMetricSection.Derived));
                }

                return;
            }

            rows.Add(CreateRow(Label(fallback, aliasKeys), FormatBinValue(value, format, unit), metricKey, InspectorBinMetricSection.Derived));
        }

        void AddSlaMetric(
            string label,
            string kind,
            InspectorValueFormat format,
            string? unit = null,
            double? fallbackValue = null,
            bool alwaysShow = false)
        {
            var slaSeries = seriesNode?.Sla?.FirstOrDefault(s => string.Equals(s.Kind, kind, StringComparison.OrdinalIgnoreCase));
            var value = fallbackValue;

            if (slaSeries is not null &&
                slaSeries.Values is not null &&
                localIndex >= 0 &&
                localIndex < slaSeries.Values.Length)
            {
                value = slaSeries.Values[localIndex];
            }

            if (value.HasValue)
            {
                rows.Add(CreateRow(label, FormatBinValue(value, format, unit), kind, InspectorBinMetricSection.Derived));
                return;
            }

            var statusLabel = FormatSlaStatus(slaSeries?.Status);
            if (!string.IsNullOrWhiteSpace(statusLabel))
            {
                rows.Add(CreateRow(label, statusLabel!, kind, InspectorBinMetricSection.Derived));
                return;
            }

            if (alwaysShow)
            {
                rows.Add(CreateRow(label, "-", kind, InspectorBinMetricSection.Derived));
            }
        }

        if (metrics is null)
        {
            if (isDependency)
            {
                return rows;
            }

            if (isSink && hasSchedule)
            {
                rows.Add(CreateRow(
                    "Arrival schedule",
                    dispatchSchedule is null ? scheduleEntry?.Summary ?? "-" : FormatDispatchSummary(dispatchSchedule),
                    "arrivalSchedule",
                    InspectorBinMetricSection.Derived));
                rows.Add(CreateRow(
                    "Schedule capacity",
                    dispatchSchedule is null ? scheduleEntry?.CapacityLabel ?? "-" : FormatDispatchCapacity(dispatchSchedule),
                    "scheduleCapacity",
                    InspectorBinMetricSection.Derived));
                AddSlaMetric(successLabel, "scheduleAdherence", InspectorValueFormat.Percent, alwaysShow: true);
            }
            else if (!isSink && (hasQueueSemantics || isServiceWithBuffer))
            {
                rows.Add(CreateRow("Queue latency", "-", "latencyMinutes", InspectorBinMetricSection.Derived));
            }

            return rows;
        }

        var safeMetrics = metrics;
        if (isDependency)
        {
            AddRaw("Arrivals", "arrivals");
            AddRaw("Served", "served");
            AddRaw("Errors", "errors");
            return rows;
        }
        AddRaw("Arrivals", "arrivals");
        AddRaw("Served", "served");
        AddRaw("Errors", "errors");
        AddRaw("Attempts", "attempts", gate: !isSink);
        AddRaw("Failed retries", "failures", gate: !isSink);
        AddRaw("Exhausted", "exhaustedFailures", gate: overlaySettings.ShowRetryMetrics && !isSink);
        AddRaw("Retry echo", "retryEcho", gate: !isSink);
        AddRaw("Retry budget remaining", "retryBudgetRemaining", gate: overlaySettings.ShowRetryBudget && !isSink);
        AddRaw("Queue depth", "queue", gate: !isSink, useAlias: false, includeAliasInTooltip: true);
        AddRaw("Capacity", "capacity", gate: !isSink);
        AddRaw("Instances", "parallelism", gate: !isSink);
        AddDerived("Effective capacity", raw is not null && raw.TryGetValue("effectiveCapacity", out var effectiveCapacity) ? effectiveCapacity : null, gate: !isSink, metricKey: "effectiveCapacity");
        AddRaw("Max attempts", "maxAttempts", gate: !isSink);

        if (constraintIds.Count > 0 && seriesNode is not null)
        {
            foreach (var constraintId in constraintIds)
            {
                AddConstraintStatus(seriesNode, constraintId, localIndex);
                AddConstraintMetric(seriesNode, constraintId, "arrivals", "Arrivals", localIndex);
                AddConstraintMetric(seriesNode, constraintId, "served", "Served", localIndex);
                AddConstraintMetric(seriesNode, constraintId, "errors", "Errors", localIndex);
                AddConstraintMetric(seriesNode, constraintId, "shortfall", "Shortfall", localIndex);
                AddConstraintMetric(seriesNode, constraintId, "latencyMinutes", "Latency", localIndex, unit: "min");
            }
        }

        if (isSink && hasSchedule)
        {
            rows.Add(CreateRow(
                "Arrival schedule",
                dispatchSchedule is null ? scheduleEntry?.Summary ?? "-" : FormatDispatchSummary(dispatchSchedule),
                "arrivalSchedule",
                InspectorBinMetricSection.Derived));
            rows.Add(CreateRow(
                "Schedule capacity",
                dispatchSchedule is null ? scheduleEntry?.CapacityLabel ?? "-" : FormatDispatchCapacity(dispatchSchedule),
                "scheduleCapacity",
                InspectorBinMetricSection.Derived));
            AddSlaMetric(successLabel, "scheduleAdherence", InspectorValueFormat.Percent, fallbackValue: safeMetrics.SuccessRate, alwaysShow: true);
        }
        else
        {
            AddSlaMetric(successLabel, "completion", InspectorValueFormat.Percent, fallbackValue: safeMetrics.SuccessRate);
        }
        if (!isSink && !isRouter)
        {
            AddSlaMetric("Backlog age SLA", "backlogAge", InspectorValueFormat.Number, unit: "min");
        }
        if (!isSink && !isRouter)
        {
            var scheduleLabel = hasSchedule ? "Schedule SLA" : "Schedule adherence";
            AddSlaMetric(scheduleLabel, "scheduleAdherence", InspectorValueFormat.Percent);
        }
        AddDerived("Utilization", safeMetrics.Utilization, InspectorValueFormat.Percent, gate: !isSink, metricKey: "utilization");
        AddDerived("Error rate", safeMetrics.ErrorRate, InspectorValueFormat.Percent, metricKey: "errorRate");
        if (!isSink && !isRouter && (hasQueueSemantics || isServiceWithBuffer))
        {
            AddDerived("Queue latency", safeMetrics.LatencyMinutes, InspectorValueFormat.Number, "min", alwaysShow: true, metricKey: "latencyMinutes");
        }
        AddDerived("Service time", safeMetrics.ServiceTimeMs, InspectorValueFormat.DurationMs, gate: !isSink && !isRouter, metricKey: "serviceTimeMs");
        AddDerived("Flow latency", safeMetrics.FlowLatencyMs, InspectorValueFormat.DurationMs, gate: !isRouter, metricKey: "flowLatencyMs");
        AddDerived("Retry tax", safeMetrics.RetryTax, InspectorValueFormat.Percent, gate: !isSink, metricKey: "retryTax");

        if (!isSink && safeMetrics.QueueLatencyStatus is not null)
        {
            rows.Add(CreateRow("Latency status", FormatQueueLatencyStatusLabel(safeMetrics.QueueLatencyStatus!), "queueLatencyStatus", InspectorBinMetricSection.Derived));
        }

        return rows;
    }

    private NodeSparklineData? BuildInspectorSparkline(NodeSparklineData sparkline, string primaryKey, double? explicitMin = null, double? explicitMax = null)
    {
        if (sparkline is null)
        {
            return null;
        }

        var slice = ResolveMetricSeriesSlice(sparkline, primaryKey);
        if (slice is null && AllowsFallback(primaryKey))
        {
            slice = ResolveFallbackSlice(sparkline, primaryKey);
        }
        if (slice is null || slice.Values.Count == 0 || !slice.Values.Any(v => v.HasValue && double.IsFinite(v.Value)))
        {
            return null;
        }

        var values = slice.Values as double?[] ?? slice.Values.ToArray();

        var additional = new Dictionary<string, SparklineSeriesSlice>(StringComparer.OrdinalIgnoreCase)
        {
            [primaryKey] = new SparklineSeriesSlice(values, slice.StartIndex)
        };

        return NodeSparklineData.Create(
            values,
            Array.Empty<double?>(),
            Array.Empty<double?>(),
            Array.Empty<double?>(),
            slice.StartIndex,
            explicitMin,
            explicitMax,
            additionalSeries: additional);
    }

    private NodeSparklineData? BuildConstraintSparklineData(TimeTravelNodeSeriesDto node, string constraintId)
    {
        if (windowData is null ||
            node.Constraints is null ||
            !node.Constraints.TryGetValue(constraintId, out var constraintSeries) ||
            constraintSeries.Series.Count == 0)
        {
            return null;
        }

        var startBin = windowData.Window.StartBin;
        var totalBins = constraintSeries.Series.Values.FirstOrDefault()?.Length ?? 0;
        if (totalBins <= 0)
        {
            return null;
        }

        var localIndex = Math.Clamp(selectedBin - startBin, 0, totalBins - 1);
        var primarySeries = constraintSeries.Series.TryGetValue("arrivals", out var arrivalsSeries)
            ? arrivalsSeries
            : constraintSeries.Series.TryGetValue("served", out var servedSeries)
                ? servedSeries
                : constraintSeries.Series.Values.FirstOrDefault();

        if (primarySeries is null || primarySeries.Length == 0)
        {
            return null;
        }

        var trimmedPrimary = TrimSeriesAt(primarySeries, sparklinePointLimit, localIndex);
        if (trimmedPrimary.Count == 0)
        {
            return null;
        }

        var primaryStartIndex = startBin + (localIndex + 1 - trimmedPrimary.Count);
        var additional = new Dictionary<string, SparklineSeriesSlice>(StringComparer.OrdinalIgnoreCase);
        foreach (var pair in constraintSeries.Series)
        {
            var series = pair.Value ?? Array.Empty<double?>();
            var trimmed = TrimSeriesAt(series, sparklinePointLimit, localIndex, trimmedPrimary.Count);
            var startIndex = series.Length == 0
                ? primaryStartIndex
                : startBin + (localIndex + 1 - trimmed.Count);
            additional[pair.Key] = new SparklineSeriesSlice(trimmed, startIndex);
        }

        return NodeSparklineData.Create(
            trimmedPrimary,
            Array.Empty<double?>(),
            Array.Empty<double?>(),
            Array.Empty<double?>(),
            primaryStartIndex,
            additionalSeries: additional);
    }

    private static SparklineSeriesSlice? ResolveMetricSeriesSlice(NodeSparklineData sparkline, string primaryKey)
    {
        if (sparkline.Series.TryGetValue(primaryKey, out var slice))
        {
            return slice;
        }

        return primaryKey switch
        {
            "queue" when sparkline.Series.TryGetValue("queueDepth", out var queueSlice) => queueSlice,
            "queueDepth" when sparkline.Series.TryGetValue("queue", out var queueAlt) => queueAlt,
            "latency" when sparkline.Series.TryGetValue("latencyMinutes", out var latencySlice) => latencySlice,
            "latencyMinutes" when sparkline.Series.TryGetValue("latency", out var latencyAlt) => latencyAlt,
            "values" when sparkline.Series.TryGetValue("output", out var outputSlice) => outputSlice,
            "output" when sparkline.Series.TryGetValue("values", out var valuesSlice) => valuesSlice,
            _ => null
        };
    }

    private static SparklineSeriesSlice? ResolveFallbackSlice(NodeSparklineData sparkline, string primaryKey)
    {
        return primaryKey switch
        {
            "values" => CreateSlice(sparkline.Values, sparkline.StartIndex),
            "utilization" => CreateSlice(sparkline.Utilization, sparkline.StartIndex),
            "errorRate" => CreateSlice(sparkline.ErrorRate, sparkline.StartIndex),
            "queue" or "queueDepth" => CreateSlice(sparkline.QueueDepth, sparkline.StartIndex),
            _ => null
        };
    }

    private static bool AllowsFallback(string key)
    {
        return key switch
        {
            "values" => true,
            "utilization" => true,
            "errorRate" => true,
            "queue" => true,
            "queueDepth" => true,
            "latency" => true,
            "latencyMinutes" => true,
            "arrivals" => true,
            "served" => true,
            _ => false
        };
    }

    private static SparklineSeriesSlice? CreateSlice(IReadOnlyList<double?> values, int startIndex)
    {
        if (values is null || values.Count == 0)
        {
            return null;
        }

        return new SparklineSeriesSlice(values, startIndex);
    }

    private NodeSparklineData? BuildPmfSparkline(TopologyNode? node, NodeSparklineData? inspectorSparkline)
    {
        if (inspectorSparkline is not null && inspectorSparkline.Series.TryGetValue("probability", out var probabilitySlice))
        {
            if (probabilitySlice.Values.Count == 0)
            {
                return null;
            }

            var array = probabilitySlice.Values as double?[] ?? probabilitySlice.Values.ToArray();
            return NodeSparklineData.Create(
                array,
                Array.Empty<double?>(),
                Array.Empty<double?>(),
                Array.Empty<double?>(),
                probabilitySlice.StartIndex,
                explicitMin: 0d,
                explicitMax: 1d);
        }

        if (node is null)
        {
            return null;
        }

        var distribution = node.Semantics?.Distribution;
        if (distribution is null || distribution.Values.Count == 0 || distribution.Probabilities.Count == 0)
        {
            return null;
        }

        var length = Math.Min(distribution.Values.Count, distribution.Probabilities.Count);
        if (length == 0)
        {
            return null;
        }

        var series = new double?[length];
        var hasValue = false;
        for (var i = 0; i < length; i++)
        {
            var probability = distribution.Probabilities[i];
            if (!double.IsFinite(probability) || probability < 0)
            {
                series[i] = 0d;
            }
            else
            {
                series[i] = probability;
                if (probability > 0)
                {
                    hasValue = true;
                }
            }
        }

        if (!hasValue)
        {
            return null;
        }

        return NodeSparklineData.Create(
            series,
            Array.Empty<double?>(),
            Array.Empty<double?>(),
            Array.Empty<double?>(),
            inspectorSparkline?.StartIndex ?? 0,
            explicitMin: 0d,
            explicitMax: 1d,
            additionalSeries: new Dictionary<string, SparklineSeriesSlice>(StringComparer.OrdinalIgnoreCase)
            {
                ["distribution"] = new SparklineSeriesSlice(series, inspectorSparkline?.StartIndex ?? 0)
            });
    }

