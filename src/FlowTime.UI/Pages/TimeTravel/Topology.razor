    {
        inspectorMetricsExpanded = !inspectorMetricsExpanded;
    }

    private static double?[]? SelectPrimarySeries(IReadOnlyDictionary<string, double?[]> series)
    {
        if (series is null || series.Count == 0)
        {
            return null;
        }

        static double?[]? Resolve(IReadOnlyDictionary<string, double?[]> dict, string key)
            => dict.TryGetValue(key, out var value) && value is { Length: > 0 } ? value : null;

        var preferredKeys = new[]
        {
            "values",
            "demand",
            "arrivals",
            "served",
            "capacity",
            "output",
            "utilization"
        };

        foreach (var key in preferredKeys)
        {
            var candidate = Resolve(series, key);
            if (candidate is not null)
            {
                return candidate;
            }
        }

        return series.Values.FirstOrDefault(value => value is { Length: > 0 });
    }

    private static string NormalizeNodeCategory(string? category)
    {
        if (string.IsNullOrWhiteSpace(category))
        {
            return string.Empty;
        }

        return category.Trim().ToLowerInvariant() switch
        {
            "const" => "constant",
            "expr" => "expression",
            _ => category.Trim().ToLowerInvariant()
        };
    }

    private static string NormalizeAnalyticalIdentity(string? identity)
    {
        if (string.IsNullOrWhiteSpace(identity))
        {
            return string.Empty;
        }

        return identity.Trim().ToLowerInvariant() switch
        {
            "const" => "constant",
            "expr" => "expression",
            _ => identity.Trim().ToLowerInvariant()
        };
    }

    private static string CanonicalizeNodeKind(string? kind)
    {
        return NormalizeAnalyticalIdentity(kind) switch
        {
            "servicewithbuffer" => "serviceWithBuffer",
            var normalized => normalized
        };
    }

    private static string ResolveNodeCategory(
        TopologyNode? topoNode,
        TimeTravelNodeSeriesDto? seriesNode = null,
        NodeBinMetrics? metrics = null)
    {
        var direct = NormalizeNodeCategory(topoNode?.Category);
        if (!string.IsNullOrWhiteSpace(direct))
        {
            return direct;
        }

        direct = NormalizeNodeCategory(seriesNode?.Category);
        if (!string.IsNullOrWhiteSpace(direct))
        {
            return direct;
        }

        direct = NormalizeNodeCategory(metrics?.NodeCategory);
        if (!string.IsNullOrWhiteSpace(direct))
        {
            return direct;
        }

        return string.Empty;
    }

    private static string ResolveAnalyticalIdentity(
        TopologyNode? topoNode,
        TimeTravelNodeSeriesDto? seriesNode = null,
        NodeBinMetrics? metrics = null)
    {
        var direct = NormalizeAnalyticalIdentity(topoNode?.Analytical?.Identity);
        if (!string.IsNullOrWhiteSpace(direct))
        {
            return CanonicalizeNodeKind(direct);
        }

        direct = NormalizeAnalyticalIdentity(seriesNode?.Analytical?.Identity);
        if (!string.IsNullOrWhiteSpace(direct))
        {
            return CanonicalizeNodeKind(direct);
        }

        direct = NormalizeAnalyticalIdentity(metrics?.AnalyticalIdentity);
        if (!string.IsNullOrWhiteSpace(direct))
        {
            return CanonicalizeNodeKind(direct);
        }

        return string.Empty;
    }

    private static bool ResolveHasQueueSemantics(
        TopologyNode? topoNode,
        TimeTravelNodeSeriesDto? seriesNode = null,
        NodeBinMetrics? metrics = null)
    {
        var topoAnalytical = topoNode?.Analytical;
        if (topoAnalytical is not null && HasAuthoritativeAnalyticalFacts(topoAnalytical.Identity, topoAnalytical.HasQueueSemantics, topoAnalytical.HasServiceSemantics))
        {
            return topoAnalytical.HasQueueSemantics;
        }

        var seriesAnalytical = seriesNode?.Analytical;
        if (seriesAnalytical is not null && HasAuthoritativeAnalyticalFacts(seriesAnalytical.Identity, seriesAnalytical.HasQueueSemantics, seriesAnalytical.HasServiceSemantics))
        {
            return seriesAnalytical.HasQueueSemantics;
        }

        if (metrics is not null && HasAuthoritativeAnalyticalFacts(metrics.AnalyticalIdentity, metrics.HasQueueSemantics, metrics.HasServiceSemantics))
        {
            return metrics.HasQueueSemantics;
        }

        return false;
    }

    private static bool ResolveHasServiceSemantics(
        TopologyNode? topoNode,
        TimeTravelNodeSeriesDto? seriesNode = null,
        NodeBinMetrics? metrics = null)
    {
        var topoAnalytical = topoNode?.Analytical;
        if (topoAnalytical is not null && HasAuthoritativeAnalyticalFacts(topoAnalytical.Identity, topoAnalytical.HasQueueSemantics, topoAnalytical.HasServiceSemantics))
        {
            return topoAnalytical.HasServiceSemantics;
        }

        var seriesAnalytical = seriesNode?.Analytical;
        if (seriesAnalytical is not null && HasAuthoritativeAnalyticalFacts(seriesAnalytical.Identity, seriesAnalytical.HasQueueSemantics, seriesAnalytical.HasServiceSemantics))
        {
            return seriesAnalytical.HasServiceSemantics;
        }

        if (metrics is not null && HasAuthoritativeAnalyticalFacts(metrics.AnalyticalIdentity, metrics.HasQueueSemantics, metrics.HasServiceSemantics))
        {
            return metrics.HasServiceSemantics;
        }

        return false;
    }

    private static string ResolveNodeDisplayKind(
        TopologyNode? topoNode,
        TimeTravelNodeSeriesDto? seriesNode = null,
        NodeBinMetrics? metrics = null)
    {
        var identity = ResolveAnalyticalIdentity(topoNode, seriesNode, metrics);
        if (!string.IsNullOrWhiteSpace(identity))
        {
            return CanonicalizeNodeKind(identity);
        }

        var category = ResolveNodeCategory(topoNode, seriesNode, metrics);
        if (!string.IsNullOrWhiteSpace(category))
        {
            return CanonicalizeNodeKind(category);
        }

        return string.Empty;
    }

    private static bool HasAuthoritativeAnalyticalFacts(string? identity, bool hasQueueSemantics, bool hasServiceSemantics)
    {
        return !string.IsNullOrWhiteSpace(identity) || hasQueueSemantics || hasServiceSemantics;
    }

    private static string ResolveProvenanceKind(
        TopologyNode? topoNode,
        TimeTravelNodeSeriesDto? seriesNode = null,
        NodeBinMetrics? metrics = null)
        => ResolveNodeDisplayKind(topoNode, seriesNode, metrics);

    private static bool IsExpressionIdentity(string? identity) =>
        string.Equals(NormalizeAnalyticalIdentity(identity), "expression", StringComparison.Ordinal);

    private static bool IsConstantIdentity(string? identity) =>
        string.Equals(NormalizeAnalyticalIdentity(identity), "constant", StringComparison.Ordinal);

    private static bool IsPmfIdentity(string? identity) =>
        string.Equals(NormalizeAnalyticalIdentity(identity), "pmf", StringComparison.Ordinal);

    private static bool IsServiceWithBufferIdentity(string? identity) =>
        string.Equals(NormalizeAnalyticalIdentity(identity), "servicewithbuffer", StringComparison.Ordinal);

    private static bool IsExpressionCategory(string? category) =>
        string.Equals(NormalizeNodeCategory(category), "expression", StringComparison.Ordinal);

    private static bool IsConstantCategory(string? category) =>
        string.Equals(NormalizeNodeCategory(category), "constant", StringComparison.Ordinal);

    private static bool IsComputedCategory(string? category) =>
        IsExpressionCategory(category) || IsConstantCategory(category);

    private static bool IsQueueCategory(string? category)
    {
        var normalized = NormalizeNodeCategory(category);
        return normalized is "queue" or "dlq";
    }

    private static bool IsRouterCategory(string? category) =>
        string.Equals(NormalizeNodeCategory(category), "router", StringComparison.Ordinal);

    private static bool IsDependencyCategory(string? category) =>
        string.Equals(NormalizeNodeCategory(category), "dependency", StringComparison.Ordinal);

    private static bool IsSinkCategory(string? category) =>
        string.Equals(NormalizeNodeCategory(category), "sink", StringComparison.Ordinal);

    private static bool IsExpressionNode(string? category, string? identity) =>
        IsExpressionCategory(category) || IsExpressionIdentity(identity);

    private static bool IsSinkRole(string? role) =>
        !string.IsNullOrWhiteSpace(role) &&
        string.Equals(role.Trim(), "sink", StringComparison.OrdinalIgnoreCase);

    private static string? ResolveNodeRoleLabel(TopologyNode? node, TimeTravelNodeSeriesDto? seriesNode = null)
    {
        if (node is null && seriesNode is null)
        {
            return null;
        }

        return IsSinkRole(node?.NodeRole) || IsSinkCategory(ResolveNodeCategory(node, seriesNode)) ? "Terminal" : null;
    }

    private static string FormatNodeKindLabel(string? kind)
    {
        if (string.IsNullOrWhiteSpace(kind))
        {
            return "Unknown";
        }

        return kind.ToLowerInvariant() switch
        {
            "expr" or "expression" => "Expression",
            "const" or "constant" => "Const",
            "pmf" => "PMF",
            "servicewithbuffer" => "Service With Buffer",
            "dlq" => "DLQ",
            _ => CultureInfo.InvariantCulture.TextInfo.ToTitleCase(kind)
        };
    }

    private TopologyNode? FindTopologyNode(string nodeId)
    {
        if (topologyGraph is null || string.IsNullOrWhiteSpace(nodeId))
        {
            return null;
        }

        return topologyGraph.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
    }

    private string? GetNodeKind(string nodeId)
    {
        var topoNode = FindTopologyNode(nodeId);
        var seriesNode = windowData?.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        return ResolveNodeDisplayKind(topoNode, seriesNode);
    }

    private string ResolveSuccessRateLabel(string? nodeId)
    {
        if (string.IsNullOrWhiteSpace(nodeId))
        {
            return "Success rate";
        }

        if (HasClassSelection)
        {
            return "Success rate";
        }

        var node = windowData?.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
        var topoNode = FindTopologyNode(nodeId);
        var isSink = IsSinkCategory(ResolveNodeCategory(topoNode, node)) || IsSinkRole(topoNode?.NodeRole);
        if (isSink && node?.DispatchSchedule is not null)
        {
            return "Schedule SLA";
        }

        var completion = node?.Sla?.FirstOrDefault(series => string.Equals(series.Kind, "completion", StringComparison.OrdinalIgnoreCase));
        return completion is null ? "Success rate" : "Completion SLA";
    }

    private static string ResolveMetricLabel(TopologyNode? node, string fallback, params string[] canonicalKeys)
    {
        var alias = TryResolveAlias(node, canonicalKeys);
        return FormatSemanticLabelWithAlias(fallback, alias);
    }

    private static string FormatSemanticLabelWithAlias(string canonicalLabel, string? alias)
    {
        if (string.IsNullOrWhiteSpace(alias))
        {
            return canonicalLabel;
        }

        if (string.Equals(alias, canonicalLabel, StringComparison.OrdinalIgnoreCase))
        {
            return canonicalLabel;
        }

        return $"{canonicalLabel}: {alias}";
    }

    private static string? TryResolveAlias(TopologyNode? node, params string[] canonicalKeys)
    {
        if (node?.Semantics?.Aliases is null || node.Semantics.Aliases.Count == 0 || canonicalKeys is null || canonicalKeys.Length == 0)
        {
            return null;
        }

        foreach (var key in canonicalKeys.SelectMany(BuildAliasKeyCandidates))
        {
            if (string.IsNullOrWhiteSpace(key))
            {
                continue;
            }

            if (node.Semantics.Aliases.TryGetValue(key, out var alias) && !string.IsNullOrWhiteSpace(alias))
            {
                return alias;
            }
        }

        return null;
    }

    private static string? GetMetadataValue(IReadOnlyDictionary<string, string>? metadata, string key)
    {
        if (metadata is null)
        {
            return null;
        }

        return metadata.TryGetValue(key, out var value) ? value : null;
    }

    private static string[] BuildAliasKeyCandidates(string? field)
    {
        if (string.IsNullOrWhiteSpace(field))
        {
            return Array.Empty<string>();
        }

        var trimmed = field.Trim();
        var keys = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { trimmed };
        var lower = trimmed.ToLowerInvariant();
        keys.Add(lower);

        var noUnderscore = trimmed.Replace("_", string.Empty, StringComparison.OrdinalIgnoreCase);
        if (!string.Equals(noUnderscore, trimmed, StringComparison.Ordinal))
        {
            keys.Add(noUnderscore);
        }

        if (string.Equals(noUnderscore, "retryecho", StringComparison.OrdinalIgnoreCase))
        {
            keys.Add("retryEcho");
            keys.Add("retry");
        }

        if (string.Equals(noUnderscore, "queue", StringComparison.OrdinalIgnoreCase))
        {
            keys.Add("queueDepth");
        }

        return keys.ToArray();
    }

    private static string? ExtractNodeReference(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return value;
        }

        var trimmed = value.Trim();
        var colonIndex = trimmed.IndexOf(':');
        return colonIndex < 0 ? trimmed : trimmed[..colonIndex].Trim();
    }

    private static double? SampleSparklineAt(NodeSparklineData? sparkline, int bin)
    {
        if (sparkline is null)
        {
            return null;
        }

        var index = bin - sparkline.StartIndex;
        if (index < 0 || index >= sparkline.Values.Count)
        {
            return null;
        }

        var value = sparkline.Values[index];
        if (!value.HasValue)
        {
            return null;
        }

        var sample = value.Value;
        return double.IsNaN(sample) || double.IsInfinity(sample) ? null : sample;
    }

    private static double? ComputePmfExpectation(TopologyNodeDistribution? distribution)
    {
        if (distribution is null || distribution.Values.Count == 0 || distribution.Probabilities.Count == 0)
        {
            return null;
        }

        var length = Math.Min(distribution.Values.Count, distribution.Probabilities.Count);
        double total = 0d;
        double totalProbability = 0d;

        for (var i = 0; i < length; i++)
        {
            var value = distribution.Values[i];
            var probability = distribution.Probabilities[i];

            if (!double.IsFinite(value) || !double.IsFinite(probability) || probability < 0d)
            {
                continue;
            }

            total += value * probability;
            totalProbability += probability;
        }

        if (totalProbability <= 0d)
        {
            return null;
        }

        return total / totalProbability;
    }

    private static (double? Probability, double? Value) ComputePmfMode(TopologyNodeDistribution? distribution)
    {
        if (distribution is null || distribution.Values.Count == 0 || distribution.Probabilities.Count == 0)
        {
            return (null, null);
        }

        var length = Math.Min(distribution.Values.Count, distribution.Probabilities.Count);
        var maxProbability = double.NegativeInfinity;
        double? modeValue = null;

        for (var i = 0; i < length; i++)
        {
            var probability = distribution.Probabilities[i];
            var value = distribution.Values[i];

            if (!double.IsFinite(probability) || probability < 0)
            {
                continue;
            }

            if (probability > maxProbability)
            {
                maxProbability = probability;
                modeValue = double.IsFinite(value) ? value : null;
            }
        }

        if (!double.IsFinite(maxProbability) || maxProbability < 0)
        {
            return (null, null);
        }

        return (maxProbability, modeValue);
    }

    private string ResolveInspectorSparklineStroke(NodeSparklineData? sparkline, string? seriesKey = null)
    {
        if (sparkline is null)
        {
            return "#CBD5E1";
        }

        var sample = SampleSparklineAt(sparkline, selectedBin);
        if (!sample.HasValue)
        {
            var fallbackSample = sparkline.Values.FirstOrDefault(static v => v.HasValue);
            if (fallbackSample.HasValue)
            {
                sample = fallbackSample;
            }
            else
            {
                return "#CBD5E1";
            }
        }

        var overlay = overlaySettings ?? TopologyOverlaySettings.Default;
        var thresholds = ColorScale.ColorThresholds.FromOverlay(overlay);
        var requestedBasis = ResolveInspectorSeriesBasis(seriesKey);
        if (requestedBasis.HasValue)
        {
            var requestedMetrics = BuildMetricsForBasis(sample.Value, requestedBasis.Value);
            var requestedColor = ColorScale.GetFill(requestedMetrics, requestedBasis.Value, thresholds);
            if (!string.IsNullOrWhiteSpace(requestedColor))
            {
                return requestedColor;
            }
        }

        var basis = overlay.ColorBasis;
        var metrics = BuildMetricsForBasis(sample.Value, basis);
        var color = ColorScale.GetFill(metrics, basis, thresholds);
        return string.IsNullOrWhiteSpace(color) ? "#CBD5E1" : color;
    }

    private static TopologyColorBasis? ResolveInspectorSeriesBasis(string? seriesKey)
    {
        if (string.IsNullOrWhiteSpace(seriesKey))
        {
            return null;
        }

        var normalized = seriesKey.Trim().ToLowerInvariant();
        if (normalized.StartsWith("constraint:", StringComparison.OrdinalIgnoreCase))
        {
            var parts = normalized.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (parts.Length >= 3)
            {
                normalized = parts[^1];
            }
        }

        return normalized switch
        {
            "successrate" => TopologyColorBasis.Sla,
            "arrivals" => TopologyColorBasis.Arrivals,
            "utilization" => TopologyColorBasis.Utilization,
            "errorrate" or "errors" => TopologyColorBasis.Errors,
            "queue" or "queuedepth" => TopologyColorBasis.Queue,
            "shortfall" => TopologyColorBasis.Queue,
            "servicetimems" or "servicetime" => TopologyColorBasis.ServiceTime,
            "flowlatencyms" or "flowlatency" => TopologyColorBasis.FlowLatency,
            _ => null
        };
    }

    private static NodeBinMetrics BuildMetricsForBasis(double sample, TopologyColorBasis basis)
    {
        return basis switch
        {
            TopologyColorBasis.Utilization => new NodeBinMetrics(null, sample, null, null, null, null),
            TopologyColorBasis.Errors => new NodeBinMetrics(null, null, sample, null, null, null),
            TopologyColorBasis.Queue => new NodeBinMetrics(null, null, null, sample, null, null),
            TopologyColorBasis.ServiceTime => new NodeBinMetrics(null, null, null, null, null, null, ServiceTimeMs: sample),
            TopologyColorBasis.FlowLatency => new NodeBinMetrics(null, null, null, null, null, null, FlowLatencyMs: sample),
            TopologyColorBasis.Arrivals => new NodeBinMetrics(null, null, null, null, null, null, CustomValue: sample),
            _ => new NodeBinMetrics(sample, null, null, null, null, null)
        };
    }

