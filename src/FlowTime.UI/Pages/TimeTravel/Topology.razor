    private static string? ResolveEdgeQualityLabel(string? edgeQuality)
    {
        if (string.IsNullOrWhiteSpace(edgeQuality))
        {
            return null;
        }

        var normalized = edgeQuality.Trim().ToLowerInvariant();
        return normalized switch
        {
            "exact" => "Exact",
            "approx" => "Approx",
            "partialclass" => "Partial class",
            "missing" => "Missing",
            _ => edgeQuality.Trim()
        };
    }

    private static string BuildProvenanceTooltip(MetricProvenanceEvaluation provenance)
    {
        var entries = BuildProvenanceTooltipEntries(provenance);
        return string.Join("\n", entries.Select(entry => $"{entry.Label}: {entry.Value}"));
    }

    private sealed record ProvenanceTooltipEntry(string Label, string Value);

    private static IReadOnlyList<ProvenanceTooltipEntry> BuildProvenanceTooltipEntries(
        MetricProvenanceEvaluation provenance,
        string? alias = null,
        bool includeAlias = false)
    {
        var formula = provenance.SelectedFormula?.Formula ?? "unavailable";
        var inputs = provenance.SelectedFormula?.Inputs ?? Array.Empty<string>();
        var gatingRules = provenance.Definition.GatingRules;
        var missing = provenance.MissingInputs;
        var aggregation = provenance.SeriesSemantics?.Aggregation;

        var entries = new List<ProvenanceTooltipEntry>
        {
            new("Meaning", string.IsNullOrWhiteSpace(provenance.Definition.Meaning) ? "unavailable" : provenance.Definition.Meaning),
            new("Formula", formula),
            new("Inputs", inputs.Count > 0 ? string.Join(", ", inputs) : "none"),
            new("Units", provenance.Definition.Unit)
        };

        var insertIndex = 1;
        if (includeAlias && !string.IsNullOrWhiteSpace(alias))
        {
            entries.Insert(insertIndex++, new ProvenanceTooltipEntry("Alias", alias.Trim()));
        }
        if (!string.IsNullOrWhiteSpace(aggregation))
        {
            entries.Insert(insertIndex++, new ProvenanceTooltipEntry("Aggregation", aggregation));
        }

        if (gatingRules.Count > 0)
        {
            entries.Add(new ProvenanceTooltipEntry("Gating", string.Join(" ", gatingRules)));
        }

        if (missing.Count > 0)
        {
            entries.Add(new ProvenanceTooltipEntry("Missing", string.Join(", ", missing)));
        }

        return entries;
    }

    private static string FormatNumber(double? value)
    {
        if (!value.HasValue)
        {
            return "—";
        }

        return value.Value.ToString("0.0", CultureInfo.InvariantCulture);
    }

    private static string FormatDispatchSummary(GraphDispatchScheduleModel schedule)
    {
        var period = Math.Max(1, schedule.PeriodBins);
        var phase = Math.Max(0, schedule.PhaseOffset);
        var cadence = period == 1 ? "Every bin" : $"Every {period} bins";
        return $"{cadence} (phase {phase})";
    }

    private static string FormatDispatchCapacity(GraphDispatchScheduleModel schedule)
    {
        return string.IsNullOrWhiteSpace(schedule.CapacitySeries)
            ? "Unbounded"
            : schedule.CapacitySeries!;
    }

    private static GraphDispatchScheduleModel? ToGraphDispatchSchedule(TimeTravelDispatchScheduleDto? schedule)
    {
        if (schedule is null)
        {
            return null;
        }

        return new GraphDispatchScheduleModel(
            schedule.Kind,
            schedule.PeriodBins,
            schedule.PhaseOffset,
            schedule.CapacitySeries);
    }

    private bool TryResolveScheduleSummary(string nodeId, out string summary, out string capacity)
    {
        summary = "-";
        capacity = "-";

        if (string.IsNullOrWhiteSpace(nodeId))
        {
            return false;
        }

        var topoNode = FindTopologyNode(nodeId);
        var schedule = topoNode?.DispatchSchedule;
        if (schedule is null)
        {
            var seriesNode = windowData?.Nodes.FirstOrDefault(n => string.Equals(n.Id, nodeId, StringComparison.OrdinalIgnoreCase));
            schedule = ToGraphDispatchSchedule(seriesNode?.DispatchSchedule);
        }

        if (schedule is not null)
        {
            summary = FormatDispatchSummary(schedule);
            capacity = FormatDispatchCapacity(schedule);
            return true;
        }

        var entry = dispatchScheduleEntries.FirstOrDefault(e => string.Equals(e.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));
        if (entry is null)
        {
            return false;
        }

        summary = entry.Summary;
        capacity = entry.CapacityLabel;
        return true;
    }

    private static string FormatQueueLatencyStatusLabel(QueueLatencyStatus status)
    {
        if (status is null)
        {
            return "Latency paused";
        }

        var code = status.Code?.Trim().ToLowerInvariant();
        if (code == "queue_latency_gate_closed")
        {
            return "Paused (gate closed)";
        }

        if (code == "queue_latency_unreported")
        {
            return "Latency unavailable";
        }

        if (!string.IsNullOrWhiteSpace(status.Message))
        {
            return status.Message.Trim();
        }

        return string.IsNullOrWhiteSpace(status.Code)
            ? "Latency paused"
            : CultureInfo.CurrentCulture.TextInfo.ToTitleCase(status.Code.Replace('_', ' '));
    }

    private static string FormatClassChipMetrics(ClassContribution contribution)
    {
        var parts = new List<string>();
        if (contribution.Arrivals.HasValue)
        {
            parts.Add($"Arr {FormatNumber(contribution.Arrivals)}");
        }
        if (contribution.Served.HasValue)
        {
            parts.Add($"Srv {FormatNumber(contribution.Served)}");
        }
        if (contribution.Errors.HasValue)
        {
            parts.Add($"Err {FormatNumber(contribution.Errors)}");
        }
        if (contribution.Queue.HasValue)
        {
            parts.Add($"Q {FormatNumber(contribution.Queue)}");
        }

        return parts.Count > 0 ? string.Join(" • ", parts) : "No metrics";
    }

    private static string FormatPercentValue(double value)
    {
        return (value * 100d).ToString("0.#", CultureInfo.InvariantCulture) + "%";
    }

    private static string FormatMs(double value)
    {
        return value.ToString("0.#", CultureInfo.InvariantCulture) + " ms";
    }

    private static string FormatDurationMs(double? value)
    {
        if (!value.HasValue)
        {
            return "—";
        }

        var sample = value.Value;
        if (sample >= 10_000)
        {
            var minutes = sample / 1000d / 60d;
            return minutes.ToString("0.0", CultureInfo.InvariantCulture) + " min";
        }

        var format = sample >= 1000 ? "0" : "0.0";
        return sample.ToString(format, CultureInfo.InvariantCulture) + " ms";
    }

    private static string FormatBinValue(double? value, InspectorValueFormat format = InspectorValueFormat.Number, string? unit = null)
    {
        var text = format switch
        {
            InspectorValueFormat.Percent => FormatPercent(value),
            InspectorValueFormat.DurationMs => FormatDurationMs(value),
            _ => FormatNumber(value)
        };

        if (string.Equals(text, "—", StringComparison.Ordinal))
        {
            return text;
        }

        if (format == InspectorValueFormat.DurationMs)
        {
            return text;
        }

        return string.IsNullOrWhiteSpace(unit) ? text : $"{text} {unit}";
    }

    private void BuildNodeSparklines(int? anchorBin = null)
    {
        var context = CaptureBinDataContext();
        var targetAnchor = anchorBin ?? selectedBin;
        var result = ComputeNodeSparklinesSnapshot(context, targetAnchor, CancellationToken.None);
        ApplyNodeSparklinesResult(result);
    }

    private static NodeSparklineComputationResult ComputeNodeSparklinesSnapshot(
        BinDataComputationContext context,
        int anchorBin,
        CancellationToken token)
    {
        var missing = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var missingExpressionNodes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (context.WindowData is null)
        {
            return new NodeSparklineComputationResult(
                new Dictionary<string, NodeSparklineData>(StringComparer.OrdinalIgnoreCase),
                missing,
                missingExpressionNodes);
        }

        var result = new Dictionary<string, NodeSparklineData>(StringComparer.OrdinalIgnoreCase);
        var windowStart = context.WindowData.Window.StartBin;
        var binCount = Math.Max(0, context.WindowData.Window.BinCount);
        var windowEnd = binCount > 0 ? windowStart + binCount - 1 : windowStart;
        var clampedSelection = Math.Clamp(anchorBin, windowStart, windowEnd);
        var selectionLocalIndex = Math.Max(0, clampedSelection - windowStart);

        foreach (var node in context.WindowData.Nodes)
        {
            token.ThrowIfCancellationRequested();

            var series = node.Series ?? new Dictionary<string, double?[]>(StringComparer.OrdinalIgnoreCase);
            var topoNode = context.FindNode(node.Id);
            var nodeCategory = ResolveNodeCategory(topoNode, node);
            var nodeIdentity = ResolveAnalyticalIdentity(topoNode, node);
            var successSeries = BuildSuccessRateSeriesSnapshot(node, context.HasClassSelection, context.SelectedClasses);
            var primarySeries = SelectPrimarySeries(series) ?? successSeries;
            var synthesizedValues = false;

            if (primarySeries is null && IsPmfIdentity(nodeIdentity))
            {
                var expectation = ComputePmfExpectation(topoNode?.Semantics?.Distribution);
                if (expectation.HasValue)
                {
                    var syntheticLength = binCount > 0 ? binCount : context.sparklinePointLimit;
                    syntheticLength = Math.Max(1, syntheticLength);
                    var syntheticSeries = new double?[syntheticLength];
                    for (var i = 0; i < syntheticLength; i++)
                    {
                        syntheticSeries[i] = expectation.Value;
                    }

                    primarySeries = syntheticSeries;
                    synthesizedValues = true;
                }
            }

            if (primarySeries is null || primarySeries.Length == 0)
            {
                if (IsExpressionNode(nodeCategory, nodeIdentity))
                {
                    missing.Add(node.Id);
                    missingExpressionNodes.Add(node.Id);
                }

                continue;
            }

            var anchor = Math.Clamp(selectionLocalIndex, 0, (primarySeries?.Length ?? 1) - 1);
            var trimmedPrimary = TrimSeriesAt(primarySeries, context.sparklinePointLimit, anchor);
            if (trimmedPrimary.Count == 0)
            {
                if (IsExpressionNode(nodeCategory, nodeIdentity))
                {
                    missing.Add(node.Id);
                    missingExpressionNodes.Add(node.Id);
                }

                continue;
            }

            var primaryStartIndex = windowStart + (anchor + 1 - trimmedPrimary.Count);
            var utilizationSeries = TryGetSeriesSnapshot(node, "utilization", context.HasClassSelection, context.SelectedClasses) ??
                                    BuildUtilizationSeriesSnapshot(node, context.HasClassSelection, context.SelectedClasses);
            var trimmedUtilization = TrimSeriesAt(utilizationSeries, context.sparklinePointLimit, anchor, trimmedPrimary.Count);
            var trimmedErrorRate = TrimSeriesAt(
                BuildErrorRateSeriesSnapshot(node, context.HasClassSelection, context.SelectedClasses),
                context.sparklinePointLimit,
                anchor,
                trimmedPrimary.Count);
            var trimmedQueue = TrimSeriesAt(
                TryGetSeriesSnapshot(node, "queue", context.HasClassSelection, context.SelectedClasses),
                context.sparklinePointLimit,
                anchor,
                trimmedPrimary.Count);
            var serviceTimeSeries = TryGetSeriesSnapshot(node, "serviceTimeMs", context.HasClassSelection, context.SelectedClasses) ??
                                    BuildServiceTimeSeriesSnapshot(node, context.HasClassSelection, context.SelectedClasses);
            var trimmedServiceTime = TrimSeriesAt(serviceTimeSeries, context.sparklinePointLimit, anchor, trimmedPrimary.Count);

            var additional = new Dictionary<string, SparklineSeriesSlice>(StringComparer.OrdinalIgnoreCase);
            foreach (var pair in series)
            {
                var trimmed = TrimSeriesAt(pair.Value, context.sparklinePointLimit, anchor, trimmedPrimary.Count);
                var startIndex = pair.Value is null || pair.Value.Length == 0
                    ? primaryStartIndex
                    : windowStart + (anchor + 1 - trimmed.Count);
                additional[pair.Key] = new SparklineSeriesSlice(trimmed, startIndex);
            }

            if (successSeries is not null)
            {
                var trimmedSuccess = TrimSeriesAt(successSeries, context.sparklinePointLimit, anchor, trimmedPrimary.Count);
                if (trimmedSuccess.Count > 0)
                {
                    var successStartIndex = windowStart + (anchor + 1 - trimmedSuccess.Count);
                    additional["successRate"] = new SparklineSeriesSlice(trimmedSuccess, successStartIndex);
                }
            }

            if (trimmedUtilization.Count > 0)
            {
                additional["utilization"] = new SparklineSeriesSlice(trimmedUtilization, primaryStartIndex);
            }

            if (trimmedErrorRate.Count > 0)
            {
                additional["errorRate"] = new SparklineSeriesSlice(trimmedErrorRate, primaryStartIndex);
            }

            if (trimmedQueue.Count > 0)
            {
                additional["queue"] = new SparklineSeriesSlice(trimmedQueue, primaryStartIndex);
            }

            if (trimmedServiceTime.Count > 0)
            {
                additional["serviceTimeMs"] = new SparklineSeriesSlice(trimmedServiceTime, primaryStartIndex);
            }

            if (synthesizedValues)
            {
                additional["values"] = new SparklineSeriesSlice(trimmedPrimary, primaryStartIndex);
            }

            var sparkline = NodeSparklineData.Create(
                trimmedPrimary,
                trimmedUtilization,
                trimmedErrorRate,
                trimmedQueue,
                primaryStartIndex,
                successSeries is not null ? 0d : null,
                successSeries is not null ? 1d : null,
                additional);

            result[node.Id] = sparkline;
        }

        if (context.TopologyGraph is not null)
        {
            foreach (var topoNode in context.TopologyGraph.Nodes)
            {
                token.ThrowIfCancellationRequested();

                if (string.IsNullOrWhiteSpace(topoNode?.Id) || result.ContainsKey(topoNode.Id))
                {
                    continue;
                }

                var distributionSlices = CreateDistributionSlices(topoNode.Id, topoNode.Semantics?.Distribution, anchorBin);

                var inlineValues = topoNode.Semantics?.InlineValues;
                if (inlineValues is not null && inlineValues.Count > 0)
                {
                    var nullableSeries = inlineValues.Select(value => (double?)value).ToArray();
                    var anchor = Math.Clamp(anchorBin, 0, nullableSeries.Length - 1);
                    var trimmedInline = TrimSeriesAt(nullableSeries, context.sparklinePointLimit, anchor);
                    if (trimmedInline.Count == 0)
                    {
                        continue;
                    }

                    var startIndex = anchor + 1 - trimmedInline.Count;
                    var additional = new Dictionary<string, SparklineSeriesSlice>(StringComparer.OrdinalIgnoreCase);
                    if (distributionSlices is not null)
                    {
                        foreach (var pair in distributionSlices)
                        {
                            additional[pair.Key] = pair.Value;
                        }
                    }

                    var inlineSlice = new SparklineSeriesSlice(trimmedInline, startIndex);
                    additional["values"] = inlineSlice;
                    additional[topoNode.Id] = inlineSlice;
                    additional[$"series:{topoNode.Id}"] = inlineSlice;

                    var sparkline = NodeSparklineData.Create(
                        trimmedInline,
                        Array.Empty<double?>(),
                        Array.Empty<double?>(),
                        Array.Empty<double?>(),
                        startIndex,
                        explicitMin: null,
                        explicitMax: null,
                        additionalSeries: additional);

                    result[topoNode.Id] = sparkline;
                    continue;
                }

                if (distributionSlices is not null &&
                    distributionSlices.TryGetValue("probability", out var probabilitySlice) &&
                    probabilitySlice.Values.Count > 0)
                {
                    var probabilityArray = probabilitySlice.Values as double?[] ?? probabilitySlice.Values.ToArray();
                    var sparkline = NodeSparklineData.Create(
                        probabilityArray,
                        Array.Empty<double?>(),
                        Array.Empty<double?>(),
                        Array.Empty<double?>(),
                        probabilitySlice.StartIndex,
                        explicitMin: 0d,
                        explicitMax: 1d,
                        additionalSeries: distributionSlices);

                    result[topoNode.Id] = sparkline;
                    continue;
                }

                var topoCategory = ResolveNodeCategory(topoNode);
                var topoIdentity = ResolveAnalyticalIdentity(topoNode);
                if (IsExpressionNode(topoCategory, topoIdentity))
                {
                    missing.Add(topoNode.Id);
                    missingExpressionNodes.Add(topoNode.Id);
                }
            }
        }

        return new NodeSparklineComputationResult(result, missing, missingExpressionNodes);
    }

private static Dictionary<string, SparklineSeriesSlice>? CreateDistributionSlices(string nodeId, TopologyNodeDistribution? distribution, int anchorBin)
    {
        if (distribution is null ||
            distribution.Values is not { Count: > 0 } ||
            distribution.Probabilities is not { Count: > 0 })
        {
            return null;
        }

        var length = Math.Min(distribution.Values.Count, distribution.Probabilities.Count);
        if (length == 0)
        {
            return null;
        }

        var probabilities = new double?[length];
        var supportValues = new double?[length];
        var hasProbability = false;
        for (var i = 0; i < length; i++)
        {
            var probability = distribution.Probabilities[i];
            var support = distribution.Values[i];

            if (!double.IsFinite(probability) || probability < 0)
            {
                probabilities[i] = 0d;
            }
            else
            {
                probabilities[i] = probability;
                if (probability > 0)
                {
                    hasProbability = true;
                }
            }

            supportValues[i] = double.IsFinite(support) ? support : null;
        }

        if (!hasProbability)
        {
            return null;
        }

        var anchor = Math.Clamp(anchorBin, 0, probabilities.Length - 1);
        var trimmedProbabilities = TrimSeriesAt(probabilities, sparklinePointLimit, anchor);
        if (trimmedProbabilities.Count == 0)
        {
            return null;
        }

        var trimmedValues = TrimSeriesAt(supportValues, sparklinePointLimit, anchor, trimmedProbabilities.Count);
        var probabilityArray = trimmedProbabilities as double?[] ?? trimmedProbabilities.ToArray();
        var valueArray = trimmedValues as double?[] ?? trimmedValues.ToArray();
        var probabilityStartIndex = anchor + 1 - probabilityArray.Length;

        var additional = new Dictionary<string, SparklineSeriesSlice>(StringComparer.OrdinalIgnoreCase)
        {
            ["distribution"] = new SparklineSeriesSlice(probabilityArray, probabilityStartIndex),
            ["probability"] = new SparklineSeriesSlice(probabilityArray, probabilityStartIndex),
            [nodeId] = new SparklineSeriesSlice(probabilityArray, probabilityStartIndex),
            [$"series:{nodeId}"] = new SparklineSeriesSlice(probabilityArray, probabilityStartIndex)
        };

        var expectation = ComputePmfExpectation(distribution);
        if (expectation.HasValue)
        {
            var expectationSeries = Enumerable.Repeat((double?)expectation.Value, probabilityArray.Length).ToArray();
            additional["values"] = new SparklineSeriesSlice(expectationSeries, probabilityStartIndex);
            additional["expectation"] = new SparklineSeriesSlice(expectationSeries, probabilityStartIndex);
        }

        return additional;
    }

