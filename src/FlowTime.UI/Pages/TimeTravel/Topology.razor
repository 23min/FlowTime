@page "/time-travel/topology"
@using MudBlazor
@using Microsoft.JSInterop
@using Microsoft.Extensions.Logging
@using FlowTime.UI.Components.Topology
@using FlowTime.UI.Configuration
@using FlowTime.UI.Services
@using System.Collections.Generic
@using System.Globalization
@using System.Linq
@using System.Text
@using System.Text.Json
@using System.Threading
@using Microsoft.Extensions.Options
@inject ITimeTravelDataService DataService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<Topology> Logger
@inject IOptions<DiagnosticsOptions> DiagnosticsOptionsAccessor
@inject IOptions<FlowTimeApiOptions> FlowTimeApiOptionsAccessor
@implements IDisposable

<PageTitle>Time-Travel Topology</PageTitle>

<MudStack Row="true" Class="topology-layout" AlignItems="@AlignItems.Stretch" Spacing="2">
    @if (featureBarOpen)
    {
        <MudPaper Class="topology-feature-panel" Elevation="1">
            <TopologyFeatureBar Settings="overlaySettings"
                                 SettingsChanged="OnOverlaySettingsChanged"
                                 CloseRequested="CloseFeatureBar"
                                 ExpandedSections="sectionExpansionState"
                                 SectionExpansionChanged="OnFeatureSectionExpansionChanged" />
        </MudPaper>
    }

        <MudPaper Class="topology-page" Elevation="1">
        <MudStack Spacing="3" Class="topology-content">
            @if (string.IsNullOrWhiteSpace(RunId))
            {
                <MudAlert Severity="Severity.Info">
                    Select a run from the Artifacts list to inspect its topology.
                </MudAlert>
            }
            else if (!hasLoaded && isLoading)
            {
                <MudPaper Class="pa-6 d-flex flex-column align-center justify-center" Elevation="0">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Style="width: 64px; height: 64px;" />
                    <MudText Typo="Typo.caption" Class="mt-2">Loading topology…</MudText>
                </MudPaper>
            }
            else if (!hasLoaded && !string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    <MudText Typo="Typo.body1">@errorMessage</MudText>
                </MudAlert>
            }
            else if (topologyGraph is null)
            {
                <MudAlert Severity="Severity.Warning">
                    Topology data was not available for run <strong>@RunId</strong>.
                </MudAlert>
            }
            else
            {
                <MudStack Spacing="2" Class="topology-main-stack">
                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                            <MudText Typo="Typo.body2">@errorMessage</MudText>
                        </MudAlert>
                    }
                    <MudPaper Class="pa-3 timeline-paper" Elevation="0">
                        <MudStack Spacing="1" Class="topology-header">
                            @{ var runInfo = GetRunInfo(); }
                            <MudStack Row="true" AlignItems="@AlignItems.Center" Justify="@Justify.SpaceBetween">
                                <MudText Typo="Typo.caption">@selectedTimestampLabel</MudText>
                                <MudStack Row="true" AlignItems="@AlignItems.Center" Justify="@Justify.FlexEnd" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="topology-run-id">Run @RunId</MudText>
                                    @if (!string.IsNullOrWhiteSpace(runInfo))
                                    {
                                        <MudText Typo="Typo.caption" Class="topology-run-info" Color="Color.Info">@runInfo</MudText>
                                    }
                                </MudStack>
                            </MudStack>
                            <div class="timeline-dial">
                                <div class="timeline-track @(visibleStartBin == visibleEndBin ? "is-disabled" : string.Empty)">
                                    <svg class="timeline-svg" viewBox="0 0 100 12" preserveAspectRatio="none">
                                        <rect class="timeline-track-bg" x="0" y="4" width="100" height="4" />
                                        @foreach (var minor in timelineMinorTicks)
                                        {
                                            <line class="timeline-tick-line timeline-tick-line--minor"
                                                  x1="@minor.ToString("0.###", CultureInfo.InvariantCulture)"
                                                  x2="@minor.ToString("0.###", CultureInfo.InvariantCulture)"
                                                  y1="3"
                                                  y2="9" />
                                        }
                                        @foreach (var tick in timelineTicks)
                                        {
                                            <line class="timeline-tick-line"
                                                  x1="@tick.Percent.ToString("0.###", CultureInfo.InvariantCulture)"
                                                  x2="@tick.Percent.ToString("0.###", CultureInfo.InvariantCulture)"
                                                  y1="1"
                                                  y2="11" />
                                        }
                                    </svg>
                                    @{
                                        var totalSpan = Math.Max(1, visibleEndBin - visibleStartBin);
                                        var winStart = Math.Max(visibleStartBin, selectedBin - sparklinePointLimit + 1);
                                        var winEnd = Math.Max(winStart, Math.Min(selectedBin, visibleEndBin));
                                        var xPct = Math.Clamp((winStart - visibleStartBin) * 100.0 / totalSpan, 0.0, 100.0);
                                        var rawWidth = (winEnd - winStart + 1) * 100.0 / totalSpan;
                                        var maxWidth = Math.Max(0.0, 100.0 - xPct);
                                        var wPct = Math.Clamp(rawWidth, 0.0, maxWidth);
                                    }
                                    <div class="timeline-window" style="left: @xPct.ToString("0.###", CultureInfo.InvariantCulture)%; width: @wPct.ToString("0.###", CultureInfo.InvariantCulture)%;"></div>
                                    <div class="timeline-pointer @(isDialPointerDragging ? "is-dragging" : string.Empty)"
                                         style="left: @DialPercent.ToString("0.###", CultureInfo.InvariantCulture)%; --timeline-transition-duration: @PointerTransitionDuration;"></div>
                                    <input class="timeline-range"
                                           type="range"
                                           min="@visibleStartBin"
                                           max="@visibleEndBin"
                                           step="1"
                                           value="@selectedBin"
                                           disabled="@(visibleStartBin == visibleEndBin)"
                                           @oninput="OnDialInput"
                                           @onpointerdown="StartDialDrag"
                                           @onpointerup="EndDialDrag"
                                           @onpointercancel="EndDialDrag"
                                           @onpointerleave="EndDialDrag" />
                                </div>
                                <div class="timeline-labels">
                                    @foreach (var tick in timelineTicks)
                                    {
                                        <span class="timeline-label" style="left:@tick.Percent.ToString("0.###", CultureInfo.InvariantCulture)%">@tick.Label</span>
                                    }
                                </div>
                                <div class="timeline-controls">
                                    <MudIconButton Icon="@(isPlaying ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(visibleStartBin == visibleEndBin)"
                                                   OnClick="TogglePlaybackAsync" />
                                    <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious"
                                                   Size="Size.Small"
                                                   Disabled="@(selectedBin <= visibleStartBin)"
                                                   OnClick="GoToPreviousBin" />
                                    <MudIconButton Icon="@Icons.Material.Filled.SkipNext"
                                                   Size="Size.Small"
                                                   Disabled="@(selectedBin >= visibleEndBin)"
                                                   OnClick="GoToNextBin" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Loop"
                                                   Size="Size.Small"
                                                   Color="@(loopPlayback ? Color.Primary : Color.Default)"
                                                   OnClick="ToggleLoop" />
                                    <MudChipSet T="double"
                                                SelectedValue="@playbackSpeedFactor"
                                                SelectedValueChanged="OnPlaybackSpeedChipChanged"
                                                Class="timeline-speed-set"
                                                Ripple="false">
                                        @foreach (var option in PlaybackSpeedOptions)
                                        {
                                            <MudChip T="double"
                                                     Value="@option.Factor"
                                                     Variant="Variant.Outlined"
                                                     Color="Color.Default"
                                                     Size="Size.Small"
                                                     Class="timeline-speed-chip">
                                                @option.Label
                                            </MudChip>
                                        }
                                    </MudChipSet>
                                    <MudStack Row="true" AlignItems="@AlignItems.Center" Class="timeline-focus-group">
                                        @{
                                            var anyWarnings = windowWarnings.Any(w => string.Equals(w.Severity, "warning", StringComparison.OrdinalIgnoreCase));
                                            var anyInfos = windowWarnings.Any(w => string.Equals(w.Severity, "info", StringComparison.OrdinalIgnoreCase));
                                        }
                                        @if (HasWindowWarnings)
                                        {
                                            var chipLabel = anyWarnings ? "Warning" : "Info";
                                            var chipColor = anyWarnings ? Color.Warning : Color.Info;
                                            var chipClass = anyWarnings ? "timeline-warning-chip" : "timeline-info-chip";
                                            <MudTooltip Class="timeline-warning-tooltip-root">
                                                <ChildContent>
                                                    <MudChip T="string"
                                                             Variant="Variant.Filled"
                                                             Class="@chipClass"
                                                             Color="@chipColor"
                                                             Ripple="false">
                                                        @chipLabel
                                                    </MudChip>
                                                </ChildContent>
                                                <TooltipContent>
                                                    <div class="timeline-warning-tooltip">
                                                        @foreach (var warning in windowWarnings)
                                                        {
                                                            <div class="timeline-warning-tooltip__item">
                                                                <div class="timeline-warning-tooltip__heading">
                                                                    <strong>@(warning.NodeId ?? "Run")</strong>
                                                                    <span class="timeline-warning-tooltip__code">@warning.Code (@warning.Severity)</span>
                                                                </div>
                                                                @if (!string.IsNullOrWhiteSpace(warning.Message))
                                                                {
                                                                    <span>@warning.Message</span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </TooltipContent>
                                            </MudTooltip>
                                        }
                                        <MudStack Row="true" AlignItems="@AlignItems.Center" Spacing="1" Class="timeline-focus-controls">
                                            <MudText Typo="Typo.caption" Class="timeline-focus-label">Focus</MudText>
                                            <MudChipSet T="TopologyColorBasis"
                                                        SelectedValue="@overlaySettings.ColorBasis"
                                                        SelectedValueChanged="OnFocusMetricChanged"
                                                        Class="timeline-focus-set"
                                                        Ripple="false">
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.Arrivals"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    Arrivals
                                                </MudChip>
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.Sla"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    SLA
                                                </MudChip>
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.Utilization"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    Utilization
                                                </MudChip>
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.Errors"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    Error rate
                                                </MudChip>
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.Queue"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    Queue depth
                                                </MudChip>
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.ServiceTime"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    Service time
                                                </MudChip>
                                                <MudChip T="TopologyColorBasis"
                                                         Value="TopologyColorBasis.FlowLatency"
                                                         Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         Class="timeline-focus-chip">
                                                    Flow latency
                                                </MudChip>
                                            </MudChipSet>
                                        </MudStack>
                                        <MudStack Row="true" AlignItems="@AlignItems.Center" Spacing="1" Class="timeline-operational-toggle">
                                            <MudText Typo="Typo.caption" Class="timeline-focus-label">Operational</MudText>
                                            <MudTooltip Text="Toggle operational-only view">
                                                <ChildContent>
                                                    <MudSwitch T="bool"
                                                               Size="Size.Small"
                                                               Ripple="false"
                                                               Value="@operationalViewOnly"
                                                               ValueChanged="OnOperationalViewChanged"
                                                               Disabled="@operationalTogglePending"
                                                               Color="Color.Primary" />
                                                </ChildContent>
                                            </MudTooltip>
                                        </MudStack>
                                        <MudStack Row="true" AlignItems="@AlignItems.Center" Spacing="1" Class="timeline-focusview-toggle">
                                            <MudText Typo="Typo.caption" Class="timeline-focus-label">Focus view</MudText>
                                            <MudTooltip Text="Select a node to enable focus view">
                                                <ChildContent>
                                                    <MudSwitch T="bool"
                                                               Size="Size.Small"
                                                               Ripple="false"
                                                               Value="@focusViewEnabled"
                                                               ValueChanged="OnFocusViewChanged"
                                                               Disabled="@(!CanToggleFocusView)"
                                                               Color="Color.Primary" />
                                                </ChildContent>
                                            </MudTooltip>
                                        </MudStack>
                                        <MudChipSet T="string"
                                                    Class="timeline-zoom-set"
                                                    Ripple="false">
                                            <MudTooltip Text="Reset zoom">
                                                <MudChip T="string"
                                                         Value="@("Reset")"
                                                         Variant="Variant.Outlined"
                                                         Color="Color.Default"
                                                         Size="Size.Small"
                                                         Class="timeline-zoom-chip"
                                                         OnClick="ResetZoom">
                                                    100%
                                                </MudChip>
                                            </MudTooltip>
                                            <MudTooltip Text="Fit graph to canvas">
                                                <MudChip T="string"
                                                         Value="@("Fit")"
                                                         Variant="Variant.Outlined"
                                                         Color="Color.Default"
                                                         Size="Size.Small"
                                                         Class="timeline-zoom-chip"
                                                         OnClick="FitViewport">
                                                    Fit
                                                </MudChip>
                                            </MudTooltip>
                                        </MudChipSet>
                                    </MudStack>
                                </div>
                            </div>
                        </MudStack>
                    </MudPaper>

                    <MudStack Row="true" AlignItems="AlignItems.Stretch" Spacing="2" Class="topology-stage">
                        <div class="topology-overlay-stack @(inspectorOpen ? "legend-shifted" : string.Empty)">
                            <div class="topology-legend-overlay">
                                <div class="topology-legend-list">
                                    @foreach (var entry in BuildLegendEntries())
                                    {
                                        <div class="legend-item">
                                            <span class="legend-swatch @entry.Swatch"></span>
                                            <span>@entry.Label</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            @{
                                var aggregationLabel = GetAggregationIndicatorLabel();
                                var edgeQualityLabel = ResolveEdgeQualityLabel(windowData?.Metadata.EdgeQuality);
                            }
                            @if (!string.IsNullOrWhiteSpace(aggregationLabel))
                            {
                                <div class="topology-aggregate-overlay">
                                    <span class="topology-aggregate-label">Aggregate</span>
                                    <MudChip T="string"
                                             Variant="Variant.Outlined"
                                             Color="Color.Default"
                                             Size="Size.Small"
                                             Class="topology-aggregate-chip"
                                             Ripple="false">
                                        @aggregationLabel
                                    </MudChip>
                                </div>
                            }
                            @if (ShowClassSelector)
                            {
                                <div class="topology-flow-overlay">
                                    <div class="topology-flow-header">
                                        <MudText Typo="Typo.overline" Class="topology-flow-panel-title">Flows</MudText>
                                    </div>
                                    <ClassSelector Classes="availableClasses"
                                                   ClassDisplayNames="classDisplayNames"
                                                   SelectionChanged="OnClassSelectionChanged"
                                                   ModeChanged="OnClassSelectionModeChanged"
                                                   QueryKey="classes" />
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(edgeQualityLabel))
                            {
                                <div class="topology-flow-overlay topology-edge-quality-overlay">
                                    <div class="topology-flow-header">
                                        <MudText Typo="Typo.overline" Class="topology-flow-panel-title">Edge quality</MudText>
                                    </div>
                                    <MudChip T="string"
                                             Variant="Variant.Outlined"
                                             Color="Color.Default"
                                             Size="Size.Small"
                                             Class="topology-edge-quality-chip"
                                             Ripple="false">
                                        @edgeQualityLabel
                                    </MudChip>
                                </div>
                            }
                            @if (focusViewEnabled)
                            {
                                <div class="topology-flow-overlay topology-focus-overlay">
                                    <div class="topology-flow-header">
                                        <MudText Typo="Typo.overline" Class="topology-flow-panel-title">Focus</MudText>
                                    </div>
                                    <MudStack Row="true" AlignItems="@AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.caption">Include downstream</MudText>
                                        <MudSwitch T="bool"
                                                   Size="Size.Small"
                                                   Ripple="false"
                                                   Value="@focusIncludeDownstream"
                                                   ValueChanged="OnFocusIncludeDownstreamChanged"
                                                   Color="Color.Primary" />
                                    </MudStack>
                                </div>
                            }
                            @{
                                var dispatchList = dispatchScheduleEntries
                                    .Where(e => inspectorNodeId != null && string.Equals(e.NodeId, inspectorNodeId, StringComparison.OrdinalIgnoreCase))
                                    .ToList();
                            }
                            @if (ShowDispatchPanel)
                            {
                                <div class="topology-flow-overlay topology-dispatch-overlay">
                                    <div class="topology-flow-header">
                                        <MudText Typo="Typo.overline" Class="topology-flow-panel-title">Schedules</MudText>
                                        <span class="topology-flow-counter">@(
                                            dispatchList.Count.ToString(CultureInfo.InvariantCulture))</span>
                                    </div>
                                    <MudStack Spacing="1" Class="topology-dispatch-chip-list">
                                        @foreach (var entry in dispatchList)
                                        {
                                            <MudChip T="string"
                                                     Variant="Variant.Outlined"
                                                     Color="Color.Info"
                                                     Size="Size.Small"
                                                     Class="topology-dispatch-chip"
                                                     OnClick="@(() => FocusDispatchNode(entry.NodeId))">
                                                <div class="dispatch-chip-content">
                                                    <span class="dispatch-chip-title">@entry.NodeId</span>
                                                    <span class="dispatch-chip-meta">@entry.Summary</span>
                                                    <span class="dispatch-chip-meta">@entry.CapacityLabel</span>
                                                </div>
                                            </MudChip>
                                        }
                                    </MudStack>
                                </div>
                            }
                        </div>
                        <div class="topology-canvas-region">
                            <TopologyCanvas @ref="canvasComponent"
                                            Graph="topologyGraph"
                                            NodeMetrics="activeMetrics"
                                            ConstraintBadges="constraintBadges"
                                            NodeSparklines="nodeSparklines"
                                            EdgeSeries="windowData?.Edges"
                                            EdgeSeriesStartIndex="@(windowData?.Window.StartBin ?? 0)"
                                            SelectedClasses="selectedClasses"
                                            HasClassSelection="@(selectedClasses.Count > 0)"
                                            EdgeQuality="@windowData?.Metadata.EdgeQuality"
                                            NodeWarnings="nodeWarningsForCanvas"
                                            EdgeWarnings="edgeWarningsForCanvas"
                                            OverlaySettings="overlaySettings"
                                            ActiveBin="renderBin"
                                            Title="@GetTemplateTitle()"
                                            DimmedNodes="classFilteredNodes"
                                            SettingsRequested="OpenFeatureBar"
                                            ZoomPercentChanged="HandleCanvasZoomChanged"
                                            ViewportChanged="OnCanvasViewportChanged"
                                            InspectorVisible="inspectorOpen"
                                            NodeFocused="OnNodeFocused"
                                            NodeSelected="OnNodeSelected"
                                            EdgeHovered="OnCanvasEdgeHovered"
                                            DumpBinRequested="DumpInspectorBinAsync"
                                            RequestedViewport="pendingViewportSnapshot"
                                            ViewportRequestConsumed="OnRequestedViewportConsumed"
                                            DiagnosticsOverlayEnabled="@diagnosticsOverlayEnabled"
                                            DiagnosticsUploadUrl="@diagnosticsUploadUrl"
                                            DiagnosticsUploadIntervalMs="@diagnosticsUploadIntervalMs"
                                            DiagnosticsDisableHoverCache="@diagnosticsDisableHoverCache"
                                            RunId="@RunId"
                                            OperationalViewOnly="@operationalViewOnly"
                                            FocusViewEnabled="@focusViewEnabled"
                                            FocusNodeId="@selectedNodeId"
                                            FocusIncludeDownstream="@focusIncludeDownstream" />
                            @if (isLoading && hasLoaded)
                            {
                                <div class="topology-reload-overlay" aria-live="polite">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Style="width: 40px; height: 40px;" />
                                    <MudText Typo="Typo.caption" Class="mt-2">Refreshing view…</MudText>
                                </div>
                            }
                        </div>

                        @if (inspectorOpen && inspectorNodeId is not null)
                        {
                            var nodeId = inspectorNodeId;
                            activeMetrics.TryGetValue(nodeId, out var nodeMetricsSnapshot);
                            var binMetrics = BuildInspectorBinMetrics(nodeId, nodeMetricsSnapshot);
                            var metricBlocks = BuildInspectorMetricBlocks(nodeId);
                            var seriesNode = windowData?.Nodes.FirstOrDefault(node => string.Equals(node.Id, nodeId, StringComparison.OrdinalIgnoreCase));
                            var constraintIds = ExtractConstraintIds(seriesNode);
                            var constraintBlocks = BuildInspectorConstraintBlocks(nodeId, selectedConstraintId);
                            var allMetricBlocks = metricBlocks.Concat(constraintBlocks).ToList();
                            var metricsHaveSeries = allMetricBlocks.Any(block => !block.IsPlaceholder);
                            var hasSparklineSeries = allMetricBlocks.Any(block => !block.IsPlaceholder && block.Sparkline is not null);
                            var topoNodeInfo = FindTopologyNode(nodeId);
                            var nodeCategory = ResolveNodeCategory(topoNodeInfo, seriesNode);
                            var nodeIdentity = ResolveAnalyticalIdentity(topoNodeInfo, seriesNode);
                            var nodeKind = ResolveNodeDisplayKind(topoNodeInfo, seriesNode);
                            var nodeRoleLabel = ResolveNodeRoleLabel(topoNodeInfo, seriesNode);
                            var expressionText = topoNodeInfo?.Semantics?.Expression;
                            var hasExpressionText = !string.IsNullOrWhiteSpace(expressionText);
                            var showExpressionSection = IsExpressionNode(nodeCategory, nodeIdentity);
                            var isComputedNode = IsComputedCategory(nodeCategory);
                            var dependencyRows = BuildInspectorDependencies(nodeId);
                            var inspectorWarnings = GetInspectorWarnings(nodeId);
                            var inspectorTabs = GetInspectorTabs(showExpressionSection);
                            var inspectorTabIndex = GetInspectorTabIndex(inspectorTab, inspectorTabs);

                            <MudPaper Class="topology-inspector topology-inspector-panel" Elevation="1" Style="width: 360px; flex: 0 0 360px;">
                                <MudStack Class="pa-4 topology-inspector-content" Spacing="2">
                                    <div class="topology-inspector-header">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.h6" Class="topology-inspector-title">@nodeId</MudText>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                               Color="Color.Secondary"
                                                               Size="Size.Small"
                                                               OnClick="CloseInspector" />
                                            </MudStack>
                                        </MudStack>
                                    </div>
	                                    <div class="topology-role-chip-row">
	                                        <MudText Typo="Typo.caption" Class="topology-kind-label">Kind</MudText>
	                                        <span class="class-chip topology-kind-chip">@FormatNodeKindLabel(nodeKind)</span>
	                                        @if (!string.IsNullOrWhiteSpace(nodeRoleLabel))
	                                        {
	                                            <span class="class-chip topology-role-chip" data-testid="sink-role-chip">@nodeRoleLabel</span>
	                                        }
	                                    </div>

                                    @if (nodeClassContributions.TryGetValue(nodeId, out var classChips) && classChips.Count > 0)
                                    {
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.subtitle2">Classes</MudText>
                                            @{
                                                var visibleChips = classChips.Take(6).ToList();
                                                var overflow = classChips.Count - visibleChips.Count;
                                            }
                                            <div class="inspector-class-selector">
                                                @foreach (var chip in visibleChips)
                                                {
                                                    var isSelected = IsClassSelectedChip(chip.Id);
                                                    var chipClass = $"class-chip{(isSelected ? " class-chip--selected" : string.Empty)}";
                                                    <button type="button"
                                                            class="@chipClass"
                                                            data-testid="inspector-class-chip">
                                                        <span class="class-chip-name">@ResolveClassLabel(chip.Id)</span>
                                                        <span class="class-chip-metrics">@FormatClassChipMetrics(chip)</span>
                                                    </button>
                                                }
                                                @if (overflow > 0)
                                                {
                                                    <button type="button" class="class-chip">
                                                        +@overflow more
                                                    </button>
                                                }
                                            </div>
                                        </MudStack>
                                    }

                                    @if (constraintIds.Count > 0)
                                    {
                                        <div class="topology-role-chip-row">
                                            <MudText Typo="Typo.caption" Class="topology-kind-label">Constraints</MudText>
                                            <div class="inspector-constraint-selector">
                                                @foreach (var constraintId in constraintIds)
                                                {
                                                    var isSelected = string.Equals(selectedConstraintId, constraintId, StringComparison.OrdinalIgnoreCase);
                                                    var chipClass = $"constraint-chip{(isSelected ? " constraint-chip--selected" : string.Empty)}";
                                                    <button type="button"
                                                            class="@chipClass"
                                                            @onclick="@(() => SelectConstraint(constraintId))">
                                                        <span class="constraint-chip-prefix">C</span>
                                                        <span class="constraint-chip-sep">|</span>
                                                        <span class="constraint-chip-name">@constraintId</span>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="constraint-chip-note">
