{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "FlowTimeApi": {
    "BaseUrl": "http://localhost:8080/",
    "ApiVersion": "v1",
    "TimeoutMinutes": 1.0
  },
  "FlowTimeSimApi": {
    "BaseUrl": "http://localhost:8090/",
    "FallbackUrls": [
      "http://localhost:8091/"
    ],
    "ApiVersion": "v1",
    "TimeoutMinutes": 1.0
  },
  "Diagnostics": {
    "Hover": {
      "EnableOverlay": true,
      "AutoUploadEnabled": true,
      "UploadIntervalSeconds": 10,
      "UploadPath": "v1/diagnostics/hover"
    }
  },
  "AllowedHosts": "*"
}
